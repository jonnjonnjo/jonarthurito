---
import '../styles/global.css'
interface Props {
  title?: string;
}

const { title = "Jonathan Arthurito" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
<script is:inline>
  const saved = localStorage.getItem('theme');
  if (saved) {
    document.documentElement.classList.add(`theme-${saved}`);
  } else {
    const themes = ['wave', 'dragon', 'lotus'];
    const random = themes[Math.floor(Math.random() * themes.length)];
    localStorage.setItem('theme', random);
    document.documentElement.classList.add(`theme-${random}`);
  }
</script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  <link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
/>  <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/aaaakshat/cm-web-fonts@latest/fonts.css" />
  </head>
  <body class="bg-kanagawa-bgDim text-kanagawa-fg font-mono h-screen w-screen ">
    <slot />
<script>
  let leaderActive = false;
  let leaderTimeout: ReturnType<typeof setTimeout> | null = null;

  document.addEventListener('keydown', (e) => {
    // 1. Always ignore if the user is typing in an input or textarea
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) {
      return;
    }

    const path = window.location.pathname;

    // 2. Handle the "Leader" key (Space)
    if (e.code === 'Space') {
      // Prevent the page from scrolling down when using space as a leader
      e.preventDefault();
      
      leaderActive = true;

      // Reset the leader state after 700ms if 'q' isn't pressed
      if (leaderTimeout) clearTimeout(leaderTimeout);
      leaderTimeout = setTimeout(() => {
        leaderActive = false;
      }, 700);
      return;
    }

    // 3. Handle the "Action" key (Q) if leader is active
    if (leaderActive && e.key.toLowerCase() === 'q') {
      e.preventDefault();
      leaderActive = false;
      if (leaderTimeout) clearTimeout(leaderTimeout);

      if (path === '/blog' || path === '/blog/') {
        // From blog list -> Home
        window.location.href = '/';
      } else if (path.startsWith('/blog/')) {
        // From a specific post -> Blog list
        window.location.href = '/blog';
      }
    } else {
      // If any other key is pressed, cancel the leader state immediately
      leaderActive = false;
      if (leaderTimeout) clearTimeout(leaderTimeout);
    }
  });
</script>
  </body>
</html>
