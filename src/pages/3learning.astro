  hardware:    { label: 'Hardware',     color: '#a3e635' },
};

// ═══════════════════════════════════════════════════════
//  NODE DATA  (id, label, category, description, resources)
// ═══════════════════════════════════════════════════════
const NODES = [
  // ── PHILOSOPHY ──────────────────────────────────────
  { id:'ph_logic',      label:'Logic',                 cat:'philosophy',
