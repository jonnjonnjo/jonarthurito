      <div class="panel-section-title">Unlocks</div>
      <div id="panel-unlocks"></div>
    </div>
    <div class="panel-section" id="resources-section">
      <div class="panel-section-title">Study Resources</div>
      <div id="panel-resources"></div>
    </div>
  </div>
</div>

<!-- ── LEGEND ── -->
<div id="legend"></div>
<div id="node-count"></div>

<script>
