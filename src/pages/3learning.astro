    res:['Metaphysics — Van Inwagen','The Problems of Philosophy — Russell','Metaphysics: An Introduction — Hospers'] },

  { id:'ph_ethics',     label:'Ethics',                cat:'philosophy',
    desc:'Normative theories: utilitarianism, Kantian deontology, virtue ethics. Meta-ethics: moral realism, relativism, emotivism.',
    res:['The Elements of Moral Philosophy — Rachels','Groundwork of the Metaphysics of Morals — Kant','Ethics: Theory & Practice — Thiroux'] },

  { id:'ph_modern',     label:'Modern Philosophy',     cat:'philosophy',
    desc:'Descartes, Hume, Locke, Leibniz, Spinoza, Kant. Rationalism vs. empiricism. The Copernican revolution in philosophy.',
