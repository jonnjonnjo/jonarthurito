// ═══════════════════════════════════════════════════════
//  BUILD CYTOSCAPE ELEMENTS
// ═══════════════════════════════════════════════════════
function buildElements() {
  const nodes = NODES.map(n => ({
    data: { id: n.id, label: n.label, cat: n.cat,
            desc: n.desc, res: n.res }
  }));
  const edges = EDGES.map(([s,t], i) => ({
    data: { id: `e${i}`, source: s, target: t }
  }));
  return [...nodes, ...edges];
}

// ═══════════════════════════════════════════════════════
//  CYTOSCAPE INIT
// ═══════════════════════════════════════════════════════
const cy = cytoscape({
  container: document.getElementById('cy'),
  elements: buildElements(),
  style: [
    {
      selector: 'node',
      style: {
        'background-color': ele => CATS[ele.data('cat')].color,
        'border-width': 2,
        'border-color': ele => CATS[ele.data('cat')].color + '88',
        'width': 110, 'height': 36,
        'shape': 'round-rectangle',
        'label': 'data(label)',
        'text-valign': 'center', 'text-halign': 'center',
        'font-family': 'JetBrains Mono, monospace',
        'font-size': '9px',
        'font-weight': '400',
        'color': '#07091299',
        'text-wrap': 'wrap',
        'text-max-width': '100px',
        'padding': '4px',
        'transition-property': 'opacity, border-width, border-color',
        'transition-duration': '0.15s',
      }
    },
    {
      selector: 'node:selected',
      style: {
        'border-width': 3,
        'border-color': '#ffffff',
        'color': '#070912',
        'font-weight': '500',
      }
    },
    {
      selector: 'node.highlighted',
      style: {
        'border-width': 2.5,
        'border-color': '#ffffff99',
        'opacity': 1,
      }
    },
    {
      selector: 'node.dimmed',
      style: { 'opacity': 0.2 }
    },
    {
      selector: 'node.search-match',
      style: {
        'border-width': 3,
        'border-color': '#ffffff',
        'background-color': '#ffffff',
        'color': '#070912',
      }
    },
    {
      selector: 'edge',
      style: {
        'width': 1.2,
        'line-color': '#1e2540',
        'target-arrow-color': '#2e3660',
        'target-arrow-shape': 'triangle',
        'arrow-scale': 0.8,
        'curve-style': 'bezier',
        'opacity': 0.7,
        'transition-property': 'opacity, line-color',
        'transition-duration': '0.15s',
      }
    },
    {
      selector: 'edge.prereq-edge',
      style: { 'line-color': '#a78bfa88', 'target-arrow-color': '#a78bfaaa', 'width': 2, 'opacity': 1 }
    },
    {
      selector: 'edge.unlocks-edge',
      style: { 'line-color': '#fbbf2488', 'target-arrow-color': '#fbbf24aa', 'width': 2, 'opacity': 1 }
    },
    {
      selector: 'edge.dimmed',
      style: { 'opacity': 0.05 }
    }
  ],
  layout: {
    name: 'breadthfirst',
    directed: true,
    padding: 40,
    spacingFactor: 1.25,
    avoidOverlap: true,
    nodeDimensionsIncludeLabels: true,
  },
  wheelSensitivity: 0.3,
  minZoom: 0.08,
  maxZoom: 3,
});

// ═══════════════════════════════════════════════════════
//  PANEL LOGIC
// ═══════════════════════════════════════════════════════
const panel = document.getElementById('panel');
const panelTitle = document.getElementById('panel-title');
const panelCatBadge = document.getElementById('panel-cat-badge');
const panelDesc = document.getElementById('panel-desc');
const panelPrereqs = document.getElementById('panel-prereqs');
const panelUnlocks = document.getElementById('panel-unlocks');
const panelResources = document.getElementById('panel-resources');

function openPanel(node) {
  const d = node.data();
  const cat = CATS[d.cat];

  panelCatBadge.textContent = cat.label;
  panelCatBadge.style.background = cat.color + '22';
  panelCatBadge.style.color = cat.color;
  panelCatBadge.style.borderLeft = `3px solid ${cat.color}`;

  panelTitle.textContent = d.label;
  panelDesc.textContent = d.desc;

  // Prerequisites (incoming neighbors)
  const prereqs = node.incomers('node');
  panelPrereqs.innerHTML = '';
  if (prereqs.length === 0) {
    panelPrereqs.innerHTML = '<span style="color:#6b7a9e;font-size:12px;font-style:italic">None — this is a root topic</span>';
  } else {
    prereqs.forEach(n => {
      const c = CATS[n.data('cat')].color;
      const chip = document.createElement('div');
      chip.className = 'node-chip';
      chip.innerHTML = `<span class="chip-dot" style="background:${c}"></span>${n.data('label')}`;
      chip.onclick = () => { cy.$(':selected').unselect(); n.select(); n.emit('tap'); };
      panelPrereqs.appendChild(chip);
    });
  }

  // Unlocks (outgoing neighbors)
  const unlocks = node.outgoers('node');
  panelUnlocks.innerHTML = '';
  if (unlocks.length === 0) {
    panelUnlocks.innerHTML = '<span style="color:#6b7a9e;font-size:12px;font-style:italic">Frontier — no further steps mapped</span>';
  } else {
    unlocks.forEach(n => {
      const c = CATS[n.data('cat')].color;
      const chip = document.createElement('div');
      chip.className = 'node-chip';
      chip.innerHTML = `<span class="chip-dot" style="background:${c}"></span>${n.data('label')}`;
      chip.onclick = () => { cy.$(':selected').unselect(); n.select(); n.emit('tap'); };
      panelUnlocks.appendChild(chip);
    });
  }

  // Resources
  panelResources.innerHTML = '';
  (d.res || []).forEach((r, i) => {
    const item = document.createElement('div');
    item.className = 'resource-item';
    item.innerHTML = `<span class="resource-num">${i+1}.</span><span>${r}</span>`;
    panelResources.appendChild(item);
  });

  panel.classList.add('open');

  // Highlight connected nodes
  cy.elements().removeClass('highlighted dimmed prereq-edge unlocks-edge');
  const connected = node.neighborhood().add(node);
  cy.elements().not(connected).addClass('dimmed');
  node.incomers('edge').addClass('prereq-edge');
  node.outgoers('edge').addClass('unlocks-edge');
  node.neighborhood('node').addClass('highlighted');
}

function closePanel() {
  panel.classList.remove('open');
  cy.elements().removeClass('highlighted dimmed prereq-edge unlocks-edge');
  cy.$(':selected').unselect();
}

cy.on('tap', 'node', e => { e.target.select(); openPanel(e.target); });
cy.on('tap', e => { if (e.target === cy) closePanel(); });
document.getElementById('close-panel').onclick = closePanel;
document.getElementById('fit-btn').onclick = () => cy.fit(40);

// ═══════════════════════════════════════════════════════
//  CATEGORY FILTERS
// ═══════════════════════════════════════════════════════
const activeFilters = new Set(Object.keys(CATS));
const filtersEl = document.getElementById('filters');

Object.entries(CATS).forEach(([key, cat]) => {
  const btn = document.createElement('button');
  btn.className = 'filter-btn active';
  btn.innerHTML = `<span class="dot" style="background:${cat.color}"></span>${cat.label}`;
  btn.style.color = cat.color;
  btn.onclick = () => {
    if (activeFilters.has(key)) {
      if (activeFilters.size === 1) return; // keep at least 1
      activeFilters.delete(key);
      btn.classList.remove('active');
      btn.style.color = 'var(--muted)';
    } else {
      activeFilters.add(key);
      btn.classList.add('active');
      btn.style.color = cat.color;
    }
    applyFilter();
  };
  filtersEl.appendChild(btn);
});

function applyFilter() {
  cy.nodes().forEach(n => {
    const show = activeFilters.has(n.data('cat'));
    n.style('display', show ? 'element' : 'none');
  });
  cy.edges().forEach(e => {
    const srcVisible = activeFilters.has(e.source().data('cat'));
    const tgtVisible = activeFilters.has(e.target().data('cat'));
    e.style('display', (srcVisible && tgtVisible) ? 'element' : 'none');
  });
}

// ═══════════════════════════════════════════════════════
//  SEARCH
// ═══════════════════════════════════════════════════════
document.getElementById('search').addEventListener('input', e => {
  const q = e.target.value.trim().toLowerCase();
  cy.nodes().removeClass('search-match dimmed');
  if (!q) return;
  cy.nodes().forEach(n => {
    const matches = n.data('label').toLowerCase().includes(q) ||
                    n.data('desc').toLowerCase().includes(q) ||
                    n.data('cat').toLowerCase().includes(q);
    n.addClass(matches ? 'search-match' : 'dimmed');
  });
  cy.edges().forEach(e => {
    const visible = !e.source().hasClass('dimmed') && !e.target().hasClass('dimmed');
    e.style('opacity', visible ? 0.7 : 0.05);
  });
});

// ═══════════════════════════════════════════════════════
//  LEGEND
// ═══════════════════════════════════════════════════════
const legendEl = document.getElementById('legend');
Object.entries(CATS).forEach(([, cat]) => {
  const item = document.createElement('div');
  item.className = 'legend-item';
  item.innerHTML = `<span class="legend-dot" style="background:${cat.color}"></span>${cat.label}`;
  legendEl.appendChild(item);
});

