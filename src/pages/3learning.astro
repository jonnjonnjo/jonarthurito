  // ── MATHEMATICS ─────────────────────────────────────
  { id:'ma_arithmetic', label:'Arithmetic',            cat:'mathematics',
    desc:'Integers, rationals, reals, number bases, primes, divisibility, fractions, decimals, basic operations. The absolute foundation.',
    res:['Art of Problem Solving Vol. 1 — Rusczyk','Khan Academy (free)','Number: The Language of Science — Dantzig'] },

  { id:'ma_algebra_basic', label:'Algebra',            cat:'mathematics',
