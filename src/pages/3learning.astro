<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <title>Atlas of Knowledge — Learning DAG</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cytoscape/3.28.1/cytoscape.min.js"></script>
  <style>
    :root {
      --bg:       #07091280;
      --surface:  #0e1120;
      --surface2: #151929;
      --border:   #1e2540;
      --text:     #e2e8f7;
      --muted:    #6b7a9e;
      --accent:   #6366f1;

      --c-philosophy: #c084fc;
      --c-mathematics: #60a5fa;
      --c-physics:     #34d399;
      --c-linguistics: #fb923c;
      --c-cs:          #f472b6;
      --c-ai:          #fbbf24;
      --c-hardware:    #a3e635;

      --panel-w: 340px;
      --toolbar-h: 56px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%; overflow: hidden;
      background: #070912;
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
    }

    /* ── Starfield BG ── */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image:
        radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,.15) 0%, transparent 100%),
        radial-gradient(1px 1px at 80% 10%, rgba(255,255,255,.1) 0%, transparent 100%),
        radial-gradient(1px 1px at 50% 70%, rgba(255,255,255,.12) 0%, transparent 100%),
        radial-gradient(1px 1px at 10% 90%, rgba(255,255,255,.08) 0%, transparent 100%),
        radial-gradient(1px 1px at 70% 50%, rgba(255,255,255,.1) 0%, transparent 100%),
        radial-gradient(600px 600px at 80% 80%, rgba(99,102,241,.04) 0%, transparent 100%),
        radial-gradient(800px 800px at 20% 20%, rgba(96,165,250,.03) 0%, transparent 100%);
    }

    /* ── Toolbar ── */
    #toolbar {
      position: fixed; top: 0; left: 0; right: 0; height: var(--toolbar-h);
      background: rgba(7,9,18,.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 12px; padding: 0 16px;
      z-index: 100;
    }

    #logo {
      font-family: 'Lora', serif;
      font-style: italic;
      font-size: 16px;
      color: var(--text);
      white-space: nowrap;
      letter-spacing: .02em;
      min-width: max-content;
    }
    #logo span { color: var(--accent); font-style: normal; }

    #search-wrap { position: relative; flex: 1; max-width: 260px; }
    #search {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 7px 12px 7px 34px;
      color: var(--text);
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      outline: none;
      transition: border-color .2s;
    }
    #search:focus { border-color: var(--accent); }
    #search::placeholder { color: var(--muted); }
    #search-icon {
      position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
      color: var(--muted); font-size: 13px; pointer-events: none;
    }

    #filters {
      display: flex; gap: 6px; align-items: center; overflow-x: auto;
      scrollbar-width: none;
    }
    #filters::-webkit-scrollbar { display: none; }

    .filter-btn {
      display: flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 20px; border: 1px solid transparent;
      background: var(--surface2);
      font-size: 11px; font-family: 'Space Grotesk', sans-serif;
      font-weight: 500; cursor: pointer;
      transition: all .18s; white-space: nowrap;
      color: var(--muted);
    }
    .filter-btn .dot { width: 7px; height: 7px; border-radius: 50%; }
    .filter-btn.active { color: var(--text); border-color: currentColor; }
    .filter-btn:hover { color: var(--text); }

    #fit-btn {
      margin-left: auto;
      padding: 5px 10px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--muted);
      cursor: pointer;
      font-size: 11px;
      font-family: 'Space Grotesk', sans-serif;
      white-space: nowrap;
      transition: all .18s;
    }
    #fit-btn:hover { color: var(--text); border-color: var(--accent); }

    /* ── Cytoscape Canvas ── */
    #cy {
      position: fixed;
      top: var(--toolbar-h); left: 0;
      right: 0; bottom: 0;
      z-index: 1;
    }

    /* ── Info Panel ── */
    #panel {
      position: fixed;
      top: var(--toolbar-h); right: 0;
      width: var(--panel-w); bottom: 0;
      background: rgba(14,17,32,.97);
      backdrop-filter: blur(16px);
      border-left: 1px solid var(--border);
      transform: translateX(100%);
      transition: transform .3s cubic-bezier(.4,0,.2,1);
      z-index: 50;
      overflow-y: auto;
      display: flex; flex-direction: column;
    }
    #panel.open { transform: translateX(0); }

    #panel-header {
      padding: 20px 20px 16px;
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0;
      background: rgba(14,17,32,.98);
      z-index: 1;
    }
    #panel-cat-badge {
      display: inline-block;
      padding: 2px 8px; border-radius: 4px;
      font-size: 10px; font-weight: 600; letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    #panel-title {
      font-family: 'Lora', serif;
      font-size: 18px; line-height: 1.3;
      color: var(--text);
      margin-bottom: 0;
    }

    #close-panel {
      position: absolute; top: 16px; right: 16px;
      background: var(--surface2); border: 1px solid var(--border);
      color: var(--muted); width: 28px; height: 28px;
      border-radius: 50%; cursor: pointer; font-size: 14px;
      display: flex; align-items: center; justify-content: center;
      transition: all .18s;
    }
    #close-panel:hover { color: var(--text); border-color: var(--muted); }

    #panel-body { padding: 20px; flex: 1; }

    .panel-section { margin-bottom: 20px; }
    .panel-section-title {
      font-size: 10px; letter-spacing: .1em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 8px; font-weight: 600;
    }
    #panel-desc {
      font-family: 'Lora', serif;
      font-size: 13.5px; line-height: 1.7;
      color: #b8c3e0;
    }

    .node-chip {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 8px; border-radius: 6px; margin: 3px 3px 3px 0;
      font-size: 11px; font-family: 'JetBrains Mono', monospace;
      cursor: pointer; transition: opacity .15s;
      background: var(--surface2); border: 1px solid var(--border);
    }
    .node-chip:hover { opacity: .75; }
    .node-chip .chip-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    .resource-item {
      display: flex; align-items: flex-start; gap: 8px;
      padding: 6px 0; border-bottom: 1px solid var(--border);
      font-size: 12px; line-height: 1.45; color: #a0aec5;
    }
    .resource-item:last-child { border-bottom: none; }
    .resource-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; color: var(--muted); min-width: 14px;
      margin-top: 1px;
    }

    /* ── Legend (bottom-left) ── */
    #legend {
      position: fixed; bottom: 16px; left: 16px;
      background: rgba(14,17,32,.9);
      backdrop-filter: blur(8px);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 14px;
      z-index: 50;
      display: grid; grid-template-columns: 1fr 1fr; gap: 5px 16px;
    }
    .legend-item {
      display: flex; align-items: center; gap: 6px;
      font-size: 10.5px; color: var(--muted); white-space: nowrap;
    }
    .legend-dot { width: 8px; height: 8px; border-radius: 50%; }

    /* ── Counter badge ── */
    #node-count {
      position: fixed; bottom: 16px; right: 16px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; color: var(--muted);
      background: rgba(14,17,32,.9);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 4px 10px;
      z-index: 50;
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
      #logo { font-size: 13px; }
      #filters { display: none; }

      #panel {
        top: auto; right: 0; left: 0;
        width: 100%; height: 70vh;
        border-left: none;
        border-top: 1px solid var(--border);
        border-radius: 16px 16px 0 0;
        transform: translateY(100%);
      }
      #panel.open { transform: translateY(0); }

      #legend {
        display: none;
      }
      #node-count { bottom: 8px; right: 8px; }
    }
  </style>
</head>
<body>

<!-- ── TOOLBAR ── -->
<div id="toolbar">
  <div id="logo">Atlas of <span>Knowledge</span></div>
  <div id="search-wrap">
    <span id="search-icon">⌕</span>
    <input id="search" placeholder="Search nodes…" autocomplete="off" spellcheck="false">
  </div>
  <div id="filters"></div>
  <button id="fit-btn" title="Reset view">⊞ Fit</button>
</div>

<!-- ── CYTOSCAPE CANVAS ── -->
<div id="cy"></div>

<!-- ── INFO PANEL ── -->
<div id="panel">
  <div id="panel-header">
    <button id="close-panel">✕</button>
    <div id="panel-cat-badge"></div>
    <h2 id="panel-title"></h2>
  </div>
  <div id="panel-body">
    <div class="panel-section">
      <div class="panel-section-title">Overview</div>
