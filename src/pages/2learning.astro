ai\", \"col\": 15, \"row\": 7, \"l\": \"Multi-agent systems\", \"books\": [{\"a\": \"Wooldridge\", \"t\": \"An Introduction to MultiAgent Systems\", \"n\": \"The standard text.\"}, {\"a\": \"Shoham & Leyton-Brown\", \"t\": \"Multiagent Systems (free online)\", \"n\": \"Deep treatment. Free online.\"}]}, {\"id\": \"formalverif\", \"d\": \"ai\", \"col\": 16, \"row\": 6, \"l\": \"Formal verification\", \"books\": [{\"a\": \"Clarke, Grumberg & Peled\", \"t\": \"Model Checking\", \"n\": \"The original model checking book.\"}, {\"a\": \"Baier & Katoen\", \"t\": \"Principles of Model Checking\", \"n\": \"The graduate standard. Very complete.\"}, {\"a\": \"Nipkow, Paulson & Wenzel\", \"t\": \"Isabelle/HOL: A Proof Assistant (free)\", \"n\": \"Interactive theorem proving.\"}]}, {\"id\": \"cogarch\", \"d\": \"ai\", \"col\": 16, \"row\": 7, \"l\": \"Cognitive architectures\", \"books\": [{\"a\": \"Newell\", \"t\": \"Unified Theories of Cognition\", \"n\": \"SOAR foundation. Foundational AGI text.\"}, {\"a\": \"Anderson\", \"t\": \"The Architecture of Cognition\", \"n\": \"ACT-R. Psychological grounding.\"}, {\"a\": \"Laird\", \"t\": \"The Soar Cognitive Architecture\", \"n\": \"Modern definitive SOAR reference.\"}]}, {\"id\": \"nonmon\", \"d\": \"ai\", \"col\": 14, \"row\": 7, \"l\": \"Non-monotonic reasoning\", \"books\": [{\"a\": \"Reiter\", \"t\": \"A Logic for Default Reasoning (paper)\", \"n\": \"The foundational paper. Free.\"}, {\"a\": \"Brewka, Dix & Konolige\", \"t\": \"Nonmonotonic Reasoning\", \"n\": \"Broad survey.\"}, {\"a\": \"Lifschitz\", \"t\": \"Answer Set Programming (free draft)\", \"n\": \"ASP \\u2014 the practical non-monotonic framework.\"}]}, {\"id\": \"aixi\", \"d\": \"ai\", \"col\": 16, \"row\": 8, \"l\": \"Universal AI (AIXI)\", \"books\": [{\"a\": \"Hutter\", \"t\": \"Universal Artificial Intelligence\", \"n\": \"The AIXI book. Requires heavy math.\"}, {\"a\": \"Li & Vit\\u00e1nyi\", \"t\": \"An Introduction to Kolmogorov Complexity and Its Applications\", \"n\": \"The prerequisite mathematical foundation.\"}, {\"a\": \"Solomonoff\", \"t\": \"A Formal Theory of Inductive Inference (paper)\", \"n\": \"The original inductive inference paper.\"}]}]";
