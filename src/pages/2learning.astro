, \"row\": 3, \"l\": \"Metric & topological spaces\", \"books\": [{\"a\": \"Munkres\", \"t\": \"Topology\", \"n\": \"The standard topology text. Very clear.\"}, {\"a\": \"Kelley\", \"t\": \"General Topology\", \"n\": \"More advanced. Classic reference.\"}, {\"a\": \"Sutherland\", \"t\": \"Introduction to Metric and Topological Spaces\", \"n\": \"Gentler entry before Munkres.\"}]}, {\"id\": \"complex\", \"d\": \"math\", \"col\": 3, \"row\": 4, \"l\": \"Complex analysis\", \"books\": [{\"a\": \"Ahlfors\", \"t\": \"Complex Analysis\", \"n\": \"The classic rigorous text. Mandatory.\"}, {\"a\": \"Conway\", \"t\": \"Functions of One Complex Variable\", \"n\": \"More modern, gentler companion to Ahlfors.\"}, {\"a\": \"Markushevich\", \"t\": \"Theory of Functions of a Complex Variable (3 vols)\", \"n\": \"Russian encyclopedic treatment. Deepest reference.\"}]}, {\"id\": \"measure\", \"d\": \"math\", \"col\": 5, \"row\": 4, \"l\": \"Measure & integration\", \"books\": [{\"a\": \"Royden\", \"t\": \"Real Analysis\", \"n\": \"Standard US graduate text.\"}, {\"a\": \"Halmos\", \"t\": \"Measure Theory\", \"n\": \"Elegant abstract treatment.\"}, {\"a\": \"Kolmogorov & Fomin\", \"t\": \"Elements of the Theory of Functions and Functional Analysis\", \"n\": \"Russian. Covers both measure and functional analysis.\"}]}, {\"id\": \"absalg\", \"d\": \"math\", \"col\": 7, \"row\": 2, \"l\": \"Abstract algebra\", \"books\": [{\"a\": \"Lang\", \"t\": \"Algebra\", \"n\": \"The hardest and most complete standard. Graduate benchmark.\"}, {\"a\": \"Vinberg\", \"t\": \"A Course in Algebra\", \"n\": \"Russian. Gentler than Lang but still rigorous.\"}, {\"a\": \"Kostrikin\", \"t\": \"Introduction to Algebra\", \"n\": \"Russian 3-volume series. Very thorough.\"}, {\"a\": \"Jacobson\", \"t\": \"Basic Algebra I & II\", \"n\": \"Deep classical reference.\"}]}, {\"id\": \"numthy\", \"d\": \"math\", \"col\": 7, \"row\": 3, \"l\": \"Number theory\", \"books\": [{\"a\": \"Hardy & Wright\", \"t\": \"An Introduction to the Theory of Numbers\", \"n\": \"The classic. Covers everything elementary and beyond.\"}, {\"a\": \"Ireland & Rosen\", \"t\": \"A Classical Introduction to Modern Number Theory\", \"n\": \"Algebraic number theory entry. Rigorous.\"}, {\"a\": \"Serre\", \"t\": \"A Course in Arithmetic\", \"n\": \"Short, deep, beautiful.\"}]}, {\"id\": \"combin\", \"d\": \"math\", \"col\": 6, \"row\": 3, \"l\": \"Combinatorics\", \"books\": [{\"a\": \"Stanley\", \"t\": \"Enumerative Combinatorics I & II\", \"n\": \"The definitive graduate reference.\"}, {\"a\": \"Alon & Spencer\", \"t\": \"The Probabilistic Method\", \"n\": \"Probabilistic combinatorics. Essential for complexity theory.\"}, {\"a\": \"van Lint & Wilson\", \"t\": \"A Course in Combinatorics\", \"n\": \"Broad classical treatment.\"}]}, {\"id\": \"prob\", \"d\": \"math\", \"col\": 5, \"row\": 5, \"l\": \"Probability theory\", \"books\": [{\"a\": \"Billingsley\", \"t\": \"Probability and Measure\", \"n\": \"Measure-theoretic probability. The rigorous standard.\"}, {\"a\": \"Shiryaev\", \"t\": \"Probability\", \"n\": \"Russian. Deep, complete, very rigorous.\"}, {\"a\": \"Feller\", \"t\": \"An Introduction to Probability Theory I & II\", \"n\": \"Classical, very intuitive yet rigorous.\"}]}, {\"id\": \"catthy\", \"d\": \"math\", \"col\": 6, \"row\": 5, \"l\": \"Category theory\", \"books\": [{\"a\": \"Mac Lane\", \"t\": \"Categories for the Working Mathematician\", \"n\": \"The original. Mandatory.\"}, {\"a\": \"Riehl\", \"t\": \"Category Theory in Context\", \"n\": \"More accessible but fully rigorous.\"}, {\"a\": \"Awodey\", \"t\": \"Category Theory\", \"n\": \"Philosophical in flavor. Good complement.\"}, {\"a\": \"Jacobs\", \"t\": \"Categorical Logic and Type Theory\", \"n\": \"For the CS/AI bridge. Very technical.\"}]}, {\"id\": \"mathlog\", \"d\": \"math\", \"col\": 4, \"row\": 5, \"l\": \"Mathematical logic\", \"books\": [{\"a\": \"Shoenfield\", \"t\": \"Mathematical Logic\", \"n\": \"The hard classic.