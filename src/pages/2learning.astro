  <meta name="viewport" content="width=device-width,initial-scale=1.0,user-scalable=no"/>
  <title>Learning DAG</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;font-family:system-ui,sans-serif;background:#f8f8f6;color:#111;overflow:hidden;touch-action:none}
    #toolbar{display:flex;flex-wrap:wrap;gap:5px;padding:8px 10px;align-items:center;background:#fff;border-bottom:1px solid #e8e8e8}
    .df{font-size:10px;padding:3px 8px;border-radius:12px;border:1.5px solid;background:transparent;cursor:pointer;font-family:inherit;font-weight:600;touch-action:manipulation}
    .df.off{opacity:0.18}
    #zbx{display:flex;gap:4px;margin-left:auto}
    .zb{font-size:14px;padding:3px 11px;border:1px solid #ccc;border-radius:6px;background:#fff;color:#111;cursor:pointer;font-family:inherit;touch-action:manipulation}
    #hint{font-size:10px;color:#999;padding:3px 10px;background:#fff;border-bottom:1px solid #eee;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    #co{position:fixed;top:0;left:0;width:100%;height:100%;overflow:hidden;touch-action:none}
    #sw{position:absolute;top:0;left:0;transform-origin:0 0;will-change:transform}
    svg{display:block;overflow:visible}
    .nd{cursor:pointer}

    /* panel — full-screen on mobile, sidebar on wide */
    #panel{
      display:none;position:fixed;z-index:50;
      background:#fff;overflow-y:auto;
      box-shadow:0 -4px 24px rgba(0,0,0,0.12);
      flex-direction:column;
    }
    #panel.open{display:flex}
    /* mobile: slide up from bottom */
    @media(max-width:640px){
      #panel{bottom:0;left:0;right:0;height:65vh;border-radius:16px 16px 0 0;border-top:1px solid #e0e0e0}
      #ph{padding:10px 16px 8px;border-bottom:1px solid #eee;position:sticky;top:0;background:#fff}
      #drag-handle{width:36px;height:4px;background:#ccc;border-radius:2px;margin:0 auto 10px}
    }
    /* desktop: sidebar */
    @media(min-width:641px){
      #panel{top:0;right:0;width:310px;height:100%;border-left:1px solid #e0e0e0;border-radius:0;box-shadow:-4px 0 16px rgba(0,0,0,0.07)}
      #ph{padding:14px 14px 10px;border-bottom:1px solid #eee;position:sticky;top:0;background:#fff}
      #drag-handle{display:none}
    }

    #pcl{float:right;font-size:22px;line-height:1;background:none;border:none;cursor:pointer;color:#aaa;padding:0 2px;font-family:inherit;touch-action:manipulation}
    #pcl:hover{color:#333}
    #pd{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px}
    #pt{font-size:16px;font-weight:700;line-height:1.3}
    #pb{padding:12px 14px 32px;display:flex;flex-direction:column;gap:10px}

    /* toolbar sits above canvas */
    #ui-layer{position:fixed;top:0;left:0;right:0;z-index:40;pointer-events:none}
    #ui-layer>*{pointer-events:all}
  </style>
</head>
<body>
<div id="co"><div id="sw"></div></div>

<div id="ui-layer">
  <div id="toolbar">
    <button class="df" data-d="math"  style="border-color:#3B6D11;color:#3B6D11">Math</button>
    <button class="df" data-d="phil"  style="border-color:#185FA5;color:#185FA5">Phil</button>
    <button class="df" data-d="phys"  style="border-color:#993C1D;color:#993C1D">Phys</button>
    <button class="df" data-d="ling"  style="border-color:#854F0B;color:#854F0B">Ling</button>
    <button class="df" data-d="cs"    style="border-color:#0F6E56;color:#0F6E56">CS</button>
    <button class="df" data-d="hw"    style="border-color:#72243E;color:#72243E">HW</button>
    <button class="df" data-d="ai"    style="border-color:#534AB7;color:#534AB7">AI</button>
    <div id="zbx">
      <button class="zb" id="zin">+</button>
      <button class="zb" id="zout">&#8722;</button>
      <button class="zb" id="zreset">fit</button>
    </div>
  </div>
  <div id="hint">pinch/scroll=zoom &middot; drag=pan &middot; tap node=books+highlight</div>
</div>

<div id="panel">
  <div id="ph">
    <div id="drag-handle"></div>
    <button id="pcl">&#215;</button>
    <div id="pd"></div>
    <div id="pt"></div>
  </div>
  <div id="pb"></div>
</div>

<script is:inline define:vars={{ nodesJson, edgesJson, domainsJson, svgContent }}>
const NODES   = JSON.parse(nodesJson);
const EDGES   = JSON.parse(edgesJson);
const DOMAINS = JSON.parse(domainsJson);

document.getElementById('sw').innerHTML = svgContent;

const nodeMap = {};
NODES.forEach(n => nodeMap[n.id] = n);

// Direct neighbors only
const directPre = {}, directDep = {};
NODES.forEach(n => { directPre[n.id]=new Set(); directDep[n.id]=new Set(); });
EDGES.forEach(([a,b]) => { directPre[b].add(a); directDep[a].add(b); });

function setNode(id, mode) {
  const r=document.getElementById('r_'+id);
  const g=document.getElementById('nd_'+id);
  if(!r||!g) return;
  const {c,f}=DOMAINS[nodeMap[id].d];
  if(mode==='self')       { g.style.opacity='1'; r.setAttribute('stroke',c); r.setAttribute('stroke-width','3'); r.setAttribute('fill',f); }
  else if(mode==='pre')   { g.style.opacity='1'; r.setAttribute('stroke','#c97b00'); r.setAttribute('stroke-width','2.5'); r.setAttribute('fill','#fff9ee'); }
  else if(mode==='dep')   { g.style.opacity='1'; r.setAttribute('stroke','#1a7a4a'); r.setAttribute('stroke-width','2.5'); r.setAttribute('fill','#edfaf3'); }
  else if(mode==='dim')   { g.style.opacity='0.1'; r.setAttribute('stroke',c); r.setAttribute('stroke-width','1.2'); r.setAttribute('fill',f); }
  else                    { g.style.opacity='1'; r.setAttribute('stroke',c); r.setAttribute('stroke-width','1.2'); r.setAttribute('fill',f); }
}

function setEdge(el, mode) {
  const src=el.dataset.src; const tgt=el.dataset.tgt;
  const na=nodeMap[src]; const cross=na&&nodeMap[tgt]&&na.d!==nodeMap[tgt].d;
  const origCol=cross?'#9c87e0':DOMAINS[na?.d]?.c||'#999';
  if(mode==='pre')  { el.style.opacity='1'; el.setAttribute('stroke-width','2.2'); el.setAttribute('stroke','#c97b00'); }
  else if(mode==='dep') { el.style.opacity='1'; el.setAttribute('stroke-width','2.2'); el.setAttribute('stroke','#1a7a4a'); }
  else if(mode==='dim') { el.style.opacity='0.04'; el.setAttribute('stroke-width','1.2'); el.setAttribute('stroke',origCol); }
  else                  { el.style.opacity='0.55'; el.setAttribute('stroke-width','1.2'); el.setAttribute('stroke',origCol); }
}

let selectedId=null;
function clearHL() {
  NODES.forEach(n=>setNode(n.id,'normal'));
  document.querySelectorAll('[data-src]').forEach(el=>setEdge(el,'normal'));
}
function applyHL(id) {
  const pres=directPre[id], deps=directDep[id];
  NODES.forEach(n=>{
    if(n.id===id)         setNode(n.id,'self');
    else if(pres.has(n.id)) setNode(n.id,'pre');
    else if(deps.has(n.id)) setNode(n.id,'dep');
    else                  setNode(n.id,'dim');
  });
  document.querySelectorAll('[data-src]').forEach(el=>{
    const s=el.dataset.src,t=el.dataset.tgt;
    if(pres.has(s)&&t===id)  setEdge(el,'pre');
    else if(s===id&&deps.has(t)) setEdge(el,'dep');
    else                     setEdge(el,'dim');
  });
}

const panel=document.getElementById('panel');
const pd=document.getElementById('pd');
const pt=document.getElementById('pt');
const pb=document.getElementById('pb');

document.getElementById('pcl').addEventListener('click',()=>{
  panel.classList.remove('open'); clearHL(); selectedId=null;
});

function renderPanel(n) {
  const dm=DOMAINS[n.d];
  pd.textContent=dm.name; pd.style.color=dm.c;
  pt.textContent=n.l;    pt.style.color=dm.c;
  pb.innerHTML=n.books.map(b=>`
    <div style="border-radius:8px;border:1.5px solid #ddd;padding:11px 13px 10px;background:#fff">
      <div style="font-size:10.5px;font-weight:700;color:${dm.t};margin-bottom:3px;text-transform:uppercase;letter-spacing:.04em">${b.a}</div>
      <div style="font-size:13px;font-weight:600;color:#111;line-height:1.4;margin-bottom:${b.n?'5px':'0'}">${b.t}</div>
      ${b.n?`<div style="font-size:11.5px;color:#555;line-height:1.55">${b.n}</div>`:''}
    </div>`).join('');
  panel.classList.add('open');
}

// ── tap / click ───────────────────────────────────────────────
let moved=false;
document.getElementById('sw').addEventListener('click',e=>{
  if(moved)return;
  const g=e.target.closest('.nd');
  if(!g){ clearHL();selectedId=null;panel.classList.remove('open');return; }
  const id=g.dataset.id;
  if(id===selectedId){ clearHL();selectedId=null;panel.classList.remove('open');return; }
  selectedId=id; applyHL(id); renderPanel(nodeMap[id]);
});

// ── pan & zoom (mouse + touch) ────────────────────────────────
const co=document.getElementById('co');
const sw=document.getElementById('sw');
// offset by toolbar height so canvas starts below UI
const TOOLBAR_H=()=>document.getElementById('ui-layer').offsetHeight;
let scale=0.65, tx=0, ty=0;
function applyT(){ sw.style.transform=`translate(${tx}px,${ty}px) scale(${scale})`; }
// Start panned so top-left is visible below toolbar
ty=TOOLBAR_H()+8;
applyT();

// mouse
let drag=false,lx=0,ly=0;
co.addEventListener('mousedown',e=>{ drag=true;lx=e.clientX;ly=e.clientY;moved=false; });
window.addEventListener('mousemove',e=>{
  if(!drag)return;
  const dx=e.clientX-lx,dy=e.clientY-ly;
  if(Math.abs(dx)+Math.abs(dy)>3)moved=true;
  tx+=dx;ty+=dy;lx=e.clientX;ly=e.clientY;applyT();
});
window.addEventListener('mouseup',()=>{drag=false;});
co.addEventListener('wheel',e=>{
  e.preventDefault();
  const rect=co.getBoundingClientRect();
  const ox=e.clientX-rect.left,oy=e.clientY-rect.top;
  const d=e.deltaY>0?0.88:1.12;
  const ns=Math.max(0.08,Math.min(5,scale*d));
  tx=ox-(ox-tx)*(ns/scale);ty=oy-(oy-ty)*(ns/scale);scale=ns;applyT();
},{passive:false});

// touch: single-finger pan + pinch zoom
let touches={};
let lastDist=null;
co.addEventListener('touchstart',e=>{
  e.preventDefault();
  moved=false;
  Array.from(e.changedTouches).forEach(t=>{ touches[t.identifier]={x:t.clientX,y:t.clientY}; });
},{passive:false});
co.addEventListener('touchmove',e=>{
  e.preventDefault();
  const ids=Object.keys(touches);
  if(e.touches.length===1){
    const t=e.touches[0];
    const prev=touches[t.identifier];
    if(prev){
      const dx=t.clientX-prev.x, dy=t.clientY-prev.y;
      if(Math.abs(dx)+Math.abs(dy)>3)moved=true;
      tx+=dx;ty+=dy;
    }
    touches[t.identifier]={x:t.clientX,y:t.clientY};
    applyT();
  } else if(e.touches.length===2){
    const t0=e.touches[0],t1=e.touches[1];
    const dist=Math.hypot(t0.clientX-t1.clientX,t0.clientY-t1.clientY);
    if(lastDist){
      moved=true;
      const cx=(t0.clientX+t1.clientX)/2;
      const cy=(t0.clientY+t1.clientY)/2;
      const rect=co.getBoundingClientRect();
      const ox=cx-rect.left,oy=cy-rect.top;
      const ns=Math.max(0.08,Math.min(5,scale*(dist/lastDist)));
      tx=ox-(ox-tx)*(ns/scale);ty=oy-(oy-ty)*(ns/scale);scale=ns;
    }
    lastDist=dist;
    [t0,t1].forEach(t=>{ touches[t.identifier]={x:t.clientX,y:t.clientY}; });
    applyT();
  }
},{passive:false});
co.addEventListener('touchend',e=>{
  Array.from(e.changedTouches).forEach(t=>delete touches[t.identifier]);
  if(e.touches.length<2)lastDist=null;
},{passive:false});

document.getElementById('zin').addEventListener('click',()=>{scale=Math.min(5,scale*1.25);applyT();});
document.getElementById('zout').addEventListener('click',()=>{scale=Math.max(0.08,scale/1.25);applyT();});
document.getElementById('zreset').addEventListener('click',()=>{scale=0.65;tx=0;ty=TOOLBAR_H()+8;applyT();});

// ── domain filter ─────────────────────────────────────────────
let activeDomain=null;
document.querySelectorAll('.df').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const d=btn.dataset.d;
    if(activeDomain===d){
      activeDomain=null;
      document.querySelectorAll('.df').forEach(b=>b.classList.remove('off'));
      NODES.forEach(n=>{document.getElementById('nd_'+n.id).style.opacity='1';});
      document.querySelectorAll('[data-src]').forEach(el=>setEdge(el,'normal'));
    }else{
      if(selectedId){clearHL();selectedId=null;panel.classList.remove('open');}
      activeDomain=d;
      document.querySelectorAll('.df').forEach(b=>b.classList.toggle('off',b.dataset.d!==d));
      NODES.forEach(n=>{document.getElementById('nd_'+n.id).style.opacity=n.d===d?'1':'0.1';});
      document.querySelectorAll('[data-src]').forEach(el=>{
        const sd=nodeMap[el.dataset.src]?.d,td=nodeMap[el.dataset.tgt]?.d;
        setEdge(el,(sd===d||td===d)?'normal':'dim');
      });
    }
  });
});
</script>
</body>
</html>
