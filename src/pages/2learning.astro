<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Learning DAG</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;font-family:system-ui,sans-serif;background:#f8f8f6;color:#111}
    #toolbar{display:flex;flex-wrap:wrap;gap:6px;padding:9px 12px;align-items:center;background:#fff;border-bottom:1px solid #e8e8e8}
    .df{font-size:11px;padding:3px 10px;border-radius:14px;border:1.5px solid;background:transparent;cursor:pointer;transition:opacity .15s;font-family:inherit;font-weight:500}
    .df.off{opacity:0.18}
    #zbx{display:flex;gap:4px;margin-left:auto}
    .zb{font-size:13px;padding:2px 10px;border:1px solid #ccc;border-radius:6px;background:#fff;color:#111;cursor:pointer;font-family:inherit}
    .zb:hover{background:#f0f0f0}
    #hint{font-size:11px;color:#999;padding:4px 12px;background:#fff;border-bottom:1px solid #eee}
    #co{width:100%;height:calc(100vh - 72px);overflow:hidden;cursor:grab;position:relative}
    #co.grabbing{cursor:grabbing}
    #sw{position:absolute;top:0;left:0;transform-origin:0 0}
    svg{display:block;overflow:visible}
    .nd{cursor:pointer}
    #panel{display:none;position:absolute;top:0;right:0;width:310px;height:100%;background:#fff;border-left:1px solid #e0e0e0;overflow-y:auto;z-index:30;box-shadow:-4px 0 16px rgba(0,0,0,0.07);flex-direction:column}
    #panel.open{display:flex}
    #ph{padding:14px 14px 10px;border-bottom:1px solid #eee;position:sticky;top:0;background:#fff;z-index:1}
    #pcl{float:right;font-size:22px;line-height:1;background:none;border:none;cursor:pointer;color:#aaa;padding:0 2px;font-family:inherit}
    #pcl:hover{color:#333}
    #pd{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px}
    #pt{font-size:16px;font-weight:700;line-height:1.3}
    #pb{padding:12px 14px 24px;display:flex;flex-direction:column;gap:10px}
  </style>
</head>
<body>
<div id="toolbar">
  <button class="df" data-d="math"  style="border-color:#3B6D11;color:#3B6D11">Mathematics</button>
  <button class="df" data-d="phil"  style="border-color:#185FA5;color:#185FA5">Philosophy</button>
  <button class="df" data-d="phys"  style="border-color:#993C1D;color:#993C1D">Physics</button>
  <button class="df" data-d="ling"  style="border-color:#854F0B;color:#854F0B">Linguistics</button>
  <button class="df" data-d="cs"    style="border-color:#0F6E56;color:#0F6E56">CS</button>
  <button class="df" data-d="hw"    style="border-color:#72243E;color:#72243E">Hardware</button>
  <button class="df" data-d="ai"    style="border-color:#534AB7;color:#534AB7">AI</button>
  <div id="zbx">
    <button class="zb" id="zin">+</button>
    <button class="zb" id="zout">&#8722;</button>
    <button class="zb" id="zreset">fit</button>
  </div>
</div>
<div id="hint">scroll to zoom &middot; drag to pan &middot; click node = direct neighbors highlighted + books shown &middot; click again to deselect</div>
<div id="co">
  <div id="sw"></div>
  <div id="panel">
    <div id="ph">
      <button id="pcl">&#215;</button>
      <div id="pd"></div>
      <div id="pt"></div>
    </div>
    <div id="pb"></div>
  </div>
</div>

<script is:inline define:vars={{ nodesJson, edgesJson, domainsJson, svgContent }}>
const NODES   = JSON.parse(nodesJson);
const EDGES   = JSON.parse(edgesJson);
const DOMAINS = JSON.parse(domainsJson);

// Inject pre-built SVG (built server-side with correct arc paths)
document.getElementById('sw').innerHTML = svgContent;

const nodeMap = {};
NODES.forEach(n => nodeMap[n.id] = n);

// Direct neighbors only (one hop)
const directPre = {}, directDep = {};
NODES.forEach(n => { directPre[n.id] = new Set(); directDep[n.id] = new Set(); });
EDGES.forEach(([a,b]) => { directPre[b].add(a); directDep[a].add(b); });

// ── highlight via direct JS attribute mutation ────────────────
let selectedId = null;

function setNode(id, mode) {
  const r = document.getElementById('r_'+id);
  const g = document.getElementById('nd_'+id);
  if (!r || !g) return;
  const {c, f} = DOMAINS[nodeMap[id].d];
  if (mode === 'self') {
    g.style.opacity = '1';
    r.setAttribute('stroke', c);
    r.setAttribute('stroke-width', '3');
    r.setAttribute('fill', f);
  } else if (mode === 'pre') {
    // prereqs = amber
    g.style.opacity = '1';
    r.setAttribute('stroke', '#c97b00');
    r.setAttribute('stroke-width', '2.5');
    r.setAttribute('fill', '#fff9ee');
  } else if (mode === 'dep') {
    // dependents = green
    g.style.opacity = '1';
    r.setAttribute('stroke', '#1a7a4a');
    r.setAttribute('stroke-width', '2.5');
    r.setAttribute('fill', '#edfaf3');
  } else if (mode === 'dim') {
    g.style.opacity = '0.1';
    r.setAttribute('stroke', c);
    r.setAttribute('stroke-width', '1.2');
    r.setAttribute('fill', f);
  } else {
    g.style.opacity = '1';
    r.setAttribute('stroke', c);
    r.setAttribute('stroke-width', '1.2');
    r.setAttribute('fill', f);
  }
}

function setEdge(el, mode) {
  if (mode === 'pre') {
    el.style.opacity = '1';
    el.setAttribute('stroke-width', '2.2');
    el.setAttribute('stroke', '#c97b00');
  } else if (mode === 'dep') {
    el.style.opacity = '1';
    el.setAttribute('stroke-width', '2.2');
    el.setAttribute('stroke', '#1a7a4a');
  } else if (mode === 'dim') {
    el.style.opacity = '0.04';
    el.setAttribute('stroke-width', '1.2');
  } else {
    // normal — restore original color
    const src = el.dataset.src;
    const na = nodeMap[src];
    if (!na) return;
    const cross = na.d !== nodeMap[el.dataset.tgt]?.d;
    el.style.opacity = '0.55';
    el.setAttribute('stroke-width', '1.2');
    el.setAttribute('stroke', cross ? '#9c87e0' : DOMAINS[na.d].c);
  }
}

function clearHighlight() {
  NODES.forEach(n => setNode(n.id, 'normal'));
  document.querySelectorAll('[data-src]').forEach(el => setEdge(el, 'normal'));
}

function applyHighlight(id) {
  const pres = directPre[id];   // direct prereqs of id
  const deps = directDep[id];   // direct dependents of id

  NODES.forEach(n => {
    if (n.id === id)          setNode(n.id, 'self');
    else if (pres.has(n.id))  setNode(n.id, 'pre');
    else if (deps.has(n.id))  setNode(n.id, 'dep');
    else                      setNode(n.id, 'dim');
  });

  document.querySelectorAll('[data-src]').forEach(el => {
    const s = el.dataset.src, t = el.dataset.tgt;
    if (pres.has(s) && t === id)  setEdge(el, 'pre');
    else if (s === id && deps.has(t)) setEdge(el, 'dep');
    else                          setEdge(el, 'dim');
  });
}

// ── panel ─────────────────────────────────────────────────────
const panel = document.getElementById('panel');
const pd = document.getElementById('pd');
const pt = document.getElementById('pt');
const pb = document.getElementById('pb');

document.getElementById('pcl').addEventListener('click', () => {
  panel.classList.remove('open'); clearHighlight(); selectedId = null;
});

function renderPanel(n) {
  const dm = DOMAINS[n.d];
  pd.textContent = dm.name; pd.style.color = dm.c;
  pt.textContent = n.l;    pt.style.color = dm.c;
  pb.innerHTML = n.books.map(b => `
    <div style="border-radius:8px;border:1.5px solid #ddd;padding:11px 13px 10px;background:#fff">
      <div style="font-size:10.5px;font-weight:700;color:${dm.t};margin-bottom:3px;text-transform:uppercase;letter-spacing:.04em">${b.a}</div>
      <div style="font-size:13px;font-weight:600;color:#111;line-height:1.4;margin-bottom:${b.n?'5px':'0'}">${b.t}</div>
      ${b.n ? `<div style="font-size:11.5px;color:#555;line-height:1.55">${b.n}</div>` : ''}
    </div>`).join('');
  panel.classList.add('open');
}

// ── click ─────────────────────────────────────────────────────
let moved = false;
document.getElementById('sw').addEventListener('click', e => {
  if (moved) return;
  const g = e.target.closest('.nd');
  if (!g) { clearHighlight(); selectedId = null; panel.classList.remove('open'); return; }
  const id = g.dataset.id;
  if (id === selectedId) { clearHighlight(); selectedId = null; panel.classList.remove('open'); return; }
  selectedId = id;
  applyHighlight(id);
  renderPanel(nodeMap[id]);
});

// ── pan & zoom ────────────────────────────────────────────────
let scale=0.65, tx=0, ty=0, drag=false, lx=0, ly=0;
const outer = document.getElementById('co');
const wrap  = document.getElementById('sw');
const applyT = () => { wrap.style.transform = `translate(${tx}px,${ty}px) scale(${scale})`; };
applyT();

outer.addEventListener('mousedown', e => { drag=true; lx=e.clientX; ly=e.clientY; moved=false; outer.classList.add('grabbing'); });
window.addEventListener('mousemove', e => {
  if (!drag) return;
  const dx=e.clientX-lx, dy=e.clientY-ly;
  if (Math.abs(dx)+Math.abs(dy)>3) moved=true;
  tx+=dx; ty+=dy; lx=e.clientX; ly=e.clientY; applyT();
});
window.addEventListener('mouseup', () => { drag=false; outer.classList.remove('grabbing'); });
outer.addEventListener('wheel', e => {
  e.preventDefault();
  const rect=outer.getBoundingClientRect();
  const ox=e.clientX-rect.left, oy=e.clientY-rect.top;
  const d=e.deltaY>0?0.88:1.12;
  const ns=Math.max(0.1,Math.min(4,scale*d));
  tx=ox-(ox-tx)*(ns/scale); ty=oy-(oy-ty)*(ns/scale); scale=ns; applyT();
}, {passive:false});
document.getElementById('zin').addEventListener('click',    ()=>{scale=Math.min(4,scale*1.2);applyT();});
document.getElementById('zout').addEventListener('click',   ()=>{scale=Math.max(0.1,scale/1.2);applyT();});
document.getElementById('zreset').addEventListener('click', ()=>{scale=0.65;tx=0;ty=0;applyT();});

// ── domain filter ─────────────────────────────────────────────
let activeDomain = null;
document.querySelectorAll('.df').forEach(btn => {
  btn.addEventListener('click', () => {
    const d = btn.dataset.d;
    if (activeDomain === d) {
      activeDomain = null;
      document.querySelectorAll('.df').forEach(b => b.classList.remove('off'));
      NODES.forEach(n => { document.getElementById('nd_'+n.id).style.opacity = '1'; });
      document.querySelectorAll('[data-src]').forEach(el => setEdge(el, 'normal'));
    } else {
      if (selectedId) { clearHighlight(); selectedId=null; panel.classList.remove('open'); }
      activeDomain = d;
      document.querySelectorAll('.df').forEach(b => b.classList.toggle('off', b.dataset.d!==d));
      NODES.forEach(n => { document.getElementById('nd_'+n.id).style.opacity = n.d===d?'1':'0.1'; });
      document.querySelectorAll('[data-src]').forEach(el => {
        const sd=nodeMap[el.dataset.src]?.d, td=nodeMap[el.dataset.tgt]?.d;
        setEdge(el, (sd===d||td===d)?'normal':'dim');
      });
    }
  });
});
</script>
</body>
</html>
