---
const nodesJson   = "[{\"id\": \"prop\", \"d\": \"math\", \"col\": 3, \"row\": 0, \"l\": \"Propositional logic\", \"books\": [{\"a\": \"Ebbinghaus, Flum & Thomas\", \"t\": \"Mathematical Logic\", \"n\": \"The rigorous German standard. Syntax, semantics, completeness, compactness. Start here.\"}, {\"a\": \"Kleene\", \"t\": \"Introduction to Metamathematics\", \"n\": \"Formal deductive systems, recursive functions, G\\u00f6del. Hard but foundational.\"}]}, {\"id\": \"proof\", \"d\": \"math\", \"col\": 4, \"row\": 0, \"l\": \"Proof methods\", \"books\": [{\"a\": \"Velleman\", \"t\": \"How to Prove It\", \"n\": \"Induction, contradiction, contrapositive. The one permissible 'accessible' book \\u2014 it is genuinely rigorous.\"}, {\"a\": \"P\\u00f3lya\", \"t\": \"Mathematics and Plausible Reasoning (2 vols)\", \"n\": \"Inductive reasoning and heuristics in mathematics. Deeper than 'How to Solve It'.\"}]}, {\"id\": \"sets\", \"d\": \"math\", \"col\": 5, \"row\": 0, \"l\": \"Naive set theory\", \"books\": [{\"a\": \"Halmos\", \"t\": \"Naive Set Theory\", \"n\": \"The classic. Every page is dense and correct. No fluff.\"}]}, {\"id\": \"fol\", \"d\": \"math\", \"col\": 3, \"row\": 1, \"l\": \"First-order logic\", \"books\": [{\"a\": \"Ebbinghaus, Flum & Thomas\", \"t\": \"Mathematical Logic\", \"n\": \"Full FOL: structures, Herbrand, completeness, L\\u00f6wenheim\\u2013Skolem. Mandatory.\"}, {\"a\": \"Kleene\", \"t\": \"Introduction to Metamathematics\", \"n\": \"Formal deductive systems, recursive functions, G\\u00f6del incompleteness.\"}, {\"a\": \"Enderton\", \"t\": \"A Mathematical Introduction to Logic\", \"n\": \"Cleaner modern presentation of the same material.\"}]}, {\"id\": \"zfc\", \"d\": \"math\", \"col\": 5, \"row\": 1, \"l\": \"Axiomatic set theory (ZFC)\", \"books\": [{\"a\": \"Kunen\", \"t\": \"Set Theory: An Introduction to Independence Proofs\", \"n\": \"The graduate standard. ZF axioms, ordinals, cardinals, forcing. No shortcuts.\"}, {\"a\": \"Jech\", \"t\": \"Set Theory (3rd millennium ed.)\", \"n\": \"The encyclopedic reference. Use alongside Kunen for depth.\"}]}, {\"id\": \"linalg\", \"d\": \"math\", \"col\": 6, \"row\": 1, \"l\": \"Linear algebra\", \"books\": [{\"a\": \"Kostrikin & Manin\", \"t\": \"Linear Algebra and Geometry\", \"n\": \"Russian school. Rigorous, geometric intuition built in. Best overall.\"}, {\"a\": \"Halmos\", \"t\": \"Finite-Dimensional Vector Spaces\", \"n\": \"Pure vector space theory. No matrices until forced. Elegant.\"}, {\"a\": \"Gelfand\", \"t\": \"Lectures on Linear Algebra\", \"n\": \"Very short, very deep. Every sentence has content.\"}]}, {\"id\": \"realanl\", \"d\": \"math\", \"col\": 4, \"row\": 2, \"l\": \"Real analysis\", \"books\": [{\"a\": \"Rudin\", \"t\": \"Principles of Mathematical Analysis\", \"n\": \"The mandatory benchmark. Terse, complete, brutal. Every analyst has suffered through this.\"}, {\"a\": \"Zorich\", \"t\": \"Mathematical Analysis I & II\", \"n\": \"Russian alternative. Superior geometric intuition. Use after or alongside Rudin.\"}, {\"a\": \"Kolmogorov & Fomin\", \"t\": \"Introductory Real Analysis\", \"n\": \"Russian. Covers functional analysis too. Dense and structurally deep.\"}]}, {\"id\": \"diffeq\", \"d\": \"math\", \"col\": 6, \"row\": 2, \"l\": \"ODEs & PDEs\", \"books\": [{\"a\": \"Arnold\", \"t\": \"Ordinary Differential Equations\", \"n\": \"The geometric treatment. Phase spaces, flows, stability. Mandatory \\u2014 no other book treats ODEs this deeply.\"}, {\"a\": \"Arnold\", \"t\": \"Mathematical Methods of Classical Mechanics\", \"n\": \"Lagrangian and Hamiltonian mechanics via symplectic geometry.\"}, {\"a\": \"Evans\", \"t\": \"Partial Differential Equations\", \"n\": \"The graduate PDE standard in the US. Sobolev spaces, elliptic theory.\"}]}, {\"id\": \"metric\", \"d\": \"math\", \"col\": 4, \"row\": 3, \"l\": \"Metric & topological spaces\", \"books\": [{\"a\": \"Munkres\", \"t\": \"Topology\", \"n\": \"The standard text. Very clear proofs. Both point-set and algebraic topology.\"}, {\"a\": \"Kelley\", \"t\": \"General Topology\", \"n\": \"More advanced and abstract. Classic reference after Munkres.\"}]}, {\"id\": \"complex\", \"d\": \"math\", \"col\": 3, \"row\": 4, \"l\": \"Complex analysis\", \"books\": [{\"a\": \"Ahlfors\", \"t\": \"Complex Analysis\", \"n\": \"The canonical rigorous text. Mandatory.\"}, {\"a\": \"Markushevich\", \"t\": \"Theory of Functions of a Complex Variable (3 vols)\", \"n\": \"Russian encyclopedic treatment. The deepest reference available.\"}]}, {\"id\": \"measure\", \"d\": \"math\", \"col\": 5, \"row\": 4, \"l\": \"Measure & integration\", \"books\": [{\"a\": \"Halmos\", \"t\": \"Measure Theory\", \"n\": \"Elegant abstract treatment. The standard for pure mathematicians.\"}, {\"a\": \"Kolmogorov & Fomin\", \"t\": \"Elements of the Theory of Functions and Functional Analysis\", \"n\": \"Russian. Measure theory and functional analysis unified. Very deep.\"}, {\"a\": \"Royden & Fitzpatrick\", \"t\": \"Real Analysis\", \"n\": \"Standard US graduate text. More computational complement to Halmos.\"}]}, {\"id\": \"absalg\", \"d\": \"math\", \"col\": 7, \"row\": 2, \"l\": \"Abstract algebra\", \"books\": [{\"a\": \"Lang\", \"t\": \"Algebra\", \"n\": \"The hardest and most complete standard. Every algebraist must work through this. No mercy.\"}, {\"a\": \"Vinberg\", \"t\": \"A Course in Algebra\", \"n\": \"Russian. Rigorous, beautiful, more geometric than Lang.\"}, {\"a\": \"Jacobson\", \"t\": \"Basic Algebra I & II\", \"n\": \"Deep classical reference. More detailed than Lang in places.\"}]}, {\"id\": \"numthy\", \"d\": \"math\", \"col\": 7, \"row\": 3, \"l\": \"Number theory\", \"books\": [{\"a\": \"Hardy & Wright\", \"t\": \"An Introduction to the Theory of Numbers\", \"n\": \"The classic. Elementary methods, deep results. Read every proof.\"}, {\"a\": \"Ireland & Rosen\", \"t\": \"A Classical Introduction to Modern Number Theory\", \"n\": \"Algebraic number theory and L-functions. Rigorous entry.\"}, {\"a\": \"Serre\", \"t\": \"A Course in Arithmetic\", \"n\": \"Quadratic forms, Dirichlet series, modular forms. Short and extraordinarily dense.\"}]}, {\"id\": \"combin\", \"d\": \"math\", \"col\": 6, \"row\": 3, \"l\": \"Combinatorics\", \"books\": [{\"a\": \"Stanley\", \"t\": \"Enumerative Combinatorics I & II\", \"n\": \"The definitive graduate reference. Generating functions, posets, symmetric functions.\"}, {\"a\": \"Alon & Spencer\", \"t\": \"The Probabilistic Method\", \"n\": \"Probabilistic combinatorics. Essential for complexity theory too.\"}]}, {\"id\": \"prob\", \"d\": \"math\", \"col\": 5, \"row\": 5, \"l\": \"Probability theory\", \"books\": [{\"a\": \"Billingsley\", \"t\": \"Probability and Measure\", \"n\": \"Measure-theoretic probability done right. The rigorous standard.\"}, {\"a\": \"Shiryaev\", \"t\": \"Probability (2 vols)\", \"n\": \"Russian. More complete than Billingsley. Very rigorous.\"}, {\"a\": \"Feller\", \"t\": \"An Introduction to Probability Theory and Its Applications I & II\", \"n\": \"Classical. Vol.2 is extraordinarily deep. Not easy.\"}]}, {\"id\": \"catthy\", \"d\": \"math\", \"col\": 6, \"row\": 5, \"l\": \"Category theory\", \"books\": [{\"a\": \"Mac Lane\", \"t\": \"Categories for the Working Mathematician\", \"n\": \"The original. Mandatory. Every page is foundational.\"}, {\"a\": \"Riehl\", \"t\": \"Category Theory in Context\", \"n\": \"More accessible but fully rigorous. Best modern treatment.\"}, {\"a\": \"Jacobs\", \"t\": \"Categorical Logic and Type Theory\", \"n\": \"For the CS/AI bridge. Fibrations, comprehension. Very technical.\"}]}, {\"id\": \"mathlog\", \"d\": \"math\", \"col\": 4, \"row\": 5, \"l\": \"Mathematical logic\", \"books\": [{\"a\": \"Shoenfield\", \"t\": \"Mathematical Logic\", \"n\": \"The hard classic. Completeness, incompleteness, recursion theory unified. Mandatory.\"}, {\"a\": \"Manin\", \"t\": \"A Course in Mathematical Logic for Mathematicians\", \"n\": \"Russian. G\\u00f6del, Tarski, forcing, model theory. Deep and broad.\"}, {\"a\": \"Enderton\", \"t\": \"A Mathematical Introduction to Logic\", \"n\": \"Cleaner modern presentation. Good for the incompleteness theorems specifically.\"}]}, {\"id\": \"modthy\", \"d\": \"math\", \"col\": 3, \"row\": 6, \"l\": \"Model theory\", \"books\": [{\"a\": \"Marker\", \"t\": \"Model Theory: An Introduction\", \"n\": \"The modern graduate standard. Saturated models, types, stability.\"}, {\"a\": \"Chang & Keisler\", \"t\": \"Model Theory\", \"n\": \"The encyclopedic classical reference. More complete than Marker.\"}]}, {\"id\": \"proofth\", \"d\": \"math\", \"col\": 5, \"row\": 6, \"l\": \"Proof theory\", \"books\": [{\"a\": \"Troelstra & Schwichtenberg\", \"t\": \"Basic Proof Theory\", \"n\": \"Sequent calculus, cut elimination, normalization theorems. The standard.\"}, {\"a\": \"Girard\", \"t\": \"Proofs and Types\", \"n\": \"Linear logic, Curry\\u2013Howard isomorphism. Free online. Fundamental.\"}, {\"a\": \"Pohlers\", \"t\": \"Proof Theory: The First Step into Impredicativity\", \"n\": \"Ordinal analysis. The hard frontier of proof theory.\"}]}, {\"id\": \"olymp\", \"d\": \"math\", \"col\": 7, \"row\": 4, \"l\": \"Olympiad mathematics\", \"books\": [{\"a\": \"Engel\", \"t\": \"Problem Solving Strategies\", \"n\": \"The canonical olympiad training book. Combinatorics, geometry, NT, algebra.\"}, {\"a\": \"Prasolov\", \"t\": \"Problems in Plane Geometry\", \"n\": \"Russian. Thousands of problems. Extraordinarily deep.\"}, {\"a\": \"Andreescu & Dospinescu\", \"t\": \"Problems from the Book\", \"n\": \"Hard competition problems with full solutions. Genuine mathematical depth.\"}, {\"a\": \"Prasolov & Tikhomirov\", \"t\": \"Geometry\", \"n\": \"Russian. Full synthetic geometry from fundamentals.\"}]}, {\"id\": \"presoc\", \"d\": \"phil\", \"col\": 0, \"row\": 0, \"l\": \"Pre-Socratics & Plato\", \"books\": [{\"a\": \"Kirk, Raven & Schofield\", \"t\": \"The Presocratic Philosophers\", \"n\": \"Scholarly edition of fragments with Greek text and commentary. The academic standard.\"}, {\"a\": \"Plato\", \"t\": \"Complete Works (Cooper ed., Hackett)\", \"n\": \"All dialogues in one volume. Read Republic, Meno, Phaedo, Theaetetus, Sophist in full.\"}, {\"a\": \"Cornford\", \"t\": \"Plato's Theory of Knowledge\", \"n\": \"Commentary on Theaetetus and Sophist. Rigorous philosophical analysis.\"}]}, {\"id\": \"arist\", \"d\": \"phil\", \"col\": 0, \"row\": 1, \"l\": \"Aristotle\", \"books\": [{\"a\": \"Aristotle\", \"t\": \"Prior Analytics (Smith trans., Oxford)\", \"n\": \"The invention of formal logic. Read with commentary.\"}, {\"a\": \"Aristotle\", \"t\": \"Metaphysics (Ross trans.)\", \"n\": \"The foundational ontology text. Read all 14 books.\"}, {\"a\": \"Aristotle\", \"t\": \"De Anima (Hamlyn trans.)\", \"n\": \"Philosophy of mind from first principles.\"}, {\"a\": \"Lear\", \"t\": \"Aristotle: The Desire to Understand\", \"n\": \"The best unified secondary account of Aristotle's whole system.\"}]}, {\"id\": \"ratio\", \"d\": \"phil\", \"col\": 0, \"row\": 2, \"l\": \"Rationalists & empiricists\", \"books\": [{\"a\": \"Descartes\", \"t\": \"Meditations on First Philosophy (Cottingham trans., Cambridge)\", \"n\": \"With all Objections and Replies. Read the full volume \\u2014 objections are essential.\"}, {\"a\": \"Spinoza\", \"t\": \"Ethics (Curley trans.)\", \"n\": \"Geometric method. Extremely hard. Read with Della Rocca's commentary.\"}, {\"a\": \"Hume\", \"t\": \"A Treatise of Human Nature\", \"n\": \"Books I and II. The empiricist masterwork. Read every footnote.\"}, {\"a\": \"Leibniz\", \"t\": \"Philosophical Essays (Ariew & Garber, Hackett)\", \"n\": \"Monadology, Discourse, New System. The definitive English anthology.\"}]}, {\"id\": \"kant\", \"d\": \"phil\", \"col\": 0, \"row\": 3, \"l\": \"Kant & German idealism\", \"books\": [{\"a\": \"Kant\", \"t\": \"Critique of Pure Reason (Guyer & Wood trans., Cambridge)\", \"n\": \"The Cambridge edition. Read A and B editions. Takes months.\"}, {\"a\": \"Allison\", \"t\": \"Kant's Transcendental Idealism (revised ed.)\", \"n\": \"The best analytic commentary on the first Critique.\"}, {\"a\": \"Hegel\", \"t\": \"Science of Logic (di Giovanni trans., Cambridge)\", \"n\": \"More fundamental than Phenomenology for Hegel's actual logic.\"}, {\"a\": \"Longuenesse\", \"t\": \"Kant and the Capacity to Judge\", \"n\": \"Best account of the Transcendental Analytic.\"}]}, {\"id\": \"philsci\", \"d\": \"phil\", \"col\": 1, \"row\": 3, \"l\": \"Philosophy of science\", \"books\": [{\"a\": \"Popper\", \"t\": \"The Logic of Scientific Discovery\", \"n\": \"Falsificationism stated with full rigor. Read the original, not summaries.\"}, {\"a\": \"Kuhn\", \"t\": \"The Structure of Scientific Revolutions\", \"n\": \"Paradigms and incommensurability. Essential.\"}, {\"a\": \"Lakatos\", \"t\": \"Proofs and Refutations\", \"n\": \"Mathematical knowledge growth as dialectic. Brilliant and rigorous.\"}, {\"a\": \"Suppes\", \"t\": \"Introduction to Logic\", \"n\": \"Logical foundations of scientific theories. More technical than Popper.\"}]}, {\"id\": \"philang\", \"d\": \"phil\", \"col\": 1, \"row\": 4, \"l\": \"Philosophy of language\", \"books\": [{\"a\": \"Frege\", \"t\": \"Collected Papers on Mathematics, Logic, and Philosophy (McGuinness ed.)\", \"n\": \"Sense/reference, concept/object, definition of number. Primary sources only.\"}, {\"a\": \"Kripke\", \"t\": \"Naming and Necessity\", \"n\": \"Rigid designators, a posteriori necessity, the essentialist revival.\"}, {\"a\": \"Davidson\", \"t\": \"Inquiries into Truth and Interpretation\", \"n\": \"Truth-conditional semantics, radical interpretation. Mandatory.\"}, {\"a\": \"Tarski\", \"t\": \"Logic, Semantics, Metamathematics\", \"n\": \"The formal definition of truth. Primary source.\"}]}, {\"id\": \"latewit\", \"d\": \"phil\", \"col\": 0, \"row\": 5, \"l\": \"Late Wittgenstein & Oxford\", \"books\": [{\"a\": \"Wittgenstein\", \"t\": \"Philosophical Investigations (Anscombe trans.)\", \"n\": \"The central text. Read slowly. Every remark matters.\"}, {\"a\": \"Wittgenstein\", \"t\": \"On Certainty\", \"n\": \"Epistemology from the inside. Completes the Investigations.\"}, {\"a\": \"Austin\", \"t\": \"How to Do Things with Words\", \"n\": \"Speech act theory from first principles.\"}, {\"a\": \"Grice\", \"t\": \"Studies in the Way of Words\", \"n\": \"Implicature and the cooperative principle. Read the original papers.\"}]}, {\"id\": \"philmnd\", \"d\": \"phil\", \"col\": 1, \"row\": 5, \"l\": \"Philosophy of mind\", \"books\": [{\"a\": \"Chalmers\", \"t\": \"The Conscious Mind\", \"n\": \"The hard problem stated with full philosophical rigor.\"}, {\"a\": \"Nagel\", \"t\": \"Mortal Questions\", \"n\": \"What is it like to be a bat. The phenomenal consciousness argument.\"}, {\"a\": \"Searle\", \"t\": \"Intentionality\", \"n\": \"Chinese Room, biological naturalism, intentional states.\"}, {\"a\": \"Fodor\", \"t\": \"The Language of Thought\", \"n\": \"Mentalese and computational theory of mind. Foundational for cognitive science.\"}]}, {\"id\": \"phenom\", \"d\": \"phil\", \"col\": 0, \"row\": 6, \"l\": \"Phenomenology\", \"books\": [{\"a\": \"Husserl\", \"t\": \"Logical Investigations (Findlay trans., 2 vols)\", \"n\": \"The founding text of phenomenology. Very hard. Read all six investigations.\"}, {\"a\": \"Husserl\", \"t\": \"Ideas I (Kersten trans.)\", \"n\": \"Phenomenological reduction and pure consciousness.\"}, {\"a\": \"Heidegger\", \"t\": \"Being and Time (Stambaugh trans., SUNY)\", \"n\": \"Best translation. Read with Blattner's guide.\"}]}, {\"id\": \"philmat\", \"d\": \"phil\", \"col\": 1, \"row\": 6, \"l\": \"Philosophy of mathematics\", \"books\": [{\"a\": \"Frege\", \"t\": \"The Foundations of Arithmetic (Austin trans.)\", \"n\": \"Logicism stated. The most important short book in philosophy of mathematics.\"}, {\"a\": \"Benacerraf & Putnam\", \"t\": \"Philosophy of Mathematics: Selected Readings\", \"n\": \"Logicism, formalism, intuitionism \\u2014 primary sources. The essential anthology.\"}, {\"a\": \"Dummett\", \"t\": \"Frege: Philosophy of Mathematics\", \"n\": \"Deep analytic commentary. Connects Frege to contemporary philosophy.\"}]}, {\"id\": \"philai\", \"d\": \"phil\", \"col\": 1, \"row\": 7, \"l\": \"Philosophy of AI\", \"books\": [{\"a\": \"Turing\", \"t\": \"Computing Machinery and Intelligence (1950, Mind journal)\", \"n\": \"The original Turing test paper. Free. Read before anything else.\"}, {\"a\": \"Dreyfus\", \"t\": \"What Computers Can't Do\", \"n\": \"Phenomenological critique of classical AI. Still the strongest objection.\"}, {\"a\": \"Penrose\", \"t\": \"The Emperor's New Mind\", \"n\": \"G\\u00f6del-based argument against computationalism. Read both for and against.\"}, {\"a\": \"Hofstadter\", \"t\": \"G\\u00f6del, Escher, Bach\", \"n\": \"Self-reference and strange loops. Not light \\u2014 requires sustained effort.\"}]}, {\"id\": \"classmech\", \"d\": \"phys\", \"col\": 9, \"row\": 1, \"l\": \"Classical mechanics\", \"books\": [{\"a\": \"Landau & Lifshitz\", \"t\": \"Mechanics (Course of Theoretical Physics vol.1)\", \"n\": \"The hardest and best. Every sentence is content. 170 pages that take months.\"}, {\"a\": \"Arnold\", \"t\": \"Mathematical Methods of Classical Mechanics\", \"n\": \"Symplectic geometry, variational principles. For mathematicians. Mandatory alongside Landau.\"}, {\"a\": \"Goldstein, Poole & Safko\", \"t\": \"Classical Mechanics\", \"n\": \"Standard graduate text. Use for problems and detail Landau omits.\"}]}, {\"id\": \"thermo\", \"d\": \"phys\", \"col\": 10, \"row\": 1, \"l\": \"Thermodynamics\", \"books\": [{\"a\": \"Fermi\", \"t\": \"Thermodynamics\", \"n\": \"Short, rigorous, masterful. The best first text. Every derivation is clean.\"}, {\"a\": \"Callen\", \"t\": \"Thermodynamics and an Introduction to Thermostatistics\", \"n\": \"Axiomatic postulational approach. Graduate standard.\"}, {\"a\": \"Landau & Lifshitz\", \"t\": \"Statistical Physics pt.1 (vol.5)\", \"n\": \"Thermodynamics derived from statistical mechanics. The deep foundation.\"}]}, {\"id\": \"emag\", \"d\": \"phys\", \"col\": 9, \"row\": 2, \"l\": \"Electromagnetism\", \"books\": [{\"a\": \"Griffiths\", \"t\": \"Introduction to Electrodynamics\", \"n\": \"Best undergraduate text. Clear, complete, every problem instructive.\"}, {\"a\": \"Jackson\", \"t\": \"Classical Electrodynamics\", \"n\": \"The hard graduate standard. Encyclopedic. Solve the problems.\"}, {\"a\": \"Landau & Lifshitz\", \"t\": \"Classical Theory of Fields (vol.2)\", \"n\": \"Relativistic EM and gravity in 400 pages. Extraordinarily dense.\"}]}, {\"id\": \"statmech\", \"d\": \"phys\", \"col\": 10, \"row\": 2, \"l\": \"Statistical mechanics\", \"books\": [{\"a\": \"Landau & Lifshitz\", \"t\": \"Statistical Physics (vol.5)\", \"n\": \"The compact, deep standard. Derive everything from the partition function.\"}, {\"a\": \"Huang\", \"t\": \"Statistical Mechanics\", \"n\": \"More pedagogical. Good for quantum statistical mechanics.\"}, {\"a\": \"Ruelle\", \"t\": \"Statistical Mechanics: Rigorous Results\", \"n\": \"Mathematical physics treatment. For those who want full rigor.\"}]}, {\"id\": \"waves\", \"d\": \"phys\", \"col\": 9, \"row\": 3, \"l\": \"Waves & optics\", \"books\": [{\"a\": \"Born & Wolf\", \"t\": \"Principles of Optics\", \"n\": \"The encyclopedic standard. Mathematical optics at graduate level.\"}, {\"a\": \"Elmore & Heald\", \"t\": \"Physics of Waves\", \"n\": \"Classical wave theory from first principles. Very thorough.\"}]}, {\"id\": \"qm\", \"d\": \"phys\", \"col\": 10, \"row\": 3, \"l\": \"Quantum mechanics\", \"books\": [{\"a\": \"Landau & Lifshitz\", \"t\": \"Quantum Mechanics: Non-Relativistic Theory (vol.3)\", \"n\": \"The hardest and most complete. Mandatory. Every problem is non-trivial.\"}, {\"a\": \"Dirac\", \"t\": \"The Principles of Quantum Mechanics\", \"n\": \"The original formulation. Still the most conceptually deep.\"}, {\"a\": \"Galindo & Pascual\", \"t\": \"Quantum Mechanics I & II\", \"n\": \"Rigorous Hilbert space treatment. More mathematically careful than Landau.\"}]}, {\"id\": \"solidst\", \"d\": \"phys\", \"col\": 9, \"row\": 4, \"l\": \"Solid-state physics\", \"books\": [{\"a\": \"Ashcroft & Mermin\", \"t\": \"Solid State Physics\", \"n\": \"The graduate standard. More complete and rigorous than Kittel.\"}, {\"a\": \"Ziman\", \"t\": \"Principles of the Theory of Solids\", \"n\": \"Deep theoretical treatment. More fundamental than Ashcroft.\"}]}, {\"id\": \"optics_lab\", \"d\": \"phys\", \"col\": 10, \"row\": 4, \"l\": \"Optics (homelab)\", \"books\": [{\"a\": \"Born & Wolf\", \"t\": \"Principles of Optics\", \"n\": \"Theory foundation \\u2014 know this before touching equipment.\"}, {\"a\": \"Hecht\", \"t\": \"Optics\", \"n\": \"More lab-oriented. Use for experimental intuition.\"}, {\"a\": \"Smith\", \"t\": \"Modern Optical Engineering\", \"n\": \"Engineering optics \\u2014 lens design, aberrations, systems. Practical.\"}]}, {\"id\": \"phono\", \"d\": \"ling\", \"col\": 12, \"row\": 1, \"l\": \"Phonology\", \"books\": [{\"a\": \"Kenstowicz\", \"t\": \"Phonology in Generative Grammar\", \"n\": \"The standard rigorous phonology text. Rule-based and constraint-based.\"}, {\"a\": \"Halle & Clements\", \"t\": \"Problem Book in Phonology\", \"n\": \"Work through every problem. Essential for truly understanding phonological rules.\"}, {\"a\": \"Prince & Smolensky\", \"t\": \"Optimality Theory: Constraint Interaction in Generative Grammar (ROA manuscript)\", \"n\": \"The foundational OT paper. Free. Mandatory.\"}]}, {\"id\": \"morph\", \"d\": \"ling\", \"col\": 12, \"row\": 2, \"l\": \"Morphology\", \"books\": [{\"a\": \"Spencer\", \"t\": \"Morphological Theory\", \"n\": \"Comprehensive and rigorous treatment of word structure.\"}, {\"a\": \"Anderson\", \"t\": \"A-Morphous Morphology\", \"n\": \"The most theoretically rigorous morphology text. Challenges naive morpheme assumptions.\"}]}, {\"id\": \"syntax\", \"d\": \"ling\", \"col\": 13, \"row\": 3, \"l\": \"Syntax (minimalism)\", \"books\": [{\"a\": \"Chomsky\", \"t\": \"Aspects of the Theory of Syntax\", \"n\": \"Standard theory. The historical foundation. Read before Minimalist Program.\"}, {\"a\": \"Chomsky\", \"t\": \"The Minimalist Program\", \"n\": \"Current framework. Very hard. Requires Aspects and GB theory first.\"}, {\"a\": \"Chomsky\", \"t\": \"Lectures on Government and Binding\", \"n\": \"The intermediate framework between Aspects and Minimalism. Cannot be skipped.\"}]}, {\"id\": \"formsem\", \"d\": \"ling\", \"col\": 13, \"row\": 4, \"l\": \"Formal semantics\", \"books\": [{\"a\": \"Heim & Kratzer\", \"t\": \"Semantics in Generative Grammar\", \"n\": \"The standard rigorous formal semantics text. Lambda calculus applied to natural language.\"}, {\"a\": \"Montague\", \"t\": \"Formal Philosophy (Thomason ed., Yale UP)\", \"n\": \"Original Montague grammar papers. Primary source.\"}, {\"a\": \"von Fintel & Heim\", \"t\": \"Intensional Semantics (MIT lecture notes)\", \"n\": \"Free online. Rigorous extension into modality and tense.\"}]}, {\"id\": \"pragma\", \"d\": \"ling\", \"col\": 12, \"row\": 5, \"l\": \"Pragmatics\", \"books\": [{\"a\": \"Levinson\", \"t\": \"Pragmatics\", \"n\": \"The standard comprehensive text. Every chapter is a genuine research contribution.\"}, {\"a\": \"Grice\", \"t\": \"Studies in the Way of Words\", \"n\": \"The original papers on implicature and conversational maxims. Primary source.\"}, {\"a\": \"Sperber & Wilson\", \"t\": \"Relevance: Communication and Cognition\", \"n\": \"The alternative framework to Grice. Technically demanding.\"}]}, {\"id\": \"histling\", \"d\": \"ling\", \"col\": 12, \"row\": 3, \"l\": \"Historical linguistics\", \"books\": [{\"a\": \"Campbell\", \"t\": \"Historical Linguistics: An Introduction\", \"n\": \"The rigorous standard. Comparative method, sound change, reconstruction.\"}, {\"a\": \"Fortson\", \"t\": \"Indo-European Language and Culture\", \"n\": \"IE reconstruction with full philological apparatus.\"}, {\"a\": \"Meier-Br\\u00fcgger\", \"t\": \"Indo-European Linguistics\", \"n\": \"The scholarly reference on PIE. Highly technical.\"}]}, {\"id\": \"typol\", \"d\": \"ling\", \"col\": 13, \"row\": 2, \"l\": \"Typological linguistics\", \"books\": [{\"a\": \"Croft\", \"t\": \"Typology and Universals\", \"n\": \"The standard typology text. Functional and formal approaches unified.\"}, {\"a\": \"Greenberg\", \"t\": \"Universals of Language (ed.)\", \"n\": \"Original universals papers. Primary sources.\"}]}, {\"id\": \"compling\", \"d\": \"ling\", \"col\": 13, \"row\": 5, \"l\": \"Computational linguistics\", \"books\": [{\"a\": \"Manning & Sch\\u00fctze\", \"t\": \"Foundations of Statistical Natural Language Processing\", \"n\": \"The rigorous statistical NLP standard. Every chapter requires mathematical effort.\"}, {\"a\": \"Jurafsky & Martin\", \"t\": \"Speech and Language Processing (3rd ed., free draft)\", \"n\": \"Comprehensive modern treatment. More up to date than Manning & Sch\\u00fctze.\"}]}, {\"id\": \"sicp\", \"d\": \"cs\", \"col\": 7, \"row\": 1, \"l\": \"CS foundations (SICP)\", \"books\": [{\"a\": \"Abelson & Sussman\", \"t\": \"Structure and Interpretation of Computer Programs (free online)\", \"n\": \"The foundational CS text. Abstraction, recursion, interpreters, compilers. Every exercise mandatory.\"}, {\"a\": \"Dijkstra\", \"t\": \"A Discipline of Programming\", \"n\": \"Formal derivation of programs from specifications. Predicate transformer semantics.\"}]}, {\"id\": \"lambda\", \"d\": \"cs\", \"col\": 8, \"row\": 1, \"l\": \"\\u03bb-calculus\", \"books\": [{\"a\": \"Barendregt\", \"t\": \"The Lambda Calculus: Its Syntax and Semantics (revised ed.)\", \"n\": \"The definitive reference. Church\\u2013Rosser, combinatory logic, models. Very complete.\"}, {\"a\": \"Hindley & Seldin\", \"t\": \"Lambda-Calculus and Combinators: An Introduction\", \"n\": \"More readable than Barendregt. Good for the Curry\\u2013Howard connection.\"}, {\"a\": \"Girard, Lafont & Taylor\", \"t\": \"Proofs and Types\", \"n\": \"Curry\\u2013Howard isomorphism. Free online. Mandatory for type theory.\"}]}, {\"id\": \"computable\", \"d\": \"cs\", \"col\": 7, \"row\": 2, \"l\": \"Computability theory\", \"books\": [{\"a\": \"Rogers\", \"t\": \"Theory of Recursive Functions and Effective Computability\", \"n\": \"The deep classical reference. Degree theory, creative sets, complete problems.\"}, {\"a\": \"Soare\", \"t\": \"Recursively Enumerable Sets and Degrees\", \"n\": \"The advanced treatment of the r.e. degrees. Graduate standard.\"}, {\"a\": \"Sipser\", \"t\": \"Introduction to the Theory of Computation\", \"n\": \"Best pedagogical entry. Use to build intuition before Rogers.\"}]}, {\"id\": \"complex2\", \"d\": \"cs\", \"col\": 7, \"row\": 3, \"l\": \"Complexity theory\", \"books\": [{\"a\": \"Arora & Barak\", \"t\": \"Computational Complexity: A Modern Approach (free online)\", \"n\": \"The graduate standard. Every major complexity class, circuit lower bounds, pseudorandomness.\"}, {\"a\": \"Papadimitriou\", \"t\": \"Computational Complexity\", \"n\": \"Classical treatment. More formal in places than Arora\\u2013Barak.\"}]}, {\"id\": \"algods\", \"d\": \"cs\", \"col\": 8, \"row\": 3, \"l\": \"Algorithms & data structures\", \"books\": [{\"a\": \"Knuth\", \"t\": \"The Art of Computer Programming vol.1\\u20134A\", \"n\": \"The ultimate reference. Mathematical analysis of algorithms. Read in parallel with everything else.\"}, {\"a\": \"Cormen, Leiserson, Rivest & Stein\", \"t\": \"Introduction to Algorithms (CLRS)\", \"n\": \"The standard text. Rigorous pseudocode and proofs. Solve every problem.\"}]}, {\"id\": \"typethy\", \"d\": \"cs\", \"col\": 8, \"row\": 4, \"l\": \"Type theory\", \"books\": [{\"a\": \"Pierce\", \"t\": \"Types and Programming Languages (TAPL)\", \"n\": \"The definitive text. Every PL researcher must know this book completely.\"}, {\"a\": \"Pierce\", \"t\": \"Advanced Topics in Types and Programming Languages (ATTAPL)\", \"n\": \"Substructural types, dependent types, type inference. Continuation of TAPL.\"}, {\"a\": \"The HoTT Book\", \"t\": \"Homotopy Type Theory (free online)\", \"n\": \"Univalence axiom, higher inductive types. The frontier of foundations.\"}]}, {\"id\": \"plt\", \"d\": \"cs\", \"col\": 8, \"row\": 5, \"l\": \"PL theory\", \"books\": [{\"a\": \"Winskel\", \"t\": \"The Formal Semantics of Programming Languages\", \"n\": \"Operational and denotational semantics. The standard entry-level rigorous text.\"}, {\"a\": \"Gunter\", \"t\": \"Semantics of Programming Languages: Structures and Techniques\", \"n\": \"Domain theory and full denotational semantics.\"}, {\"a\": \"Abramsky & Jung\", \"t\": \"Domain Theory (Handbook of Logic in CS vol.3)\", \"n\": \"The definitive technical treatment of domain theory.\"}]}, {\"id\": \"compiler\", \"d\": \"cs\", \"col\": 8, \"row\": 6, \"l\": \"Compilers\", \"books\": [{\"a\": \"Appel\", \"t\": \"Modern Compiler Implementation in ML\", \"n\": \"The ML edition is the cleanest. Covers SSA, register allocation, GC.\"}, {\"a\": \"Aho, Lam, Sethi & Ullman\", \"t\": \"Compilers: Principles, Techniques, and Tools (Dragon Book)\", \"n\": \"The classic encyclopedic reference. Parsing theory is unmatched.\"}, {\"a\": \"Appel\", \"t\": \"Compiling with Continuations\", \"n\": \"CPS transformation and functional language compilation. Foundational.\"}]}, {\"id\": \"os\", \"d\": \"cs\", \"col\": 9, \"row\": 6, \"l\": \"Operating systems\", \"books\": [{\"a\": \"Bach\", \"t\": \"The Design of the UNIX Operating System\", \"n\": \"Deep internals: inodes, process scheduling, IPC. Read source alongside.\"}, {\"a\": \"Tanenbaum\", \"t\": \"Modern Operating Systems\", \"n\": \"Broad and rigorous. The standard graduate text.\"}, {\"a\": \"MIT xv6\", \"t\": \"xv6 OS source + commentary (free, MIT)\", \"n\": \"Implement it. The only way to truly understand OS internals.\"}]}, {\"id\": \"nets\", \"d\": \"cs\", \"col\": 10, \"row\": 6, \"l\": \"Computer networks\", \"books\": [{\"a\": \"Tanenbaum & Wetherall\", \"t\": \"Computer Networks\", \"n\": \"The standard text. Protocol layers, TCP/IP, routing algorithms.\"}, {\"a\": \"Stevens\", \"t\": \"TCP/IP Illustrated vol.1\", \"n\": \"Every packet traced. The definitive protocol-level reference.\"}]}, {\"id\": \"distsys\", \"d\": \"cs\", \"col\": 9, \"row\": 7, \"l\": \"Distributed systems\", \"books\": [{\"a\": \"Lynch\", \"t\": \"Distributed Algorithms\", \"n\": \"The formal rigorous treatment. Impossibility results, asynchrony, fault tolerance.\"}, {\"a\": \"Lamport\", \"t\": \"Time, Clocks, and the Ordering of Events in a Distributed System (1978 paper)\", \"n\": \"The foundational paper. Free. Read before anything else.\"}, {\"a\": \"Attiya & Welch\", \"t\": \"Distributed Computing: Fundamentals, Simulations, and Advanced Topics\", \"n\": \"Formal models, lower bounds, shared memory. Graduate standard.\"}]}, {\"id\": \"security\", \"d\": \"cs\", \"col\": 10, \"row\": 7, \"l\": \"Security & cryptography\", \"books\": [{\"a\": \"Boneh & Shoup\", \"t\": \"A Graduate Course in Applied Cryptography (free online)\", \"n\": \"The rigorous modern standard. Provable security, reductions, all major primitives.\"}, {\"a\": \"Goldreich\", \"t\": \"Foundations of Cryptography I & II\", \"n\": \"The deepest foundational treatment. Computational complexity meets cryptography.\"}, {\"a\": \"Anderson\", \"t\": \"Security Engineering (free online)\", \"n\": \"The comprehensive systems security reference. Every threat model and countermeasure.\"}]}, {\"id\": \"devops\", \"d\": \"cs\", \"col\": 11, \"row\": 7, \"l\": \"DevOps & SRE\", \"books\": [{\"a\": \"Beyer et al.\", \"t\": \"Site Reliability Engineering (free online, Google)\", \"n\": \"The only rigorous SRE text. Error budgets, SLOs, toil. Written by practitioners.\"}, {\"a\": \"Limoncelli, Hogan & Chalup\", \"t\": \"The Practice of System and Network Administration\", \"n\": \"Comprehensive sysadmin principles. More rigorous than most SRE books.\"}]}, {\"id\": \"compprog\", \"d\": \"cs\", \"col\": 9, \"row\": 5, \"l\": \"Competitive programming\", \"books\": [{\"a\": \"Knuth\", \"t\": \"The Art of Computer Programming vol.1\\u20134A\", \"n\": \"The mathematical foundation. No contest programmer can ignore this.\"}, {\"a\": \"Halim\", \"t\": \"Competitive Programming 3\", \"n\": \"The standard contest preparation book. Every technique with problems.\"}, {\"a\": \"de Bruijn / various\", \"t\": \"USACO, Codeforces, AtCoder editorial archives\", \"n\": \"Read every editorial for problems you cannot solve. More valuable than any book.\"}]}, {\"id\": \"elec_fund\", \"d\": \"hw\", \"col\": 11, \"row\": 1, \"l\": \"Electronics fundamentals\", \"books\": [{\"a\": \"Horowitz & Hill\", \"t\": \"The Art of Electronics (3rd ed.)\", \"n\": \"The bible. Every circuit, every technique, every subtlety. Mandatory.\"}, {\"a\": \"Hayt & Kemmerly\", \"t\": \"Engineering Circuit Analysis\", \"n\": \"Rigorous KVL/KCL, Laplace methods, network theorems. The theoretical foundation.\"}]}, {\"id\": \"analog\", \"d\": \"hw\", \"col\": 11, \"row\": 2, \"l\": \"Analog circuits\", \"books\": [{\"a\": \"Horowitz & Hill\", \"t\": \"The Art of Electronics \\u2014 analog chapters\", \"n\": \"Op-amps, BJTs, FETs, feedback. No other book matches the depth-to-clarity ratio.\"}, {\"a\": \"Razavi\", \"t\": \"Design of Analog CMOS Integrated Circuits\", \"n\": \"Graduate-level analog IC design. Very rigorous transistor-level analysis.\"}, {\"a\": \"Gray, Hurst, Lewis & Meyer\", \"t\": \"Analysis and Design of Analog Integrated Circuits\", \"n\": \"The other graduate-level standard. More systematic than Razavi.\"}]}, {\"id\": \"digital\", \"d\": \"hw\", \"col\": 11, \"row\": 3, \"l\": \"Digital logic\", \"books\": [{\"a\": \"Wakerly\", \"t\": \"Digital Design: Principles and Practices\", \"n\": \"The rigorous digital design standard. Timing, hazards, state machines.\"}, {\"a\": \"Harris & Harris\", \"t\": \"Digital Design and Computer Architecture (RISC-V ed.)\", \"n\": \"Best modern combined digital logic and architecture text.\"}]}, {\"id\": \"microarch\", \"d\": \"hw\", \"col\": 11, \"row\": 4, \"l\": \"Computer architecture\", \"books\": [{\"a\": \"Hennessy & Patterson\", \"t\": \"Computer Architecture: A Quantitative Approach\", \"n\": \"The definitive graduate reference. ILP, memory hierarchy, multiprocessors. Read every appendix.\"}, {\"a\": \"Patterson & Hennessy\", \"t\": \"Computer Organization and Design (RISC-V ed.)\", \"n\": \"Use as foundation before the Quantitative Approach.\"}]}, {\"id\": \"embedded\", \"d\": \"hw\", \"col\": 11, \"row\": 5, \"l\": \"Embedded systems\", \"books\": [{\"a\": \"White\", \"t\": \"Making Embedded Systems\", \"n\": \"Best modern practical embedded systems book. Registers, interrupts, RTOS from scratch.\"}, {\"a\": \"Barr & Massa\", \"t\": \"Programming Embedded Systems\", \"n\": \"Bare-metal C, bootloaders, memory maps. Very rigorous for a practical book.\"}, {\"a\": \"Labrosse\", \"t\": \"MicroC/OS-II: The Real-Time Kernel\", \"n\": \"RTOS design and implementation in full. Source code included.\"}]}, {\"id\": \"fpga\", \"d\": \"hw\", \"col\": 12, \"row\": 4, \"l\": \"FPGAs & HDL\", \"books\": [{\"a\": \"Chu\", \"t\": \"FPGA Prototyping by Verilog Examples\", \"n\": \"Best practical Verilog text. Every circuit synthesized and tested.\"}, {\"a\": \"Ashenden\", \"t\": \"The Designer's Guide to VHDL\", \"n\": \"The definitive rigorous VHDL reference.\"}, {\"a\": \"Weste & Harris\", \"t\": \"CMOS VLSI Design\", \"n\": \"From HDL to silicon. The full digital design stack.\"}]}, {\"id\": \"pcb\", \"d\": \"hw\", \"col\": 12, \"row\": 5, \"l\": \"PCB design\", \"books\": [{\"a\": \"Ott\", \"t\": \"Electromagnetic Compatibility Engineering\", \"n\": \"EMC, signal integrity, ground planes, crosstalk. Mandatory for real PCBs.\"}, {\"a\": \"Johnson & Graham\", \"t\": \"High-Speed Signal Propagation\", \"n\": \"Transmission lines, termination, SI at high speed. Very rigorous.\"}, {\"a\": \"Montrose\", \"t\": \"Printed Circuit Board Design Techniques for EMC Compliance\", \"n\": \"Practical EMC rules derived from first principles.\"}]}, {\"id\": \"rf\", \"d\": \"hw\", \"col\": 12, \"row\": 6, \"l\": \"RF & SDR\", \"books\": [{\"a\": \"Pozar\", \"t\": \"Microwave Engineering\", \"n\": \"Rigorous microwave circuit theory. S-parameters, transmission lines, amplifiers.\"}, {\"a\": \"Balanis\", \"t\": \"Antenna Theory: Analysis and Design\", \"n\": \"The antenna theory standard. Maxwell's equations to array design.\"}, {\"a\": \"ARRL\", \"t\": \"The ARRL Handbook for Radio Communications\", \"n\": \"The practical RF reference. Every circuit, every band, every mode.\"}]}, {\"id\": \"sysadmin\", \"d\": \"hw\", \"col\": 11, \"row\": 6, \"l\": \"Linux & homelab\", \"books\": [{\"a\": \"Kerrisk\", \"t\": \"The Linux Programming Interface\", \"n\": \"The definitive Linux systems programming reference. 1500 pages of pure substance.\"}, {\"a\": \"Limoncelli, Hogan & Chalup\", \"t\": \"The Practice of System and Network Administration\", \"n\": \"Comprehensive sysadmin principles and practices.\"}, {\"a\": \"Stevens & Rago\", \"t\": \"Advanced Programming in the UNIX Environment\", \"n\": \"UNIX system calls at the lowest level. The technical standard.\"}]}, {\"id\": \"testmeas\", \"d\": \"hw\", \"col\": 12, \"row\": 3, \"l\": \"Test & measurement\", \"books\": [{\"a\": \"Horowitz & Hill\", \"t\": \"The Art of Electronics \\u2014 measurement chapters\", \"n\": \"Oscilloscope technique, noise, grounding, probing. No separate book needed.\"}, {\"a\": \"Williams\", \"t\": \"The Circuit Designer's Companion\", \"n\": \"Practical analog debugging. Noise, instability, layout issues solved.\"}, {\"a\": \"Tektronix\", \"t\": \"XYZs of Oscilloscopes (free PDF)\", \"n\": \"Instrument fundamentals from the manufacturer. Free and accurate.\"}]}, {\"id\": \"search\", \"d\": \"ai\", \"col\": 14, \"row\": 3, \"l\": \"Search & heuristics\", \"books\": [{\"a\": \"Nilsson\", \"t\": \"Principles of Artificial Intelligence\", \"n\": \"The rigorous classical treatment. A*, AO*, game trees with full proofs.\"}, {\"a\": \"Pearl\", \"t\": \"Heuristics: Intelligent Search Strategies for Computer Problem Solving\", \"n\": \"The definitive theoretical treatment of A* admissibility and optimality.\"}, {\"a\": \"Nau, Kumar & Kanal\", \"t\": \"Search in Artificial Intelligence\", \"n\": \"Formal survey of search algorithms. More complete than AIMA on this topic.\"}]}, {\"id\": \"csp\", \"d\": \"ai\", \"col\": 14, \"row\": 4, \"l\": \"Constraint satisfaction\", \"books\": [{\"a\": \"Rossi, van Beek & Walsh\", \"t\": \"Handbook of Constraint Programming (Elsevier)\", \"n\": \"The comprehensive reference. Every CSP technique, with proofs.\"}, {\"a\": \"Dechter\", \"t\": \"Constraint Processing\", \"n\": \"Full formal treatment: arc consistency, backtracking, tree decompositions.\"}]}, {\"id\": \"kr\", \"d\": \"ai\", \"col\": 14, \"row\": 5, \"l\": \"Knowledge representation\", \"books\": [{\"a\": \"Brachman & Levesque\", \"t\": \"Knowledge Representation and Reasoning\", \"n\": \"The standard KR text. Description logics, defaults, belief revision.\"}, {\"a\": \"Sowa\", \"t\": \"Knowledge Representation: Logical, Philosophical, and Computational Foundations\", \"n\": \"Broadest treatment. Conceptual graphs, ontologies, formal logic.\"}, {\"a\": \"Baader et al.\", \"t\": \"The Description Logic Handbook\", \"n\": \"The definitive DL reference. ALC, SHIQ, OWL foundations.\"}]}, {\"id\": \"logprog\", \"d\": \"ai\", \"col\": 14, \"row\": 6, \"l\": \"Logic programming\", \"books\": [{\"a\": \"Lloyd\", \"t\": \"Foundations of Logic Programming\", \"n\": \"The formal rigorous treatment. Fixpoint semantics, SLD resolution, completeness.\"}, {\"a\": \"Apt\", \"t\": \"From Logic Programming to Prolog\", \"n\": \"Full formal semantics of Prolog. More rigorous than Sterling & Shapiro.\"}, {\"a\": \"Doets\", \"t\": \"From Logic to Logic Programming\", \"n\": \"Logical foundations and provably correct programs.\"}]}, {\"id\": \"autoreas\", \"d\": \"ai\", \"col\": 15, \"row\": 5, \"l\": \"Automated reasoning\", \"books\": [{\"a\": \"Harrison\", \"t\": \"Handbook of Practical Logic and Automated Reasoning\", \"n\": \"The modern comprehensive reference. SAT, SMT, HOL, all with implementations.\"}, {\"a\": \"Fitting\", \"t\": \"First-Order Logic and Automated Theorem Proving\", \"n\": \"Tableau methods, resolution, completeness proofs. Rigorous.\"}, {\"a\": \"Bachmair & Ganzinger\", \"t\": \"Resolution Theorem Proving (Handbook of Automated Reasoning vol.1)\", \"n\": \"The definitive treatment of resolution. Primary reference.\"}]}, {\"id\": \"planning\", \"d\": \"ai\", \"col\": 15, \"row\": 6, \"l\": \"AI planning\", \"books\": [{\"a\": \"Ghallab, Nau & Traverso\", \"t\": \"Automated Planning: Theory and Practice\", \"n\": \"The standard text. STRIPS, PDDL, HTN, partial-order, temporal planning.\"}, {\"a\": \"Ghallab, Nau & Traverso\", \"t\": \"Automated Planning and Acting\", \"n\": \"Sequel. Online planning, acting under uncertainty, hierarchical methods.\"}]}, {\"id\": \"multiagent\", \"d\": \"ai\", \"col\": 15, \"row\": 7, \"l\": \"Multi-agent systems\", \"books\": [{\"a\": \"Shoham & Leyton-Brown\", \"t\": \"Multiagent Systems: Algorithmic, Game-Theoretic, and Logical Foundations (free)\", \"n\": \"The rigorous treatment. Game theory, mechanism design, logical formalisms.\"}, {\"a\": \"Wooldridge\", \"t\": \"An Introduction to MultiAgent Systems\", \"n\": \"More accessible. Agent architectures, communication, norms.\"}]}, {\"id\": \"formalverif\", \"d\": \"ai\", \"col\": 16, \"row\": 6, \"l\": \"Formal verification\", \"books\": [{\"a\": \"Clarke, Grumberg & Peled\", \"t\": \"Model Checking\", \"n\": \"The original model checking book by its inventors. CTL, LTL, BDDs.\"}, {\"a\": \"Baier & Katoen\", \"t\": \"Principles of Model Checking\", \"n\": \"The graduate standard. More complete and modern than Clarke.\"}, {\"a\": \"Nipkow, Paulson & Wenzel\", \"t\": \"Isabelle/HOL: A Proof Assistant for Higher-Order Logic (free)\", \"n\": \"Interactive theorem proving. The Isabelle bible.\"}]}, {\"id\": \"cogarch\", \"d\": \"ai\", \"col\": 16, \"row\": 7, \"l\": \"Cognitive architectures\", \"books\": [{\"a\": \"Newell\", \"t\": \"Unified Theories of Cognition\", \"n\": \"SOAR foundation. The most ambitious AGI theory. Mandatory.\"}, {\"a\": \"Anderson\", \"t\": \"The Architecture of Cognition\", \"n\": \"ACT-R. Psychological grounding for cognitive architectures.\"}, {\"a\": \"Anderson & Lebiere\", \"t\": \"The Atomic Components of Thought\", \"n\": \"Full ACT-R theory with empirical validation.\"}]}, {\"id\": \"nonmon\", \"d\": \"ai\", \"col\": 14, \"row\": 7, \"l\": \"Non-monotonic reasoning\", \"books\": [{\"a\": \"Reiter\", \"t\": \"A Logic for Default Reasoning (Artificial Intelligence, 1980)\", \"n\": \"The foundational paper. Free. Read before any textbook.\"}, {\"a\": \"Gelfond & Lifschitz\", \"t\": \"The Stable Model Semantics for Logic Programming (ICLP 1988)\", \"n\": \"Answer set programming foundations. Primary source.\"}, {\"a\": \"Brewka, Dix & Konolige\", \"t\": \"Nonmonotonic Reasoning: An Overview\", \"n\": \"Survey of all major frameworks. Good map of the field.\"}]}, {\"id\": \"aixi\", \"d\": \"ai\", \"col\": 16, \"row\": 8, \"l\": \"Universal AI (AIXI)\", \"books\": [{\"a\": \"Hutter\", \"t\": \"Universal Artificial Intelligence: Sequential Decisions Based on Algorithmic Probability\", \"n\": \"The AIXI book. Requires measure theory, computability, and probability.\"}, {\"a\": \"Li & Vit\\u00e1nyi\", \"t\": \"An Introduction to Kolmogorov Complexity and Its Applications\", \"n\": \"The prerequisite. Kolmogorov complexity, Solomonoff induction.\"}, {\"a\": \"Legg\", \"t\": \"Machine Super Intelligence (PhD thesis, 2008, free)\", \"n\": \"Formal definitions of universal intelligence. Accessible entry to AIXI theory.\"}]}]";
