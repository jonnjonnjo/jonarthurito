---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Archive / Blog">
  <div class="min-h-screen bg-kanagawa-bgDim text-kanagawa-fg px-4 sm:px-8 py-12 font-sans">
    
    <div class="max-w-4xl mx-auto">
      
      <header class="mb-12 flex flex-col items-center text-center">
        <h1 class="text-3xl font-normal text-kanagawa-fg mb-4">
          <a href="https://en.wiktionary.org/wiki/सूत्र" target="_blank" class="hover:text-kanagawa-orange transition-colors">सूत्र</a> &middot; 
          <a href="https://en.wiktionary.org/wiki/كتاب" target="_blank" class="hover:text-kanagawa-yellow transition-colors">كتاب</a> &middot; 
          <a href="https://en.wiktionary.org/wiki/文" target="_blank" class="hover:text-kanagawa-blue transition-colors">文</a> &middot; 
          <a href="https://en.wiktionary.org/wiki/renungan" target="_blank" class="italic hover:text-kanagawa-pink transition-colors">Renungan</a>
        </h1>
        
        <div class="text-[13px] font-mono text-kanagawa-comment uppercase tracking-widest">
          N={posts.length}
        </div>
      </header>

      <div class="font-sans text-[16px] leading-tight">
        {posts.map(post => (
          <div class="flex items-baseline gap-2 py-1.5 group">
            
            <time class="font-mono text-[13px] text-kanagawa-comment shrink-0 w-24">
              {post.data.date}
            </time>

            <a href={`/blog/${post.id}`} class="text-kanagawa-fg group-hover:text-kanagawa-blue transition-colors shrink-0">
              {post.data.title}
            </a>
            
            <div class="hidden sm:block flex-1 border-b border-dotted border-kanagawa-comment/30 relative -top-1.5 mx-2 group-hover:border-kanagawa-blue/40 transition-colors"></div>

            <div class="font-mono text-[11px] text-kanagawa-fgDim shrink-0 text-right space-x-1.5">
              {post.data.tags.map(tag => (
                <span class="group-hover:text-kanagawa-cyan transition-colors">[{tag}]</span>
              ))}
            </div>
            
          </div>
        ))}
      </div>

      <footer class="mt-16 pt-4 border-t border-kanagawa-bgHighlight/40 flex justify-center">
        <a href="/" class="text-[13px] font-mono text-kanagawa-comment hover:text-kanagawa-fg transition-colors flex items-center gap-2 group">
          <span class="text-kanagawa-blue group-hover:-translate-x-1 transition-transform">&lt;-</span>
          <span>return</span>
        </a>
      </footer>
      
    </div>
  </div>
</Layout>
