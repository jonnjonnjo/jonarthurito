---
import nodes from '../data/learning-nodes.json';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rigorous Fundamentals — Learning DAG</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fdfcf9;--surf:#f4f1ea;--surf2:#ffffff;
  --b1:#d8d4c8;--b2:#e8e4d8;
  --t1:#1f1d18;--t2:#5a584f;--t3:#9a968a;

  --found:#475569;   /* slate */
  --math:#047857;   /* emerald */
  --phil:#6d28d9;   /* violet */
  --ling:#c2410c;   /* orange */
  --cs:#0369a1;     /* sky */
  --ai:#a16207;     /* amber */
  --phys:#b91c1c;   /* red */
  --hw:#0e7490;     /* cyan */

  --anc:#c2410c;     /* direct prerequisites */
  --desc:#0e7490;    /* direct unlocks */
  --self:#6d28d9;    /* clicked node */

  --font:'EB Garamond',Georgia,serif;
  --mono:'IBM Plex Mono',monospace;
}
html,body{height:100%;background:var(--bg);color:var(--t1);font-family:var(--font);overflow:hidden}
#app{display:flex;flex-direction:column;height:100vh;width:100vw;position:fixed;top:0;left:0}

#topbar{display:flex;align-items:center;justify-content:space-between;padding:7px 14px;border-bottom:1px solid var(--b1);flex-shrink:0;gap:8px;flex-wrap:wrap;background:var(--surf)}
#topbar h1{font-family:var(--mono);font-size:9px;font-weight:400;color:var(--t3);letter-spacing:.18em;text-transform:uppercase;white-space:nowrap}
#legend{display:flex;gap:10px;flex-wrap:wrap}
.li{display:flex;align-items:center;gap:4px;font-size:8.5px;color:var(--t2);font-family:var(--mono)}
.ld{width:7px;height:7px;border-radius:1px;flex-shrink:0}

#filters{display:flex;gap:3px;padding:5px 14px;border-bottom:1px solid var(--b1);flex-shrink:0;flex-wrap:wrap;background:var(--surf)}
.fb{font-size:8px;font-family:var(--mono);padding:2px 7px;border-radius:2px;border:1px solid var(--b1);background:transparent;color:var(--t3);cursor:pointer;transition:all .1s;letter-spacing:.07em;text-transform:uppercase}
.fb:hover{color:var(--t2)}
.fb.active{font-weight:500;color:#fdfcf9!important;border-color:transparent!important}
.fb[data-cat="all"].active{background:var(--found)}
.fb[data-cat="found"].active{background:var(--found)}
.fb[data-cat="math"].active{background:var(--math)}
.fb[data-cat="phil"].active{background:var(--phil)}
.fb[data-cat="ling"].active{background:var(--ling)}
.fb[data-cat="cs"].active{background:var(--cs)}
.fb[data-cat="ai"].active{background:var(--ai)}
.fb[data-cat="phys"].active{background:var(--phys)}
.fb[data-cat="hw"].active{background:var(--hw)}

#hint{font-family:var(--mono);font-size:7.5px;color:var(--t3);padding:3px 14px;border-bottom:1px solid var(--b1);background:var(--surf);flex-shrink:0;letter-spacing:.04em}
#hint b{color:var(--t2);font-weight:400}
#hint .akey{color:var(--anc)}
#hint .dkey{color:var(--desc)}
#hint .skey{color:var(--self)}

#main{display:flex;flex:1;overflow:hidden}
#cw{flex:1;overflow:auto;position:relative;background:var(--bg);cursor:grab}
#cw.panning{cursor:grabbing;user-select:none}
#dag-svg{display:block}

#panel{width:0;flex-shrink:0;overflow:hidden;border-left:1px solid var(--b1);transition:width .2s ease;background:var(--surf)}
#panel.open{width:380px;overflow-y:auto}
#pi{padding:16px;min-width:380px}
.pcl{float:right;font-size:16px;color:var(--t3);cursor:pointer;line-height:1;font-family:var(--mono)}
.pcl:hover{color:var(--t1)}
.pcat{font-family:var(--mono);font-size:8px;letter-spacing:.16em;text-transform:uppercase;margin-bottom:3px}
.ptit{font-size:15px;font-weight:500;margin-bottom:7px;line-height:1.3}
.pdsc{font-size:11.5px;color:var(--t2);line-height:1.85;margin-bottom:8px}
.psec{font-family:var(--mono);font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:var(--t3);margin:12px 0 5px;padding-top:9px;border-top:1px solid var(--b1)}
.ptgs{display:flex;flex-wrap:wrap;gap:3px}
.ptg{font-size:8px;padding:2px 7px;border-radius:2px;border:1px solid var(--b1);color:var(--t2);cursor:pointer;font-family:var(--mono);transition:all .1s}
.ptg:hover{color:var(--t1)}
#pbooks{display:flex;flex-direction:column;gap:7px;margin-top:4px}
.bk{padding:9px 12px;background:var(--surf2);border:1px solid #b8b4a8;border-radius:5px;box-shadow:0 1px 3px rgba(0,0,0,.07)}
.bk.primary{border-left:3px solid var(--self)}
.btit{font-size:13px;font-weight:500;line-height:1.35;color:var(--t1)}
.baut{font-size:10.5px;color:var(--t2);margin-top:3px;font-family:var(--mono)}
.bnot{font-size:10.5px;color:var(--t2);margin-top:5px;line-height:1.55;font-style:italic;border-left:2px solid var(--b2);padding-left:8px}
.bprim{color:var(--self);margin-right:5px;font-style:normal}
.lk{padding:4px 0;border-bottom:1px solid var(--b1)}
.lk:last-child{border-bottom:none}
.lk a{font-size:10px;color:var(--cs);text-decoration:none;font-family:var(--mono);line-height:1.5;display:block}
.lk a:hover{text-decoration:underline}
.kcount{font-family:var(--mono);font-size:9px;color:var(--t3);margin-bottom:4px}
.kcount b{color:var(--t1)}

#tip{position:fixed;pointer-events:none;background:var(--surf2);border:1px solid var(--b1);border-radius:3px;padding:5px 9px;font-size:9px;color:var(--t2);font-family:var(--mono);max-width:280px;display:none;z-index:200;line-height:1.7}
</style>
</head>
<body>
<div id="app">
<div id="topbar">
  <h1>Rigorous Fundamentals — Jonathan's reset</h1>
  <div id="legend">
    <div class="li"><div class="ld" style="background:var(--found)"></div>Foundations</div>
    <div class="li"><div class="ld" style="background:var(--math)"></div>Mathematics</div>
    <div class="li"><div class="ld" style="background:var(--phil)"></div>Philosophy</div>
    <div class="li"><div class="ld" style="background:var(--ling)"></div>Linguistics</div>
    <div class="li"><div class="ld" style="background:var(--cs)"></div>Computer Science</div>
    <div class="li"><div class="ld" style="background:var(--ai)"></div>AI (general)</div>
    <div class="li"><div class="ld" style="background:var(--phys)"></div>Physics</div>
    <div class="li"><div class="ld" style="background:var(--hw)"></div>Hardware</div>
  </div>
</div>
<div id="filters">
  <button class="fb active" data-cat="all">All</button>
  <button class="fb" data-cat="found">Foundations</button>
  <button class="fb" data-cat="math">Mathematics</button>
  <button class="fb" data-cat="phil">Philosophy</button>
  <button class="fb" data-cat="ling">Linguistics</button>
  <button class="fb" data-cat="cs">CS</button>
  <button class="fb" data-cat="ai">AI</button>
  <button class="fb" data-cat="phys">Physics</button>
  <button class="fb" data-cat="hw">Hardware</button>
</div>
<div id="hint">click a node → highlight <span class="skey">■ self</span> + <b><span class="akey">direct prerequisites (in)</span></b> + <b><span class="dkey">direct unlocks (out)</span></b> &nbsp;·&nbsp; click again or × to release &nbsp;·&nbsp; ★ = primary source</div>
<div id="main">
  <div id="cw"><svg id="dag-svg" xmlns="http://www.w3.org/2000/svg"></svg></div>
  <div id="panel"><div id="pi">
    <span class="pcl" onclick="closePanel()">×</span>
    <div class="pcat" id="pcat"></div>
    <div class="ptit" id="ptit"></div>
    <div class="pdsc" id="pdsc"></div>
    <div class="psec">Books — start here</div>
    <div id="pbooks"></div>
    <div class="psec" id="ppre-sec">Prerequisites (read first) <span class="kcount" id="ppre-count"></span></div>
    <div class="ptgs" id="ppre"></div>
    <div class="psec" id="punl-sec">Unlocks (read after) <span class="kcount" id="punl-count"></span></div>
    <div class="ptgs" id="punl"></div>
  </div></div>
</div>
<div id="tip"></div>
</div>
<script define:vars={{ nodes }}>
const C={found:'#94a3b8',math:'#34d399',phil:'#c084fc',ling:'#fb923c',cs:'#38bdf8',ai:'#facc15',phys:'#f87171',hw:'#22d3ee'};
const CAT_NAME={found:'Foundations',math:'Mathematics',phil:'Philosophy',ling:'Linguistics',cs:'Computer Science',ai:'Artificial Intelligence',phys:'Physics',hw:'Hardware / Electronics'};
const ANC='#f59e0b', DESC='#06b6d4', SELF='#a78bfa';

const N = nodes;

// ═══════════════════════════════════════════════════════════════════
// LAYOUT — automatic tiering via longest path from roots
// ═══════════════════════════════════════════════════════════════════
const TIER={};
function depth(id,visiting=new Set()){
  if(id in TIER)return TIER[id];
  if(visiting.has(id))return 0;
  visiting.add(id);
  const pre=N[id].pre||[];
  if(pre.length===0){TIER[id]=0;return 0;}
  const d=1+Math.max(...pre.map(p=>depth(p,visiting)));
  visiting.delete(id);
  TIER[id]=d;
  return d;
}
for(const id in N)depth(id);

// reverse adjacency (descendants)
const REV={};
for(const id in N)REV[id]=[];
for(const id in N)for(const p of(N[id].pre||[])){if(REV[p])REV[p].push(id);}

// group by tier, then by category for stable ordering
const byTier={};
for(const id in N){const t=TIER[id];(byTier[t]=byTier[t]||[]).push(id);}
const CAT_ORDER=['found','math','phil','ling','cs','ai','phys','hw'];
const tiers=Object.keys(byTier).map(Number).sort((a,b)=>a-b);
for(const t of tiers){byTier[t].sort((a,b)=>{
  const ca=CAT_ORDER.indexOf(N[a].cat),cb=CAT_ORDER.indexOf(N[b].cat);
  if(ca!==cb)return ca-cb;
  return N[a].label.localeCompare(N[b].label);
});}

// node x positions: distribute evenly per tier
const COL_W=300,ROW_H=200,PAD_L=220,PAD_T=180;
const maxCol=Math.max(...tiers.map(t=>byTier[t].length));
const SVGW=PAD_L*2+(maxCol-1)*COL_W+320;
const SVGH=PAD_T*2+tiers.length*ROW_H+180;

const POS={};
for(const t of tiers){
  const arr=byTier[t];
  const span=(maxCol-1)*COL_W;
  const start=PAD_L+(span-(arr.length-1)*COL_W)/2;
  arr.forEach((id,i)=>{POS[id]={x:start+i*COL_W,y:PAD_T+t*ROW_H};});
}

// ═══════════════════════════════════════════════════════════════════
// SVG RENDER
// ═══════════════════════════════════════════════════════════════════
const svg=document.getElementById('dag-svg');
svg.setAttribute('viewBox',`0 0 ${SVGW} ${SVGH}`);
svg.setAttribute('width',SVGW);
svg.setAttribute('height',SVGH);

// defs: arrow markers
const defs=document.createElementNS('http://www.w3.org/2000/svg','defs');
defs.innerHTML=`
<marker id="ar" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="4" markerHeight="4" orient="auto-start-reverse">
  <path d="M2 2.5L8 5L2 7.5" fill="none" stroke="#a8a497" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</marker>
<marker id="ar-anc" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="4.5" markerHeight="4.5" orient="auto-start-reverse">
  <path d="M2 2.5L8 5L2 7.5" fill="none" stroke="${ANC}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
</marker>
<marker id="ar-desc" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="4.5" markerHeight="4.5" orient="auto-start-reverse">
  <path d="M2 2.5L8 5L2 7.5" fill="none" stroke="${DESC}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
</marker>`;
svg.appendChild(defs);

// edges first (so nodes draw on top)
const NS='http://www.w3.org/2000/svg';
const edgeEls=[];
for(const tid in N){
  for(const fid of(N[tid].pre||[])){
    const a=POS[fid],b=POS[tid];if(!a||!b)continue;
    const dx=b.x-a.x,dy=b.y-a.y;
    // start at bottom of source rect, end at top of target rect
    const NW=210,NH=56;
    const x1=a.x,y1=a.y+NH/2;
    const x2=b.x,y2=b.y-NH/2;
    const midY=(y1+y2)/2;
    const path=document.createElementNS(NS,'path');
    path.setAttribute('d',`M${x1} ${y1} C ${x1} ${midY}, ${x2} ${midY}, ${x2} ${y2}`);
    path.setAttribute('class','edge');
    path.setAttribute('fill','none');
    path.setAttribute('stroke','#a8a497');
    path.setAttribute('stroke-width','0.7');
    path.setAttribute('marker-end','url(#ar)');
    path.dataset.from=fid;path.dataset.to=tid;
    svg.appendChild(path);
    edgeEls.push(path);
  }
}

// nodes
const nodeEls={};
const NW=210,NH=56;
function wrap(text,maxLen){
  const words=text.split(' ');const lines=[];let cur='';
  for(const w of words){if((cur+' '+w).trim().length>maxLen){lines.push(cur);cur=w;}else cur=(cur?cur+' ':'')+w;}
  if(cur)lines.push(cur);return lines;
}
for(const id in N){
  const node=N[id],p=POS[id],col=C[node.cat];
  const g=document.createElementNS(NS,'g');
  g.setAttribute('class','node');g.setAttribute('transform',`translate(${p.x-NW/2} ${p.y-NH/2})`);
  g.style.cursor='pointer';
  const rect=document.createElementNS(NS,'rect');
  rect.setAttribute('width',NW);rect.setAttribute('height',NH);rect.setAttribute('rx',3);
  rect.setAttribute('fill','#ffffff');rect.setAttribute('stroke',col+'88');
  rect.setAttribute('stroke-width','0.9');
  g.appendChild(rect);
  // category dot
  const dot=document.createElementNS(NS,'rect');
  dot.setAttribute('x',6);dot.setAttribute('y',6);dot.setAttribute('width',5);dot.setAttribute('height',5);dot.setAttribute('fill',col);dot.setAttribute('rx',1);
  g.appendChild(dot);
  // label (wrap to ~25 chars)
  const lines=wrap(node.label,22);
  const ly=lines.length===1?NH/2+4.5:NH/2-(lines.length-1)*7+4.5;
  lines.forEach((ln,i)=>{
    const tx=document.createElementNS(NS,'text');
    tx.setAttribute('x',NW/2);tx.setAttribute('y',ly+i*14);
    tx.setAttribute('text-anchor','middle');tx.setAttribute('fill','#1f1d18');
    tx.setAttribute('font-family',"'EB Garamond',Georgia,serif");
    tx.setAttribute('font-size','13');tx.setAttribute('font-weight','400');
    tx.style.pointerEvents='none';tx.textContent=ln;
    g.appendChild(tx);
  });
  svg.appendChild(g);
  nodeEls[id]={g,rect,col};
  g.addEventListener('mouseenter',e=>{doHover(id);showTip(e,node);});
  g.addEventListener('mouseleave',()=>{clearHover();hideTip();});
  g.addEventListener('mousemove',moveTip);
  g.addEventListener('click',()=>handleClick(id));
}

// ═══════════════════════════════════════════════════════════════════
// HIGHLIGHT
// ═══════════════════════════════════════════════════════════════════
let filterCat='all',lockedId=null;

function applyHighlight(id){
  const directPre=new Set(N[id].pre||[]);
  const directUnl=new Set(REV[id]||[]);
  for(const nid in nodeEls){
    const{g,rect,col}=nodeEls[nid];
    const isSelf=nid===id,isA=directPre.has(nid),isD=directUnl.has(nid);
    if(isSelf){
      g.style.opacity='1';
      rect.setAttribute('stroke',SELF);
      rect.setAttribute('stroke-width','2.6');
      rect.setAttribute('fill','#ede9fe');
    } else if(isA){
      g.style.opacity='1';
      rect.setAttribute('stroke',ANC);
      rect.setAttribute('stroke-width','1.8');
      rect.setAttribute('fill','#fff1e6');
    } else if(isD){
      g.style.opacity='1';
      rect.setAttribute('stroke',DESC);
      rect.setAttribute('stroke-width','1.8');
      rect.setAttribute('fill','#e0f7fa');
    } else {
      g.style.opacity='0.18';
      rect.setAttribute('stroke',col+'40');
      rect.setAttribute('stroke-width','0.6');
      rect.setAttribute('fill','#ffffff');
    }
  }
  for(const el of edgeEls){
    const f=el.dataset.from,t=el.dataset.to;
    const isAncEdge=(t===id&&directPre.has(f));
    const isUnlEdge=(f===id&&directUnl.has(t));
    if(isAncEdge){
      el.style.opacity='1';
      el.setAttribute('stroke',ANC);el.setAttribute('stroke-width','1.8');
      el.setAttribute('marker-end','url(#ar-anc)');
    } else if(isUnlEdge){
      el.style.opacity='1';
      el.setAttribute('stroke',DESC);el.setAttribute('stroke-width','1.8');
      el.setAttribute('marker-end','url(#ar-desc)');
    } else {
      el.style.opacity='0.08';
      el.setAttribute('stroke','#c8c4b8');el.setAttribute('stroke-width','0.5');
      el.setAttribute('marker-end','url(#ar)');
    }
  }
}

function clearHighlight(){
  for(const nid in nodeEls){
    const{g,rect,col}=nodeEls[nid];
    const vis=filterCat==='all'||N[nid].cat===filterCat;
    g.style.opacity=vis?'1':'0.18';
    rect.setAttribute('stroke',col+'88');
    rect.setAttribute('stroke-width','0.9');
    rect.setAttribute('fill','#ffffff');
  }
  for(const el of edgeEls){
    el.style.opacity=filterCat==='all'?'0.45':'0.1';
    el.setAttribute('stroke','#a8a497');el.setAttribute('stroke-width','0.7');
    el.setAttribute('marker-end','url(#ar)');
  }
}

// ═══════════════════════════════════════════════════════════════════
// DRAG-TO-PAN
// ═══════════════════════════════════════════════════════════════════
const cw=document.getElementById('cw');
let panning=false,panX=0,panY=0,scrollX0=0,scrollY0=0,wasDrag=false;
cw.addEventListener('mousedown',e=>{
  if(e.button!==0)return;
  panning=true;wasDrag=false;
  panX=e.clientX;panY=e.clientY;
  scrollX0=cw.scrollLeft;scrollY0=cw.scrollTop;
  cw.classList.add('panning');
  e.preventDefault();
});
window.addEventListener('mousemove',e=>{
  if(!panning)return;
  const dx=e.clientX-panX,dy=e.clientY-panY;
  if(!wasDrag&&(Math.abs(dx)>4||Math.abs(dy)>4))wasDrag=true;
  cw.scrollLeft=scrollX0-dx;
  cw.scrollTop=scrollY0-dy;
});
window.addEventListener('mouseup',()=>{
  panning=false;cw.classList.remove('panning');
});

function doHover(id){if(lockedId===null)applyHighlight(id);}
function clearHover(){if(lockedId!==null)applyHighlight(lockedId);else clearHighlight();}
function handleClick(id){
  if(wasDrag)return;
  if(lockedId===id){lockedId=null;clearHighlight();closePanel();}
  else{lockedId=id;applyHighlight(id);openPanel(id);}
}

document.querySelectorAll('.fb').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.fb').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');filterCat=btn.dataset.cat;
    if(lockedId)applyHighlight(lockedId);else clearHighlight();
  });
});

// ═══════════════════════════════════════════════════════════════════
// TOOLTIP & PANEL
// ═══════════════════════════════════════════════════════════════════
const tip=document.getElementById('tip');
function showTip(e,node){
  const pn=(node.pre||[]).map(p=>N[p]?.label||p).join(', ')||'Root — no prerequisites';
  tip.innerHTML=`<b style="color:var(--t1)">${node.label}</b><br>${pn}`;
  tip.style.display='block';moveTip(e);
}
function moveTip(e){tip.style.left=(e.clientX+14)+'px';tip.style.top=(e.clientY-40)+'px';}
function hideTip(){tip.style.display='none';}

const panel=document.getElementById('panel');
function tagsHTML(ids,colorFn){
  if(ids.length===0)return'<span style="font-size:10px;color:var(--t3)">— none —</span>';
  return ids.map(p=>{const pn=N[p],pc=colorFn?colorFn(p):C[pn?.cat]||'#888';
    return`<span class="ptg" style="border-color:${pc}55;color:${pc}" onclick="handleClick('${p}')">${pn?.label||p} ↗</span>`;}).join('');
}
function openPanel(id){
  const node=N[id],col=C[node.cat];
  document.getElementById('pcat').textContent=(CAT_NAME[node.cat]||node.cat).toUpperCase();
  document.getElementById('pcat').style.color=col;
  document.getElementById('ptit').textContent=node.label;
  document.getElementById('pdsc').textContent=node.desc;
  document.getElementById('pbooks').innerHTML=(node.books||[]).map(b=>`<div class="bk${b.primary?' primary':''}">
    <div class="btit">${b.primary?'<span class="bprim">★</span>':''}${b.t}</div>
    <div class="baut">${b.a}</div>
    ${b.n?`<div class="bnot">${b.n}</div>`:''}
  </div>`).join('');
  const pre=(node.pre||[]).slice().sort((a,b)=>TIER[a]-TIER[b]);
  const unl=(REV[id]||[]).slice().sort((a,b)=>TIER[a]-TIER[b]);
  document.getElementById('ppre-count').innerHTML=`<b>${pre.length}</b>`;
  document.getElementById('punl-count').innerHTML=`<b>${unl.length}</b>`;
  document.getElementById('ppre').innerHTML=tagsHTML(pre,()=>ANC);
  document.getElementById('punl').innerHTML=tagsHTML(unl,()=>DESC);
  panel.classList.add('open');
}
function closePanel(){panel.classList.remove('open');lockedId=null;clearHighlight();}
window.handleClick=handleClick;
window.closePanel=closePanel;

clearHighlight();
</script>
</body>
</html>
