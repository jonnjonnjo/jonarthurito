<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rigorous Fundamentals — Learning DAG</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fdfcf9;--surf:#f4f1ea;--surf2:#ffffff;
  --b1:#d8d4c8;--b2:#e8e4d8;
  --t1:#1f1d18;--t2:#5a584f;--t3:#9a968a;

  --found:#475569;   /* slate */
  --math:#047857;   /* emerald */
  --phil:#6d28d9;   /* violet */
  --ling:#c2410c;   /* orange */
  --cs:#0369a1;     /* sky */
  --ai:#a16207;     /* amber */
  --phys:#b91c1c;   /* red */
  --hw:#0e7490;     /* cyan */

  --anc:#c2410c;     /* direct prerequisites */
  --desc:#0e7490;    /* direct unlocks */
  --self:#6d28d9;    /* clicked node */

  --font:'EB Garamond',Georgia,serif;
  --mono:'IBM Plex Mono',monospace;
}
html,body{height:100%;background:var(--bg);color:var(--t1);font-family:var(--font);overflow:hidden}
#app{display:flex;flex-direction:column;height:100vh;width:100vw;position:fixed;top:0;left:0}

#topbar{display:flex;align-items:center;justify-content:space-between;padding:7px 14px;border-bottom:1px solid var(--b1);flex-shrink:0;gap:8px;flex-wrap:wrap;background:var(--surf)}
#topbar h1{font-family:var(--mono);font-size:9px;font-weight:400;color:var(--t3);letter-spacing:.18em;text-transform:uppercase;white-space:nowrap}
#legend{display:flex;gap:10px;flex-wrap:wrap}
.li{display:flex;align-items:center;gap:4px;font-size:8.5px;color:var(--t2);font-family:var(--mono)}
.ld{width:7px;height:7px;border-radius:1px;flex-shrink:0}

#filters{display:flex;gap:3px;padding:5px 14px;border-bottom:1px solid var(--b1);flex-shrink:0;flex-wrap:wrap;background:var(--surf)}
.fb{font-size:8px;font-family:var(--mono);padding:2px 7px;border-radius:2px;border:1px solid var(--b1);background:transparent;color:var(--t3);cursor:pointer;transition:all .1s;letter-spacing:.07em;text-transform:uppercase}
.fb:hover{color:var(--t2)}
.fb.active{font-weight:500;color:#fdfcf9!important;border-color:transparent!important}
.fb[data-cat="all"].active{background:var(--found)}
.fb[data-cat="found"].active{background:var(--found)}
.fb[data-cat="math"].active{background:var(--math)}
.fb[data-cat="phil"].active{background:var(--phil)}
.fb[data-cat="ling"].active{background:var(--ling)}
.fb[data-cat="cs"].active{background:var(--cs)}
.fb[data-cat="ai"].active{background:var(--ai)}
.fb[data-cat="phys"].active{background:var(--phys)}
.fb[data-cat="hw"].active{background:var(--hw)}

#hint{font-family:var(--mono);font-size:7.5px;color:var(--t3);padding:3px 14px;border-bottom:1px solid var(--b1);background:var(--surf);flex-shrink:0;letter-spacing:.04em}
#hint b{color:var(--t2);font-weight:400}
#hint .akey{color:var(--anc)}
#hint .dkey{color:var(--desc)}
#hint .skey{color:var(--self)}

#main{display:flex;flex:1;overflow:hidden}
#cw{flex:1;overflow:auto;position:relative;background:var(--bg);cursor:grab}
#cw.panning{cursor:grabbing;user-select:none}
#dag-svg{display:block}

#panel{width:0;flex-shrink:0;overflow:hidden;border-left:1px solid var(--b1);transition:width .2s ease;background:var(--surf)}
#panel.open{width:380px;overflow-y:auto}
#pi{padding:16px;min-width:380px}
.pcl{float:right;font-size:16px;color:var(--t3);cursor:pointer;line-height:1;font-family:var(--mono)}
.pcl:hover{color:var(--t1)}
.pcat{font-family:var(--mono);font-size:8px;letter-spacing:.16em;text-transform:uppercase;margin-bottom:3px}
.ptit{font-size:15px;font-weight:500;margin-bottom:7px;line-height:1.3}
.pdsc{font-size:11.5px;color:var(--t2);line-height:1.85;margin-bottom:8px}
.psec{font-family:var(--mono);font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:var(--t3);margin:12px 0 5px;padding-top:9px;border-top:1px solid var(--b1)}
.ptgs{display:flex;flex-wrap:wrap;gap:3px}
.ptg{font-size:8px;padding:2px 7px;border-radius:2px;border:1px solid var(--b1);color:var(--t2);cursor:pointer;font-family:var(--mono);transition:all .1s}
.ptg:hover{color:var(--t1)}
#pbooks{display:flex;flex-direction:column;gap:7px;margin-top:4px}
.bk{padding:9px 12px;background:var(--surf2);border:1px solid #b8b4a8;border-radius:5px;box-shadow:0 1px 3px rgba(0,0,0,.07)}
.bk.primary{border-left:3px solid var(--self)}
.btit{font-size:13px;font-weight:500;line-height:1.35;color:var(--t1)}
.baut{font-size:10.5px;color:var(--t2);margin-top:3px;font-family:var(--mono)}
.bnot{font-size:10.5px;color:var(--t2);margin-top:5px;line-height:1.55;font-style:italic;border-left:2px solid var(--b2);padding-left:8px}
.bprim{color:var(--self);margin-right:5px;font-style:normal}
.lk{padding:4px 0;border-bottom:1px solid var(--b1)}
.lk:last-child{border-bottom:none}
.lk a{font-size:10px;color:var(--cs);text-decoration:none;font-family:var(--mono);line-height:1.5;display:block}
.lk a:hover{text-decoration:underline}
.kcount{font-family:var(--mono);font-size:9px;color:var(--t3);margin-bottom:4px}
.kcount b{color:var(--t1)}

#tip{position:fixed;pointer-events:none;background:var(--surf2);border:1px solid var(--b1);border-radius:3px;padding:5px 9px;font-size:9px;color:var(--t2);font-family:var(--mono);max-width:280px;display:none;z-index:200;line-height:1.7}
</style>
</head>
<body>
<div id="app">
<div id="topbar">
  <h1>Rigorous Fundamentals — Jonathan's reset</h1>
  <div id="legend">
    <div class="li"><div class="ld" style="background:var(--found)"></div>Foundations</div>
    <div class="li"><div class="ld" style="background:var(--math)"></div>Mathematics</div>
    <div class="li"><div class="ld" style="background:var(--phil)"></div>Philosophy</div>
    <div class="li"><div class="ld" style="background:var(--ling)"></div>Linguistics</div>
    <div class="li"><div class="ld" style="background:var(--cs)"></div>Computer Science</div>
    <div class="li"><div class="ld" style="background:var(--ai)"></div>AI (general)</div>
    <div class="li"><div class="ld" style="background:var(--phys)"></div>Physics</div>
    <div class="li"><div class="ld" style="background:var(--hw)"></div>Hardware</div>
  </div>
</div>
<div id="filters">
  <button class="fb active" data-cat="all">All</button>
  <button class="fb" data-cat="found">Foundations</button>
  <button class="fb" data-cat="math">Mathematics</button>
  <button class="fb" data-cat="phil">Philosophy</button>
  <button class="fb" data-cat="ling">Linguistics</button>
  <button class="fb" data-cat="cs">CS</button>
  <button class="fb" data-cat="ai">AI</button>
  <button class="fb" data-cat="phys">Physics</button>
  <button class="fb" data-cat="hw">Hardware</button>
</div>
<div id="hint">click a node → highlight <span class="skey">■ self</span> + <b><span class="akey">direct prerequisites (in)</span></b> + <b><span class="dkey">direct unlocks (out)</span></b> &nbsp;·&nbsp; click again or × to release &nbsp;·&nbsp; ★ = primary source</div>
<div id="main">
  <div id="cw"><svg id="dag-svg" xmlns="http://www.w3.org/2000/svg"></svg></div>
  <div id="panel"><div id="pi">
    <span class="pcl" onclick="closePanel()">×</span>
    <div class="pcat" id="pcat"></div>
    <div class="ptit" id="ptit"></div>
    <div class="pdsc" id="pdsc"></div>
    <div class="psec">Books — start here</div>
    <div id="pbooks"></div>
    <div class="psec" id="ppre-sec">Prerequisites (read first) <span class="kcount" id="ppre-count"></span></div>
    <div class="ptgs" id="ppre"></div>
    <div class="psec" id="punl-sec">Unlocks (read after) <span class="kcount" id="punl-count"></span></div>
    <div class="ptgs" id="punl"></div>
  </div></div>
</div>
<div id="tip"></div>
</div>
<script>
const C={found:'#94a3b8',math:'#34d399',phil:'#c084fc',ling:'#fb923c',cs:'#38bdf8',ai:'#facc15',phys:'#f87171',hw:'#22d3ee'};
const CAT_NAME={found:'Foundations',math:'Mathematics',phil:'Philosophy',ling:'Linguistics',cs:'Computer Science',ai:'Artificial Intelligence',phys:'Physics',hw:'Hardware / Electronics'};
const ANC='#f59e0b', DESC='#06b6d4', SELF='#a78bfa';

// ═══════════════════════════════════════════════════════════════════
// NODES
// id:{cat,label,desc,books:[{t,a,n,primary?}],pre:[ids]}
// ═══════════════════════════════════════════════════════════════════
const N={

// ─── FOUNDATIONS ───────────────────────────────────────────────────
prop_logic:{cat:'found',label:'Propositional Logic',
desc:'Truth tables, connectives, tautologies, CNF/DNF, natural deduction. The floor of every formal discipline.',
pre:[],
books:[
  {t:'Begriffsschrift',a:'Gottlob Frege (1879)',n:'12 pages that founded modern logic. Read the primary source.',primary:true},
  {t:'Principles of Mathematical Logic',a:'D. Hilbert & W. Ackermann (1928)',n:'The textbook that shaped a generation. Terse and rigorous.'},
  {t:'forall x: Calgary',a:'P. D. Magnus & T. Button (free)',n:'Modern free intro, axiomatic.'},
]},

set_theory:{cat:'found',label:'Naive Set Theory',
desc:'Sets, relations, functions, cardinality, Cantor diagonalisation. The raw vocabulary of every later subject.',
pre:[],
books:[
  {t:'Naive Set Theory',a:'Paul Halmos (1960)',n:'~100 pages. The single best week of self-study you can take.',primary:true},
  {t:'Basic Set Theory',a:'A. Shen & N. K. Vereshchagin',n:'Soviet rigour. Free PDF online. Concise.'},
  {t:'Beiträge zur Begründung der transfiniten Mengenlehre',a:'Georg Cantor (1895/97)',n:'The original. Cantor builds the ordinals himself.',primary:true},
]},

proof:{cat:'found',label:'Mathematical Proof',
desc:'Direct, contradiction, contrapositive, induction, well-ordering. Writing mathematics, not computing it.',
pre:[],
books:[
  {t:'How to Prove It',a:'Daniel Velleman',n:'Best bridge from CS-mind to math-mind.',primary:true},
  {t:'Problems in Mathematics',a:'V. V. Prasolov',n:'Soviet olympiad tradition — proof by doing.'},
  {t:'Elements',a:'Euclid (~300 BC)',n:'The oldest proof tradition still in use. Books I–VI.'},
]},

pred_logic:{cat:'found',label:'First-Order Logic',
desc:'Quantifiers, terms, models, validity, prenex normal form, completeness theorem. The formal language of all of mathematics and CS theory.',
pre:['prop_logic','set_theory','proof'],
books:[
  {t:'A Mathematical Introduction to Logic',a:'Herbert Enderton',n:'Cleanest standard text.',primary:true},
  {t:'Mathematical Logic',a:'Yu. I. Manin',n:'Soviet. From a deep mathematician\'s view.'},
  {t:'Introduction to Mathematical Logic',a:'Elliott Mendelson',n:'The classic axiomatic standard.'},
]},

// ─── MATHEMATICS ───────────────────────────────────────────────────
number_systems:{cat:'math',label:'Number Systems (ℕ→ℝ)',
desc:'Peano axioms, construction of ℤ, ℚ, ℝ via Dedekind cuts or Cauchy sequences. What "2+2=4" actually means.',
pre:['set_theory','proof'],
books:[
  {t:'Was sind und was sollen die Zahlen?',a:'Richard Dedekind (1888)',n:'How ℕ is constructed. Primary source.',primary:true},
  {t:'Foundations of Analysis',a:'Edmund Landau (1930)',n:'German rigour. ℕ to ℂ from scratch.'},
  {t:'The Foundations of Arithmetic',a:'Gottlob Frege (1884)',n:'The logicist programme.'},
]},

discrete_math:{cat:'math',label:'Discrete Mathematics',
desc:'Combinatorics, recurrences, generating functions, graph theory, asymptotics. The mathematics of finite structures.',
pre:['pred_logic','proof'],
books:[
  {t:'Concrete Mathematics',a:'Graham, Knuth & Patashnik',n:'The standard. Computer-scientist\'s discrete math, done with rigour.',primary:true},
  {t:'A Course in Combinatorics',a:'J. H. van Lint & R. M. Wilson',n:'Cambridge classic.'},
  {t:'Diskretnaya Matematika',a:'F. A. Novikov',n:'Russian classic. Used at MGU.'},
]},

calculus:{cat:'math',label:'Calculus (one variable)',
desc:'Limits, continuity, derivatives, Riemann integral, sequences and series — done rigorously, with ε-δ proofs.',
pre:['proof','number_systems'],
books:[
  {t:'Calculus',a:'Michael Spivak',n:'Calculus as a first proof course. The standard for serious students.',primary:true},
  {t:'Mathematical Analysis I',a:'V. A. Zorich',n:'Soviet tradition. More rigorous and complete than Spivak.'},
  {t:'Differential and Integral Calculus',a:'G. M. Fichtenholz',n:'Soviet. Three volumes, exhaustively complete.'},
]},

linear_algebra:{cat:'math',label:'Linear Algebra',
desc:'Vector spaces, linear maps, eigenvalues, inner products, spectral theorem — coordinate-free.',
pre:['proof','number_systems'],
books:[
  {t:'Linear Algebra Done Right',a:'Sheldon Axler',n:'Determinants postponed. Pedagogically pure.',primary:true},
  {t:'Linear Algebra and Geometry',a:'A. I. Kostrikin & Yu. I. Manin',n:'Soviet. Linear algebra fused with geometry.'},
  {t:'Finite-Dimensional Vector Spaces',a:'Paul Halmos',n:'A Hungarian master\'s 200-page distillation.'},
]},

elementary_geometry:{cat:'math',label:'Euclidean & Synthetic Geometry',
desc:'Plane and solid Euclidean geometry, ruler-and-compass constructions, similarity, the conics.',
pre:['proof'],
books:[
  {t:'Geometry: Planimetry & Stereometry',a:'A. P. Kiselev',n:'The Russian school textbook. Used in the USSR for over a century. Translated by A. Givental.',primary:true},
  {t:'Elements',a:'Euclid (~300 BC)',n:'Books I–VI. The model.'},
  {t:'Geometry Revisited',a:'H. S. M. Coxeter & S. L. Greitzer',n:'Olympiad-flavoured geometry, beautifully done.'},
]},

elem_number_theory:{cat:'math',label:'Elementary Number Theory',
desc:'Divisibility, primes, congruences, quadratic reciprocity, Diophantine equations.',
pre:['discrete_math','proof'],
books:[
  {t:'An Introduction to the Theory of Numbers',a:'G. H. Hardy & E. M. Wright',n:'The classic English text.',primary:true},
  {t:'Elements of Number Theory',a:'I. M. Vinogradov',n:'Soviet master\'s textbook. Tight and brutal.'},
  {t:'A Classical Introduction to Modern Number Theory',a:'K. Ireland & M. Rosen',n:'Bridge to algebraic number theory.'},
]},

abstract_algebra:{cat:'math',label:'Abstract Algebra',
desc:'Groups, rings, fields, modules, Galois theory. The structural skeleton beneath all of mathematics.',
pre:['linear_algebra','elem_number_theory'],
books:[
  {t:'A Course in Algebra',a:'È. B. Vinberg',n:'Soviet master at MGU. Possibly the best single algebra book ever written.',primary:true},
  {t:'Algebra',a:'Serge Lang',n:'Bourbaki-style reference. Necessary but not always pedagogical.'},
  {t:'Basic Algebra I & II',a:'Nathan Jacobson',n:'American classic. Comprehensive.'},
]},

real_analysis:{cat:'math',label:'Real Analysis',
desc:'Metric spaces, sequences, continuity, differentiation, Riemann–Stieltjes integration, function spaces.',
pre:['calculus','set_theory','proof'],
books:[
  {t:'Principles of Mathematical Analysis',a:'Walter Rudin',n:'"Baby Rudin". The American gold standard. Terse.',primary:true},
  {t:'Mathematical Analysis I & II',a:'V. A. Zorich',n:'Soviet/Russian. More complete than Rudin and arguably better.',primary:true},
  {t:'Cours d\'analyse',a:'Roger Godement',n:'French analytic tradition (Bourbaki-adjacent).'},
]},

multivar_calc:{cat:'math',label:'Multivariable & Vector Calculus',
desc:'Differentiation in ℝⁿ, implicit/inverse function theorems, multiple integrals, line/surface integrals, Stokes.',
pre:['calculus','linear_algebra'],
books:[
  {t:'Calculus on Manifolds',a:'Michael Spivak',n:'140 pages. Stokes\' theorem on manifolds in chapter 5.',primary:true},
  {t:'Mathematical Analysis II',a:'V. A. Zorich',n:'The complete multivariable treatment.'},
  {t:'Advanced Calculus',a:'L. H. Loomis & S. Sternberg',n:'Free PDF. Coordinate-free, banach-space-flavoured.'},
]},

ode:{cat:'math',label:'Ordinary Differential Equations',
desc:'Existence-uniqueness, linear systems, phase plane, stability, Hamiltonian flows.',
pre:['calculus','linear_algebra'],
books:[
  {t:'Ordinary Differential Equations',a:'V. I. Arnold',n:'Soviet. The most beautiful ODE book ever written. Geometric viewpoint throughout.',primary:true},
  {t:'Differential Equations and Dynamical Systems',a:'Lawrence Perko',n:'Standard graduate-level Western text.'},
  {t:'Theory of Ordinary Differential Equations',a:'Coddington & Levinson',n:'Classical reference.'},
]},

probability:{cat:'math',label:'Probability Theory',
desc:'Measure-theoretic probability: (Ω,ℱ,P), random variables, LLN, CLT, conditional expectation, martingales.',
pre:['real_analysis','set_theory'],
books:[
  {t:'Probability',a:'A. N. Shiryaev',n:'Soviet. Stricter and deeper than Western analogues.',primary:true},
  {t:'Foundations of the Theory of Probability',a:'A. N. Kolmogorov (1933)',n:'The 80-page paper that founded modern probability.',primary:true},
  {t:'Probability Theory: A Comprehensive Course',a:'Achim Klenke',n:'German. Modern and complete.'},
]},

topology:{cat:'math',label:'General Topology',
desc:'Open sets, continuity, compactness, connectedness, product/quotient spaces, Tychonoff. The home of "limit".',
pre:['real_analysis','set_theory'],
books:[
  {t:'Topology',a:'James Munkres',n:'The pedagogical standard.',primary:true},
  {t:'General Topology',a:'John L. Kelley',n:'Classic graduate reference.'},
  {t:'Topologie',a:'Klaus Jänich',n:'German. Geometric intuition.'},
]},

complex_analysis:{cat:'math',label:'Complex Analysis',
desc:'Holomorphic functions, Cauchy theorem, residues, conformal maps, Riemann mapping. Where real analysis becomes magic.',
pre:['real_analysis'],
books:[
  {t:'Complex Analysis',a:'Lars V. Ahlfors',n:'Fields-medallist\'s textbook. The standard.',primary:true},
  {t:'Methods of the Theory of Functions of a Complex Variable',a:'M. A. Lavrentiev & B. V. Shabat',n:'Soviet classic, geometric style.'},
  {t:'Complex Analysis',a:'Stein & Shakarchi',n:'Modern Princeton series.'},
]},

measure_theory:{cat:'math',label:'Measure & Integration',
desc:'σ-algebras, Lebesgue measure, dominated convergence, Lᵖ spaces, Radon-Nikodym, Fubini-Tonelli.',
pre:['real_analysis'],
books:[
  {t:'Real Analysis: Modern Techniques and Their Applications',a:'Gerald B. Folland',n:'The standard graduate text.',primary:true},
  {t:'Measure Theory',a:'Paul Halmos',n:'1950 classic, still readable.'},
  {t:'Real Analysis',a:'H. L. Royden & P. M. Fitzpatrick',n:'The traditional American course.'},
]},

functional_analysis:{cat:'math',label:'Functional Analysis',
desc:'Banach/Hilbert spaces, bounded operators, Hahn-Banach, open mapping, spectral theorem.',
pre:['real_analysis','linear_algebra','measure_theory'],
books:[
  {t:'Elements of the Theory of Functions and Functional Analysis',a:'A. N. Kolmogorov & S. V. Fomin',n:'Soviet. The most-used functional analysis book on Earth.',primary:true},
  {t:'Functional Analysis',a:'Walter Rudin',n:'"Big Rudin". Western standard.'},
  {t:'Functional Analysis',a:'Peter D. Lax',n:'Modern, motivated.'},
]},

diff_geometry:{cat:'math',label:'Differential Geometry',
desc:'Smooth manifolds, tangent bundles, differential forms, Riemannian metrics, curvature.',
pre:['multivar_calc','topology','linear_algebra'],
books:[
  {t:'Differential Geometry of Curves and Surfaces',a:'Manfredo P. do Carmo',n:'The standard introduction.',primary:true},
  {t:'Riemannian Geometry',a:'Manfredo P. do Carmo',n:'The natural sequel.'},
  {t:'Modern Geometry I, II, III',a:'B. A. Dubrovin, A. T. Fomenko, S. P. Novikov',n:'Soviet trilogy. Geometry from a physicist\'s viewpoint.'},
]},

pde:{cat:'math',label:'Partial Differential Equations',
desc:'Heat, wave, Laplace equations; Fourier methods; Sobolev spaces; weak solutions; method of characteristics.',
pre:['real_analysis','ode','multivar_calc'],
books:[
  {t:'Partial Differential Equations',a:'Lawrence C. Evans',n:'The American graduate standard.',primary:true},
  {t:'Equations of Mathematical Physics',a:'A. N. Tikhonov & A. A. Samarskii',n:'Soviet classic.'},
  {t:'Partial Differential Equations',a:'V. I. Arnold (Lectures)',n:'Geometric, characteristics-first.'},
]},

// ─── PHILOSOPHY ────────────────────────────────────────────────────
aristotle_organon:{cat:'phil',label:'Aristotelian Logic (Organon)',
desc:'Syllogisms, categories, terms, contradiction, demonstration. The original logical canon, ~340 BC.',
pre:['prop_logic'],
books:[
  {t:'Organon (Categories, On Interpretation, Prior & Posterior Analytics, Topics, Sophistical Refutations)',a:'Aristotle',n:'Six works. Read in this order.',primary:true},
  {t:'Aristotle\'s Earlier Logic',a:'John Woods',n:'Modern logical reconstruction.'},
]},

ancient_phil:{cat:'phil',label:'Ancient Greek Philosophy',
desc:'Pre-socratics, Plato\'s dialogues, Aristotle\'s metaphysics. The 800-year ground floor of the West.',
pre:['aristotle_organon'],
books:[
  {t:'The Republic',a:'Plato',n:'Read after the shorter dialogues (Apology, Meno, Phaedo).',primary:true},
  {t:'Metaphysics & Nicomachean Ethics',a:'Aristotle',n:'Read with a guide. Hard.',primary:true},
  {t:'A History of Western Philosophy',a:'Bertrand Russell',n:'Bk. I — biased but readable.'},
  {t:'The Presocratic Philosophers',a:'G. S. Kirk, J. E. Raven, M. Schofield',n:'Standard fragment-collection with commentary.'},
]},

eastern_phil:{cat:'phil',label:'Eastern Philosophy',
desc:'Chinese (Confucius, Laozi, Zhuangzi), Indian (Upanishads, Buddhist Madhyamaka), classical Japanese. Intentionally unparalleled by Greek thought.',
pre:[],
books:[
  {t:'道德經 (Dao De Jing / Tao Te Ching)',a:'Lao Tzu (老子)',n:'Read D. C. Lau or Robert Henricks translation.',primary:true},
  {t:'論語 (Analects)',a:'Confucius (孔子)',n:'D. C. Lau or Edward Slingerland translation.',primary:true},
  {t:'Mūlamadhyamakakārikā',a:'Nāgārjuna (नागार्जुन, c. 150 CE)',n:'Foundation of Mahāyāna Buddhist philosophy. Garfield translation.',primary:true},
  {t:'The Principal Upaniṣads',a:'ed. & tr. S. Radhakrishnan',n:'Hindu philosophical canon.'},
  {t:'A Source Book in Indian Philosophy',a:'Radhakrishnan & C. A. Moore',n:'Survey anthology.'},
]},

medieval_phil:{cat:'phil',label:'Medieval Philosophy',
desc:'Christian, Jewish and Islamic scholastic traditions. Augustine, Aquinas, Avicenna, Averroes, Maimonides.',
pre:['ancient_phil'],
books:[
  {t:'Summa Theologiae (selections)',a:'Thomas Aquinas',n:'Use Pegis edition or McDermott\'s Concise Translation.',primary:true},
  {t:'The Book of Healing (selections)',a:'Avicenna (ابن سينا, Ibn Sīnā)',n:'Persian-Islamic scholastic.'},
  {t:'Guide for the Perplexed',a:'Maimonides (משה בן מימון)',n:'Jewish scholastic.'},
  {t:'Confessions',a:'Augustine of Hippo',n:'Latin Christian root.',primary:true},
]},

rationalism:{cat:'phil',label:'Continental Rationalism',
desc:'17th-c. systems built from clear-and-distinct ideas: Descartes, Spinoza, Leibniz.',
pre:['medieval_phil'],
books:[
  {t:'Meditations on First Philosophy',a:'René Descartes (1641)',n:'80 pages. Read with Objections and Replies.',primary:true},
  {t:'Ethics, Demonstrated in Geometrical Order',a:'Baruch Spinoza (1677)',n:'Hard. Worth a year. Use Curley translation.',primary:true},
  {t:'Monadology & Discourse on Metaphysics',a:'G. W. Leibniz',n:'Short. Read before secondary literature.',primary:true},
]},

empiricism:{cat:'phil',label:'British Empiricism',
desc:'17th–18th c. counterpart: knowledge from sensation. Locke, Berkeley, Hume.',
pre:['medieval_phil'],
books:[
  {t:'A Treatise of Human Nature',a:'David Hume (1739)',n:'The system. Or his Enquiry as a digest.',primary:true},
  {t:'An Essay Concerning Human Understanding',a:'John Locke (1689)',n:'The seminal text on empiricism.',primary:true},
  {t:'Three Dialogues Between Hylas and Philonous',a:'George Berkeley',n:'Idealism, beautifully written.'},
]},

ethics:{cat:'phil',label:'Ethics',
desc:'Virtue (Aristotle), deontology (Kant), utilitarianism (Mill, Bentham), modern metaethics.',
pre:['ancient_phil'],
books:[
  {t:'Nicomachean Ethics',a:'Aristotle',n:'Virtue ethics from the source.',primary:true},
  {t:'Groundwork of the Metaphysics of Morals',a:'Immanuel Kant (1785)',n:'Categorical imperative in 80 pages.',primary:true},
  {t:'Utilitarianism',a:'John Stuart Mill (1861)',n:'The classical defence.',primary:true},
]},

political_phil:{cat:'phil',label:'Political Philosophy',
desc:'Hobbes, Locke, Rousseau, Marx, Rawls. The basis of legitimacy of the state.',
pre:['ancient_phil','ethics'],
books:[
  {t:'Leviathan',a:'Thomas Hobbes (1651)',n:'The state of nature argument.',primary:true},
  {t:'The Social Contract',a:'Jean-Jacques Rousseau (1762)',n:'Foundation of modern political theory.',primary:true},
  {t:'Capital, Vol. I',a:'Karl Marx (1867)',n:'Critique of political economy.',primary:true},
  {t:'A Theory of Justice',a:'John Rawls (1971)',n:'20th-c. liberal canon.'},
]},

epistemology:{cat:'phil',label:'Epistemology',
desc:'What knowledge is, how it is justified, how to answer the skeptic. JTB tradition → Gettier (1963) → reliabilism, virtue epistemology, knowledge-first (Williamson), Bayesian/formal epistemology, social epistemology. Foundationalism vs. coherentism; internalism vs. externalism; a priori/a posteriori. The hinge of every other rigorous discipline — what licenses belief.',
pre:['ancient_phil','pred_logic'],
books:[
  {t:'Theaetetus',a:'Plato',n:'The original "what is knowledge?" dialogue. Read with Cornford or Burnyeat commentary.',primary:true},
  {t:'Meditations on First Philosophy',a:'René Descartes (1641)',n:'Foundationalism born here. The skeptic\'s gauntlet.',primary:true},
  {t:'An Enquiry Concerning Human Understanding',a:'David Hume (1748)',n:'The problem of induction. Empiricist skepticism at its sharpest.',primary:true},
  {t:'The Problems of Philosophy',a:'Bertrand Russell (1912)',n:'90 pages. Fastest rigorous entry into the modern picture.',primary:true},
  {t:'Is Justified True Belief Knowledge?',a:'Edmund Gettier (1963)',n:'Three pages that broke JTB. The inflection point of 20th-c. epistemology.',primary:true},
  {t:'What is Justified Belief?',a:'Alvin Goldman (1979)',n:'Reliabilism founded. The externalist turn.'},
  {t:'A Virtue Epistemology',a:'Ernest Sosa (2007)',n:'Animal vs. reflective knowledge; competence-based justification.'},
  {t:'Knowledge and Its Limits',a:'Timothy Williamson (2000)',n:'Knowledge-first programme. Knowledge as unanalyzable mental state.'},
  {t:'Probability Theory: The Logic of Science',a:'E. T. Jaynes (2003)',n:'Bayesian/formal epistemology. Probability as extended logic.',primary:true},
]},

kant:{cat:'phil',label:'Kant',
desc:'Critique of Pure Reason: synthesis of rationalism and empiricism. Phenomena/noumena, transcendental idealism, antinomies. THE pivot of modern philosophy.',
pre:['rationalism','empiricism','epistemology'],
books:[
  {t:'Critique of Pure Reason (1781/1787)',a:'Immanuel Kant',n:'Read Kemp Smith or Guyer & Wood translation. Plan a year.',primary:true},
  {t:'Critique of Practical Reason (1788)',a:'Immanuel Kant',n:'Ethics, sequel to KrV.',primary:true},
  {t:'Prolegomena to Any Future Metaphysics',a:'Immanuel Kant',n:'Self-summary of the first Critique. Start here.'},
]},

hegel:{cat:'phil',label:'Hegel',
desc:'Phenomenology of Spirit, Logic. Dialectical method. The most ambitious 19th-century system.',
pre:['kant'],
books:[
  {t:'Phenomenology of Spirit (1807)',a:'G. W. F. Hegel',n:'Notoriously hard. Pinkard translation. Use a guide (e.g. Stern).',primary:true},
  {t:'Science of Logic',a:'G. W. F. Hegel',n:'Hegel\'s "logical" system, post-Phenomenology.',primary:true},
]},

nietzsche:{cat:'phil',label:'Nietzsche',
desc:'Genealogy of morals, eternal recurrence, will to power. The hammer of 19th-c. metaphysics.',
pre:['kant'],
books:[
  {t:'Beyond Good and Evil',a:'Friedrich Nietzsche (1886)',n:'Most accessible mature work.',primary:true},
  {t:'On the Genealogy of Morals',a:'Friedrich Nietzsche (1887)',n:'Three essays. Tightest argument.',primary:true},
  {t:'Thus Spoke Zarathustra',a:'Friedrich Nietzsche',n:'Read after the others.'},
]},

phenomenology:{cat:'phil',label:'Phenomenology (Husserl)',
desc:'Intentionality, the epoché, lifeworld. The descriptive science of consciousness.',
pre:['kant'],
books:[
  {t:'Logical Investigations',a:'Edmund Husserl (1900–01)',n:'Two volumes. The foundational text.',primary:true},
  {t:'Ideas I',a:'Edmund Husserl (1913)',n:'Phenomenological reduction at the source.',primary:true},
  {t:'Cartesian Meditations',a:'Edmund Husserl',n:'Late, condensed.'},
]},

continental:{cat:'phil',label:'20th-c. Continental',
desc:'Heidegger, Merleau-Ponty, Sartre, Foucault, Derrida.',
pre:['hegel','phenomenology','nietzsche'],
books:[
  {t:'Being and Time',a:'Martin Heidegger (1927)',n:'Macquarrie & Robinson or Stambaugh translation.',primary:true},
  {t:'Phenomenology of Perception',a:'Maurice Merleau-Ponty (1945)',n:'Embodied cognition\'s philosophical root.',primary:true},
  {t:'Discipline and Punish',a:'Michel Foucault (1975)',n:'Genealogy of modern power.'},
]},

analytic_phil:{cat:'phil',label:'Analytic Philosophy',
desc:'Frege–Russell–Wittgenstein–Carnap–Quine. Logic, language, meaning. The 20th-century Anglo tradition.',
pre:['pred_logic','kant'],
books:[
  {t:'Tractatus Logico-Philosophicus',a:'Ludwig Wittgenstein (1921)',n:'Numbered propositions. Read with Anscombe\'s introduction.',primary:true},
  {t:'Philosophical Investigations',a:'Ludwig Wittgenstein (1953)',n:'The later anti-Tractatus.',primary:true},
  {t:'From a Logical Point of View',a:'W. V. O. Quine',n:'"Two Dogmas of Empiricism" — required.'},
]},

phil_lang:{cat:'phil',label:'Philosophy of Language',
desc:'Sense vs. reference (Frege), rigid designators (Kripke), speech acts (Austin), implicature (Grice).',
pre:['analytic_phil'],
books:[
  {t:'Über Sinn und Bedeutung',a:'Gottlob Frege (1892)',n:'20 pages. Sense and reference founded here.',primary:true},
  {t:'Naming and Necessity',a:'Saul Kripke',n:'Modal logic applied to language.'},
  {t:'Studies in the Way of Words',a:'H. P. Grice',n:'Implicature.'},
]},

phil_science:{cat:'phil',label:'Philosophy of Science',
desc:'Falsifiability (Popper), paradigms (Kuhn), research programmes (Lakatos), realism vs. anti-realism.',
pre:['analytic_phil','empiricism','epistemology'],
books:[
  {t:'The Logic of Scientific Discovery',a:'Karl Popper (1934)',n:'Falsificationism founded.',primary:true},
  {t:'The Structure of Scientific Revolutions',a:'Thomas Kuhn (1962)',n:'Paradigms; the most-cited 20th-c. book.',primary:true},
  {t:'Proofs and Refutations',a:'Imre Lakatos',n:'Mathematics as discovery, in dialogue form.'},
]},

phil_mind:{cat:'phil',label:'Philosophy of Mind',
desc:'Mind-body, qualia, intentionality, functionalism, the hard problem, Chinese Room.',
pre:['analytic_phil','kant','epistemology'],
books:[
  {t:'The Conscious Mind',a:'David Chalmers (1996)',n:'The hard-problem statement.',primary:true},
  {t:'Consciousness Explained',a:'Daniel Dennett (1991)',n:'The functionalist riposte.'},
  {t:'Materialism and the Mind-Body Problem',a:'ed. David M. Rosenthal',n:'Anthology of canonical papers.'},
]},

// ─── LINGUISTICS ───────────────────────────────────────────────────
panini:{cat:'ling',label:'Pāṇinian Grammar',
desc:'Aṣṭādhyāyī (~5th c. BCE): the world\'s first generative grammar. ~4000 sūtras describing Sanskrit. Predates Western linguistics by 2300 years.',
pre:[],
books:[
  {t:'Aṣṭādhyāyī (अष्टाध्यायी)',a:'Pāṇini (c. 4th c. BCE)',n:'Read Sumitra M. Katre\'s translation.',primary:true},
  {t:'Pāṇini: His Work and Its Traditions',a:'George Cardona',n:'The standard scholarly key.'},
  {t:'The Aṣṭādhyāyī of Pāṇini',a:'Rama Nath Sharma',n:'6-volume annotated translation.'},
]},

saussure:{cat:'ling',label:'Structural Linguistics (Saussure)',
desc:'Signifier/signified, langue/parole, synchronic vs diachronic. The 1916 birth of modern linguistics.',
pre:[],
books:[
  {t:'Cours de linguistique générale (1916)',a:'Ferdinand de Saussure',n:'Posthumously assembled lecture notes. Harris translation.',primary:true},
  {t:'Course in General Linguistics: notes from the 3rd course',a:'ed. Eisuke Komatsu, tr. Roy Harris',n:'Closer to the actual lectures.'},
]},

phonetics:{cat:'ling',label:'Phonetics',
desc:'Articulatory, acoustic, auditory phonetics. The IPA. The physical substrate of speech.',
pre:[],
books:[
  {t:'A Course in Phonetics',a:'Peter Ladefoged & Keith Johnson',n:'The standard introductory text. Audio supplement.',primary:true},
  {t:'The Sounds of the World\'s Languages',a:'Ladefoged & Maddieson',n:'Cross-linguistic phonetic data.'},
  {t:'Vowels and Consonants',a:'Peter Ladefoged',n:'Gentler than Course.'},
]},

phonology:{cat:'ling',label:'Phonology',
desc:'Phonemes, distinctive features, autosegmental phonology, optimality theory. The cognitive sound system.',
pre:['phonetics','saussure'],
books:[
  {t:'Grundzüge der Phonologie (1939)',a:'N. S. Trubetzkoy',n:'Prague-school founding text. Russian–European structuralism.',primary:true},
  {t:'Introductory Phonology',a:'Bruce Hayes',n:'Modern textbook standard.',primary:true},
  {t:'The Sound Pattern of English',a:'N. Chomsky & M. Halle (SPE, 1968)',n:'Generative phonology, formative.'},
]},

morphology:{cat:'ling',label:'Morphology',
desc:'Word structure: morphemes, affixation, compounding, paradigms. Word-formation across languages.',
pre:['phonology','panini'],
books:[
  {t:'Morphological Theory',a:'Andrew Spencer',n:'Comprehensive overview.',primary:true},
  {t:'What is Morphology?',a:'Mark Aronoff & Kirsten Fudeman',n:'Best one-semester intro.'},
  {t:'Morphology',a:'P. H. Matthews',n:'Cambridge classical statement.'},
]},

syntax:{cat:'ling',label:'Syntax',
desc:'Phrase structure, X-bar, movement, government and binding, minimalism. The grammatical architecture.',
pre:['morphology','panini','pred_logic'],
books:[
  {t:'Aspects of the Theory of Syntax',a:'Noam Chomsky (1965)',n:'Generative grammar founded here.',primary:true},
  {t:'Syntax: A Generative Introduction',a:'Andrew Carnie',n:'Best textbook entry.',primary:true},
  {t:'Lectures on Government and Binding',a:'Noam Chomsky (1981)',n:'GB theory at the source.'},
]},

semantics:{cat:'ling',label:'Formal Semantics',
desc:'Truth conditions, λ-calculus for natural language, types, quantifier scope, intensionality.',
pre:['syntax','pred_logic','phil_lang'],
books:[
  {t:'Semantics in Generative Grammar',a:'Irene Heim & Angelika Kratzer',n:'The standard textbook.',primary:true},
  {t:'The Proper Treatment of Quantification in Ordinary English',a:'Richard Montague (1973)',n:'Foundational paper.'},
  {t:'Introduction to Montague Semantics',a:'D. R. Dowty, R. E. Wall, S. Peters',n:'Tutorial classic.'},
]},

pragmatics:{cat:'ling',label:'Pragmatics',
desc:'Speech acts, presupposition, conversational implicature, deixis, politeness.',
pre:['syntax','phil_lang'],
books:[
  {t:'Pragmatics',a:'Stephen C. Levinson',n:'Cambridge textbook standard.',primary:true},
  {t:'Logic and Conversation',a:'H. P. Grice (1975)',n:'The founding paper. ~25 pages.',primary:true},
  {t:'Relevance: Communication and Cognition',a:'D. Sperber & D. Wilson',n:'Modern alternative framework.'},
]},

historical_ling:{cat:'ling',label:'Historical Linguistics',
desc:'Sound change, the comparative method, Indo-European reconstruction, grammaticalisation.',
pre:['phonology','morphology'],
books:[
  {t:'Language History, Language Change, and Language Relationship',a:'Hans Henrich Hock & Brian D. Joseph',n:'The standard.',primary:true},
  {t:'Indo-European Language and Culture',a:'Benjamin W. Fortson IV',n:'Best PIE/IE survey.'},
  {t:'Sound Change',a:'Joseph Salmons',n:'Modern phonological-change reference.'},
]},

typology:{cat:'ling',label:'Linguistic Typology',
desc:'Cross-linguistic variation in word order, morphology, alignment. Universals.',
pre:['syntax','morphology'],
books:[
  {t:'Typology and Universals',a:'William Croft',n:'The standard textbook.',primary:true},
  {t:'Describing Morphosyntax',a:'Thomas E. Payne',n:'Field-grammar handbook.'},
]},

// ─── COMPUTER SCIENCE ──────────────────────────────────────────────
sicp:{cat:'cs',label:'Programming as Discipline (SICP)',
desc:'Abstraction, recursion, higher-order functions, interpreters, register machines. Built bottom-up in Scheme.',
pre:[],
books:[
  {t:'Structure and Interpretation of Computer Programs',a:'H. Abelson & G. J. Sussman with J. Sussman',n:'MIT 6.001. The single best CS-philosophy book.',primary:true},
  {t:'The Little Schemer',a:'D. P. Friedman & M. Felleisen',n:'Recursive thinking, taught by induction.'},
  {t:'Concepts, Techniques, and Models of Computer Programming',a:'P. Van Roy & S. Haridi',n:'CTM. SICP\'s intellectual descendant.'},
]},

data_struct:{cat:'cs',label:'Data Structures',
desc:'Arrays, lists, trees, hash tables, heaps, balanced search trees, persistent structures, amortised analysis.',
pre:['discrete_math','sicp'],
books:[
  {t:'The Design and Analysis of Computer Algorithms',a:'A. Aho, J. Hopcroft, J. Ullman (1974)',n:'Original integration of structures and analysis.',primary:true},
  {t:'Purely Functional Data Structures',a:'Chris Okasaki',n:'Functional perspective.'},
  {t:'The Art of Computer Programming, Vol. 1',a:'Donald Knuth',n:'Foundational, exhaustive.'},
]},

algorithms:{cat:'cs',label:'Algorithms',
desc:'Correctness, asymptotic analysis, divide-and-conquer, dynamic programming, graph algorithms, NP-hardness.',
pre:['data_struct','discrete_math'],
books:[
  {t:'Introduction to Algorithms (CLRS)',a:'T. H. Cormen, C. E. Leiserson, R. L. Rivest, C. Stein',n:'The reference. Read parts I–VI.',primary:true},
  {t:'The Art of Computer Programming, Vols. 1–4A',a:'Donald Knuth',n:'TAOCP. Read what your interest demands.',primary:true},
  {t:'Algorithm Design',a:'J. Kleinberg & É. Tardos',n:'Stronger pedagogy than CLRS.'},
]},

formal_lang:{cat:'cs',label:'Formal Languages & Automata',
desc:'Regular and context-free languages, pushdown automata, Chomsky hierarchy, parsing theory.',
pre:['discrete_math','pred_logic'],
books:[
  {t:'Introduction to Automata Theory, Languages, and Computation',a:'Hopcroft, Motwani & Ullman',n:'The standard.',primary:true},
  {t:'Introduction to the Theory of Computation',a:'Michael Sipser',n:'More elegant. Read both parts I and II here as well as in computability.'},
]},

computability:{cat:'cs',label:'Computability',
desc:'Turing machines, Church–Turing thesis, halting problem, recursion theorem, μ-recursive functions.',
pre:['formal_lang','pred_logic'],
books:[
  {t:'Introduction to the Theory of Computation',a:'Michael Sipser',n:'The standard. Part III.',primary:true},
  {t:'Computability and Logic',a:'G. Boolos, J. Burgess, R. Jeffrey',n:'Logical-foundations slant.'},
  {t:'On Computable Numbers',a:'Alan Turing (1936)',n:'The original 36-page paper.',primary:true},
]},

complexity:{cat:'cs',label:'Computational Complexity',
desc:'P, NP, polynomial hierarchy, space complexity, randomised classes, interactive proofs, PCP.',
pre:['computability','algorithms'],
books:[
  {t:'Computational Complexity: A Modern Approach',a:'Sanjeev Arora & Boaz Barak',n:'The graduate standard.',primary:true},
  {t:'Computational Complexity',a:'C. H. Papadimitriou',n:'Older but extremely tight.'},
]},

type_theory:{cat:'cs',label:'Type Theory & PL',
desc:'Simply-typed λ-calculus, polymorphism, dependent types, Curry-Howard. The mathematics of programming languages.',
pre:['pred_logic','sicp'],
books:[
  {t:'Types and Programming Languages (TAPL)',a:'Benjamin C. Pierce',n:'The standard.',primary:true},
  {t:'Programming Language Pragmatics',a:'Michael L. Scott',n:'Engineering counterpart.'},
  {t:'Per Martin-Löf: Intuitionistic Type Theory',a:'Notes by Giovanni Sambin (1980)',n:'Source of dependent type theory.',primary:true},
]},

compilers:{cat:'cs',label:'Compilers',
desc:'Lexing, parsing, IR, type checking, optimisation, code generation. From source to silicon.',
pre:['algorithms','type_theory','formal_lang'],
books:[
  {t:'Compilers: Principles, Techniques and Tools (Dragon Book)',a:'A. V. Aho, M. S. Lam, R. Sethi, J. D. Ullman',n:'The standard reference.',primary:true},
  {t:'Engineering a Compiler',a:'K. D. Cooper & L. Torczon',n:'Modern alternative.'},
  {t:'Modern Compiler Implementation in ML',a:'Andrew W. Appel',n:'Cleanest pedagogy.'},
]},

comp_arch:{cat:'cs',label:'Computer Architecture',
desc:'ISA, pipelining, caches, memory hierarchy, parallelism, GPUs.',
pre:['digital_logic'],
books:[
  {t:'Computer Architecture: A Quantitative Approach',a:'J. L. Hennessy & D. A. Patterson',n:'The graduate-level reference.',primary:true},
  {t:'Computer Organization and Design',a:'Patterson & Hennessy',n:'Undergraduate version.'},
]},

os:{cat:'cs',label:'Operating Systems',
desc:'Processes, threads, scheduling, virtual memory, file systems, synchronisation, virtualisation.',
pre:['comp_arch','algorithms','data_struct'],
books:[
  {t:'Modern Operating Systems',a:'Andrew S. Tanenbaum',n:'The textbook standard.',primary:true},
  {t:'Operating Systems: Three Easy Pieces',a:'Arpaci-Dusseau & Arpaci-Dusseau',n:'Free, modern, brilliantly written.',primary:true},
  {t:'The Design and Implementation of the FreeBSD Operating System',a:'McKusick et al.',n:'For the deeper systems-y types.'},
]},

networks:{cat:'cs',label:'Computer Networks',
desc:'OSI/TCP-IP layers, routing, congestion control, transport, application layer.',
pre:['os','algorithms'],
books:[
  {t:'Computer Networks',a:'Andrew S. Tanenbaum & D. J. Wetherall',n:'Bottom-up classic.',primary:true},
  {t:'Computer Networking: A Top-Down Approach',a:'J. F. Kurose & K. W. Ross',n:'Top-down counterpart.'},
]},

databases:{cat:'cs',label:'Databases',
desc:'Relational model, SQL, transactions/ACID, indexing, query optimisation, distributed DBs.',
pre:['data_struct','algorithms'],
books:[
  {t:'Database Systems: The Complete Book',a:'H. Garcia-Molina, J. D. Ullman, J. Widom',n:'The reference.',primary:true},
  {t:'An Introduction to Database Systems',a:'C. J. Date',n:'Codd-relational tradition, philosophical.'},
  {t:'Readings in Database Systems',a:'ed. Bailis, Hellerstein, Stonebraker',n:'The "Red Book". Free online.'},
]},

distributed_sys:{cat:'cs',label:'Distributed Systems',
desc:'Consensus, replication, CAP, time and order (Lamport), fault tolerance, Paxos/Raft.',
pre:['networks','os'],
books:[
  {t:'Distributed Algorithms',a:'Nancy A. Lynch',n:'The mathematical reference.',primary:true},
  {t:'Designing Data-Intensive Applications',a:'Martin Kleppmann',n:'Engineering side, beautifully done.'},
  {t:'Time, Clocks, and the Ordering of Events',a:'Leslie Lamport (1978)',n:'Foundational paper.',primary:true},
]},

cryptography:{cat:'cs',label:'Cryptography',
desc:'Provable security, symmetric/asymmetric, hash functions, zero-knowledge, lattice crypto.',
pre:['probability','complexity','elem_number_theory'],
books:[
  {t:'Introduction to Modern Cryptography',a:'Jonathan Katz & Yehuda Lindell',n:'The provable-security textbook.',primary:true},
  {t:'Foundations of Cryptography (Vols. 1 & 2)',a:'Oded Goldreich',n:'The Israeli theorist\'s reference.'},
]},

// ─── AI (general) ──────────────────────────────────────────────────
