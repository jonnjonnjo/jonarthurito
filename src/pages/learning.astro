]},

morph_syntax:{tier:4,cat:'ling',label:'Morphology & Syntax',
desc:'Morphemes, allomorphs, word formation rules; X-bar theory, movement transformations (wh-, NP-movement), binding theory, control, Government & Binding, the Minimalist Program.',
figures:'Chomsky (Syntactic Structures, 1957 — generative grammar; Minimalist Program, 1995), Fillmore (case grammar), Bresnan (LFG)',
pre:['struct_ling','formal_sem','phonology'],
books:[
