],lec:[
  {t:'Boyd & Vandenberghe: Convex Optimization (free)',u:'https://web.stanford.edu/~boyd/cvxbook/',type:'book-free'},
  {t:'Stanford EE364a: Convex Optimization',u:'https://web.stanford.edu/class/ee364a/',type:'course'},
]},

