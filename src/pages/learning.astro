  {t:'Programming Embedded Systems in C and C++',a:'Michael Barr',n:'Bare-metal C. Clean and rigorous.'},
  {t:'Real-Time Systems',a:'Jane Liu',n:'Scheduling theory rigorously proved.',hard:true},
],lec:[
  {t:'ARM Architecture Reference Manual (free)',u:'https://developer.arm.com/documentation/',type:'book-free'},
  {t:'FreeRTOS documentation and book',u:'https://www.freertos.org/Documentation/RTOS_book.html',type:'book-free'},
  {t:'edX: Embedded Systems — UT Austin',u:'https://www.edx.org/learn/embedded-systems',type:'course'},
]},

