],lec:[
  {t:'MIT 18.102: Functional Analysis (OCW)',u:'https://ocw.mit.edu/courses/18-102-introduction-to-functional-analysis-spring-2021/',type:'course'},
]},

info_theory:{tier:5,cat:'cs',label:'Information Theory',
desc:'Shannon entropy, mutual information, channel capacity theorem (Shannon 1948), source coding theorem, channel coding theorem, rate-distortion theory, Kolmogorov complexity, minimum description length.',
figures:'Shannon (A Mathematical Theory of Communication, 1948 — the most important paper in information theory), Kolmogorov (complexity), Hamming (error-correcting codes), Huffman',
jonathan:'This is the mathematical foundation of compression, cryptography, and learning. Shannon\'s 1948 paper is 50 pages and completely self-contained.',
