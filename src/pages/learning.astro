von_neumann_deep:{tier:5,cat:'canon',label:'★ von Neumann: Full Contributions',
canon:true,
desc:'von Neumann algebras (factors, W*-algebras), spectral theory of unbounded operators, mathematical foundations of quantum mechanics (Hilbert space formalism), ergodic theorem, minimax theorem (game theory), stored-program architecture. The broadest mathematical mind of the 20th century.',
figures:'John von Neumann (1903–1957): set theory, QM foundations, game theory, operator algebras, computer architecture, cellular automata — all primary contributions.',
jonathan:'von Neumann built the computer you\'re using. His 1945 EDVAC report is upstream of every CPU. His mathematical physics is upstream of all quantum computing.',
pre:['functional_analysis','abstract_alg','prob_theory'],
books:[
  {t:'Mathematical Foundations of Quantum Mechanics',a:'John von Neumann (1932)',n:'Hilbert space formalism for QM. Rigorous. Primary source.',primary:true,soviet:true},
  {t:'Theory of Games and Economic Behavior',a:'von Neumann & Morgenstern (1944)',n:'Game theory invented and proved. Primary source.',primary:true,soviet:true},
  {t:'The Computer and the Brain',a:'John von Neumann (1958)',n:'His final lectures. Architecture of mind and machine.',primary:true},
