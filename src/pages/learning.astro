],lec:[
  {t:'MIT 6.341: Discrete-Time Signal Processing (OCW)',u:'https://ocw.mit.edu/courses/6-341-discrete-time-signal-processing-fall-2005/',type:'course'},
  {t:'Alan Oppenheim: DSP (MIT YouTube)',u:'https://www.youtube.com/playlist?list=PL8157CA8884571BA3',type:'video'},
]},

hardware_ml:{tier:5,cat:'hw',label:'Hardware for ML / Neuromorphic',
desc:'Systolic arrays (the engine inside TPUs), GPU/TPU architecture from silicon up, matrix-multiply units, memory bandwidth bottlenecks and roofline model, dataflow architectures, in-memory computing, neuromorphic chips (Intel Loihi, IBM TrueNorth), spiking neural networks on silicon. Homelab: implement a systolic array on FPGA.',
figures:'Kung (systolic arrays, 1978), Mead (neuromorphic computing, 1990), Dean (TPU architecture, 2016)',
