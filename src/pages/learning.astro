}; // ── END NODES ─────────────────────────────────────────────────────────

// ── LAYOUT ────────────────────────────────────────────────────────────────
const TIER_H=135, PAD_T=44, NW=92, NH=36, NR=4;

// Careful x-positions to avoid overlaps — tier by tier
const PX={
  // tier 0 (4 nodes)
  prop_logic:100, naive_set:340, proof:570, epistemology:920,
  // tier 1 (8 nodes)
  pred_logic:100, arithmetic_found:310, phil_lang:520, phil_sci:730,
  boolean_logic_hw:1200, signals_intro:1440,
  // (phil_sci continued) cog_sci pushed to tier 4 in layout
  // tier 2 (11 nodes)
  model_theory:55, axiomatic_set:200, cantor_deep:380, abstract_alg:560,
  real_analysis:750, combinatorics:940, struct_ling:1110, phil_mind:1290,
  computer_arch:1440, phonology:1600,
  // tier 3 (12 nodes)
  metalogic:55, hilbert_deep:215, type_theory:380, cat_theory:560,
  linear_alg:740, number_theory:920, graph_theory:1080, topology:1220,
  measure_theory:1360, formal_sem:1490, vlsi:1620,
  // tier 4 (11 nodes)
  computability:55, turing_deep:220, complexity:400, prob_theory:580,
  diff_geometry:760, morph_syntax:940, cog_sci:1110, calc_variations:1280,
  fourier_analysis:1440, os_systems:1590, embedded_sys:1720,
  // tier 5 (9 nodes)
  functional_analysis:55, info_theory:250, algorithms:440, convex_opt:640,
  algebraic_topology:840, von_neumann_deep:1040, dsp:1230, hardware_ml:1420,
  // tier 6 (12 nodes)
  temporal_logic:55, game_theory:215, logic_ai:390, knowledge_rep:570,
  ml_found:750, verification:930, nlp_found:1100, prob_graphical:1270,
  cellular_automata:1440, stat_sp:1600,
  // tier 7 (8 nodes)
  control_theory:55, deep_learning:260, tda:470, multi_agent:670,
  comp_ling:870, wavelets:1060,
  // tier 8 (4 nodes)
  reinforcement:150, neuro_symbolic:430, distributed_sys:720, compressed_sensing:1020,
  // tier 9 (1 node)
  general_ai:870,
};

function ny(t){return PAD_T+t*TIER_H;}
function gp(id){return{x:PX[id],y:ny(N[id].tier)};}

const SVGW=1850, SVGH=PAD_T+10*TIER_H+80;
const svg=document.getElementById('dag-svg');
svg.setAttribute('viewBox',`0 0 ${SVGW} ${SVGH}`);
svg.setAttribute('width',SVGW);
svg.setAttribute('height',SVGH);

// ── DEFS ──────────────────────────────────────────────────────────────────
const defs=document.createElementNS('http://www.w3.org/2000/svg','defs');
defs.innerHTML=`<marker id="ar" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="4" markerHeight="4" orient="auto-start-reverse">
  <path d="M2 2.5L8 5L2 7.5" fill="none" stroke="#1a1c2e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</marker>
<marker id="ar-canon" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="4" markerHeight="4" orient="auto-start-reverse">
  <path d="M2 2.5L8 5L2 7.5" fill="none" stroke="#7c6af5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</marker>`;
svg.appendChild(defs);

// Tier labels
const TL=['T0 · Bedrock','T1 · First Principles','T2 · Core Structures',
  'T3 · Formal Foundations','T4 · Advanced Theory','T5 · Applied Theory',
  'T6 · Synthesis I','T7 · Synthesis II','T8 · Frontier','T9 · General AI'];
for(let t=0;t<=9;t++){
  const txt=document.createElementNS('http://www.w3.org/2000/svg','text');
  txt.setAttribute('x',8);txt.setAttribute('y',ny(t)+4);
  txt.setAttribute('font-size','7');txt.setAttribute('fill','#1c1e2e');
  txt.setAttribute('font-family','IBM Plex Mono,monospace');
  txt.setAttribute('letter-spacing','0.12em');
  txt.textContent=TL[t];svg.appendChild(txt);
}

// Tier separator lines
for(let t=0;t<=9;t++){
  const line=document.createElementNS('http://www.w3.org/2000/svg','line');
  line.setAttribute('x1',0);line.setAttribute('y1',ny(t)-20);
  line.setAttribute('x2',SVGW);line.setAttribute('y2',ny(t)-20);
  line.setAttribute('stroke','#111320');line.setAttribute('stroke-width','0.5');
  svg.appendChild(line);
}

// ── EDGES ─────────────────────────────────────────────────────────────────
const EL=document.createElementNS('http://www.w3.org/2000/svg','g');
EL.id='el';svg.appendChild(EL);
for(const[id,node]of Object.entries(N)){
  for(const pre of (node.pre||[])){
    if(!N[pre])continue;
    const fp=gp(pre),tp=gp(id),td=node.tier-N[pre].tier;
    const isCanon=node.cat==='canon'||N[pre].cat==='canon';
    const path=document.createElementNS('http://www.w3.org/2000/svg','path');
    const cy1=fp.y+TIER_H*(td>1?0.58:0.45);
    const cy2=tp.y-TIER_H*(td>1?0.58:0.45);
    path.setAttribute('d',`M${fp.x},${fp.y+NH/2} C${fp.x},${cy1} ${tp.x},${cy2} ${tp.x},${tp.y-NH/2}`);
    path.setAttribute('fill','none');
    path.setAttribute('stroke',isCanon?'#7c6af522':'#181928');
    path.setAttribute('stroke-width',isCanon?'0.9':'0.65');
    path.setAttribute('marker-end',isCanon?'url(#ar-canon)':'url(#ar)');
    path.setAttribute('data-from',pre);path.setAttribute('data-to',id);
    path.classList.add('edge');EL.appendChild(path);
  }
}

// ── NODES ─────────────────────────────────────────────────────────────────
const NL=document.createElementNS('http://www.w3.org/2000/svg','g');
NL.id='nl';svg.appendChild(NL);
const nodeEls={};

for(const[id,node]of Object.entries(N)){
  const{x,y}=gp(id);
  const col=node.canon?C.canon:C[node.cat];
  const g=document.createElementNS('http://www.w3.org/2000/svg','g');
  g.setAttribute('transform',`translate(${x-NW/2},${y-NH/2})`);
  g.style.cursor='pointer';g.classList.add('ng');

  const rect=document.createElementNS('http://www.w3.org/2000/svg','rect');
  rect.setAttribute('width',NW);rect.setAttribute('height',NH);
  rect.setAttribute('rx',NR);rect.setAttribute('ry',NR);
  // Canon nodes get a special fill
  if(node.canon){
    rect.setAttribute('fill','#7c6af514');
    rect.setAttribute('stroke','#7c6af566');
    rect.setAttribute('stroke-width','1.2');
  } else {
    rect.setAttribute('fill',col+'10');
    rect.setAttribute('stroke',col+'40');
    rect.setAttribute('stroke-width','0.6');
  }
  g.appendChild(rect);

  // Start badge
  if(node.start){
    const badge=document.createElementNS('http://www.w3.org/2000/svg','text');
    badge.setAttribute('x',NW-3);badge.setAttribute('y',7);
    badge.setAttribute('text-anchor','end');badge.setAttribute('font-size','7');
    badge.setAttribute('fill','#34d39988');badge.setAttribute('font-family','IBM Plex Mono,monospace');
    badge.textContent='⚡';g.appendChild(badge);
  }
  if(node.canon){
    const star=document.createElementNS('http://www.w3.org/2000/svg','text');
    star.setAttribute('x',NW-3);star.setAttribute('y',7);
    star.setAttribute('text-anchor','end');star.setAttribute('font-size','7');
    star.setAttribute('fill','#7c6af5aa');star.setAttribute('font-family','IBM Plex Mono,monospace');
    star.textContent='★';g.appendChild(star);
  }

  const words=node.label.replace(/★\s*/,'').split(' ');
  const maxW=2;
  const lines=[];
  for(let i=0;i<words.length;i+=maxW){lines.push(words.slice(i,i+maxW).join(' '));}
  const lcount=Math.min(lines.length,2);
  lines.slice(0,lcount).forEach((ln,i)=>{
    const t=document.createElementNS('http://www.w3.org/2000/svg','text');
    t.setAttribute('x',NW/2);
    t.setAttribute('y',NH/2-(lcount-1)*5.5+i*11+3);
    t.setAttribute('text-anchor','middle');
    t.setAttribute('font-size',lcount>1?'7.2':'8.2');
    t.setAttribute('font-weight','500');
    t.setAttribute('font-family','EB Garamond,Georgia,serif');
    t.setAttribute('fill',node.canon?'#a78bfa':col);
    t.setAttribute('pointer-events','none');
    t.textContent=ln;g.appendChild(t);
  });

  NL.appendChild(g);nodeEls[id]={g,rect,col,canon:node.canon};
  g.addEventListener('mouseenter',e=>{doHover(id);showTip(e,node);});
  g.addEventListener('mouseleave',()=>{clearHover();hideTip();});
  g.addEventListener('mousemove',moveTip);
  g.addEventListener('click',()=>handleClick(id));
}

// ── HIGHLIGHT STATE ───────────────────────────────────────────────────────
let filterCat='all',lockedId=null;

function applyHighlight(id){
  const node=N[id];
  const pre=new Set(node.pre||[]);
  const unl=new Set(Object.entries(N).filter(([k,v])=>(v.pre||[]).includes(id)).map(([k])=>k));
  for(const[nid,{g,rect,col,canon}]of Object.entries(nodeEls)){
    const isA=nid===id,isP=pre.has(nid),isU=unl.has(nid),dim=!isA&&!isP&&!isU;
    g.style.opacity=dim?'0.06':'1';
    if(isA){
      rect.setAttribute('stroke',canon?'#a78bfa':col);
      rect.setAttribute('stroke-width','2.4');
    } else if(isP){
      rect.setAttribute('stroke','#fb923c');
      rect.setAttribute('stroke-width','1.6');
    } else if(isU){
      rect.setAttribute('stroke',canon?'#a78bfa':col);
      rect.setAttribute('stroke-width','1.2');
    } else {
      rect.setAttribute('stroke',(canon?'#7c6af566':col+'40'));
      rect.setAttribute('stroke-width',canon?'1.2':'0.6');
    }
  }
  svg.querySelectorAll('.edge').forEach(el=>{
    const f=el.dataset.from,t=el.dataset.to,rel=f===id||t===id;
    el.style.opacity=rel?'1':'0.015';
    if(t===id){el.setAttribute('stroke','#fb923c');el.setAttribute('stroke-width','1.8');}
    else if(f===id){el.setAttribute('stroke',C[N[t]?.cat]||'#666');el.setAttribute('stroke-width','1.6');}
    else{el.setAttribute('stroke','#181928');el.setAttribute('stroke-width','0.65');}
  });
}

function clearHighlight(){
  for(const[nid,{g,rect,col,canon}]of Object.entries(nodeEls)){
    const vis=filterCat==='all'||(filterCat==='canon'&&N[nid].canon)||N[nid].cat===filterCat;
    g.style.opacity=vis?'1':'0.05';
    rect.setAttribute('stroke',canon?'#7c6af566':col+'40');
    rect.setAttribute('stroke-width',canon?'1.2':'0.6');
  }
  svg.querySelectorAll('.edge').forEach(el=>{
    el.style.opacity=filterCat==='all'?'0.6':'0.02';
    el.setAttribute('stroke','#181928');el.setAttribute('stroke-width','0.65');
  });
}

function doHover(id){if(lockedId===null||lockedId===id)applyHighlight(id);}
function clearHover(){if(lockedId!==null)applyHighlight(lockedId);else clearHighlight();}
function handleClick(id){
  if(lockedId===id){lockedId=null;clearHighlight();closePanel();}
  else{lockedId=id;applyHighlight(id);openPanel(id);}
}

document.querySelectorAll('.fb').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.fb').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');filterCat=btn.dataset.cat;
    if(lockedId)applyHighlight(lockedId);else clearHighlight();
  });
});

// ── TOOLTIP ───────────────────────────────────────────────────────────────
const tip=document.getElementById('tip');
function showTip(e,node){
  const pn=(node.pre||[]).map(p=>N[p]?.label||p).join(', ')||'Root — start here';
  tip.innerHTML=`<b style="color:#dedad2">${node.label}</b><br>${pn}`;
  tip.style.display='block';moveTip(e);
}
function moveTip(e){tip.style.left=(e.clientX+14)+'px';tip.style.top=(e.clientY-40)+'px';}
function hideTip(){tip.style.display='none';}

// ── PANEL ─────────────────────────────────────────────────────────────────
const panel=document.getElementById('panel');
function openPanel(id){
  const node=N[id];const col=node.canon?'#a78bfa':C[node.cat];
  const canBadge=document.getElementById('pcanon');
  if(node.canon){canBadge.style.display='block';canBadge.innerHTML='<div class="canon-badge">★ CANON FIGURE NODE</div>';}
  else canBadge.style.display='none';
  document.getElementById('pcat').textContent=(CAT_NAME[node.cat]||node.cat).toUpperCase();
  document.getElementById('pcat').style.color=col;
  document.getElementById('ptit').textContent=node.label.replace(/^★\s*/,'');
  document.getElementById('pdsc').textContent=node.desc;
  const figEl=document.getElementById('pfig');
  if(node.figures){figEl.style.display='block';figEl.innerHTML=`<b>Key figures:</b> ${node.figures}`;}
  else figEl.style.display='none';
  const whyEl=document.getElementById('pwhy');
  if(node.jonathan){whyEl.style.display='block';whyEl.innerHTML=`<b style="color:#7c6af5">⚡ Why you specifically:</b> ${node.jonathan}`;}
  else whyEl.style.display='none';
  const preEl=document.getElementById('ppre');
  preEl.innerHTML=(node.pre||[]).length===0
    ?'<span style="font-size:10px;color:var(--t3)">None — root node. Start here immediately.</span>'
    :(node.pre||[]).map(p=>{const pn=N[p];const pc=pn?.canon?'#7c6af5':C[pn?.cat]||'#888';
       return`<span class="ptg" style="border-color:${pc}44;color:${pc}" onclick="handleClick('${p}')">${pn?.label?.replace(/^★\s*/,'')||p} ↗</span>`;}).join('');
  document.getElementById('pbooks').innerHTML=(node.books||[]).map(b=>`<div class="bk">
    <div class="btit">${b.primary?'<span style="color:#7c6af5;margin-right:3px">★</span>':''}${b.t}</div>
    <div class="baut">${b.a}</div>
    ${b.n?`<div class="${b.hard?'bnot bhard':'bnot'}">${b.hard?'⚠ Hard: ':''} ${b.n}</div>`:''}
  </div>`).join('');
  const lecEl=document.getElementById('plecs');
  const llbl=document.getElementById('llbl');
  if(node.lec&&node.lec.length>0){
    llbl.style.display='block';
    lecEl.innerHTML=node.lec.map(l=>`<div class="lk"><div class="ltype">${TLAB[l.type]||l.type}</div><a href="${l.u}" target="_blank" rel="noopener">${l.t}</a></div>`).join('');
  }else{llbl.style.display='none';lecEl.innerHTML='';}
  panel.classList.add('open');
}
function closePanel(){panel.classList.remove('open');lockedId=null;clearHighlight();}
</script>
</body>
</html>
