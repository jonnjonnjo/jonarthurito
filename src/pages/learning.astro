]},

dsp:{tier:5,cat:'sig',label:'Digital Signal Processing',
desc:'DTFT, DFT, FFT (Cooley-Tukey algorithm, split-radix), FIR/IIR filter design (windowing, bilinear transform, Parks-McClellan algorithm), Nyquist-Shannon sampling theorem, quantisation noise, multirate signal processing.',
figures:'Nyquist (1928), Shannon (sampling theorem, 1949), Cooley & Tukey (FFT, 1965), Parks & McClellan (filter design)',
pre:['fourier_analysis','signals_intro','prob_theory'],
books:[
  {t:'Discrete-Time Signal Processing',a:'Oppenheim & Schafer',n:'The definitive graduate text. Work every problem.',hard:true},
