algorithms:{tier:5,cat:'cs',label:'Algorithms & Data Structures (Rigorous)',
desc:'Divide-and-conquer with recurrence analysis, DP (Bellman optimality equations), greedy algorithms with exchange arguments, graph algorithms (Dijkstra correctness, max-flow min-cut), amortized analysis, randomised algorithms (Las Vegas/Monte Carlo), algebraic algorithms (FFT), lower bounds via adversary arguments.',
figures:'Euclid (GCD — the oldest algorithm), Dijkstra (shortest paths, 1959), Bellman (DP, 1957), Knuth (TAOCP), Strassen (matrix multiply, 1969), Cooley & Tukey (FFT, 1965)',
jonathan:'You already know these algorithms from ICPC. The upgrade here is writing formal proofs of correctness and tight lower bounds — the difference between a competitor and a theorist.',
pre:['complexity','graph_theory','linear_alg','prob_theory'],
books:[
  {t:'The Art of Computer Programming (vols. 1–4B)',a:'Donald Knuth',n:'Legendary. Every algorithm proved. Lifetime companion.',hard:true,primary:true},
  {t:'Introduction to Algorithms (CLRS)',a:'Cormen, Leiserson, Rivest & Stein',n:'The standard. Every algorithm with proof. You know this.'},
  {t:'Algorithm Design',a:'Kleinberg & Tardos',n:'Excellent proof emphasis throughout.'},
  {t:'Randomized Algorithms',a:'Motwani & Raghavan',n:'Probabilistic algorithms rigorously.',hard:true},
],lec:[
  {t:'MIT 6.046J: Design and Analysis of Algorithms (OCW)',u:'https://ocw.mit.edu/courses/6-046j-design-and-analysis-of-algorithms-spring-2015/',type:'course'},
  {t:'Dasgupta et al.: Algorithms (free PDF)',u:'https://people.eecs.berkeley.edu/~vazirani/algorithms/all.pdf',type:'book-free'},
]},

convex_opt:{tier:5,cat:'math',label:'Convex Analysis & Optimisation',
