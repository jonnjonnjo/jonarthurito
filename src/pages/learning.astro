  {t:'Probability',a:'A. N. Shiryaev',n:'Soviet. Full graduate measure-theoretic treatment. Encyclopedic.',soviet:true,hard:true},
  {t:'Probability and Measure',a:'Patrick Billingsley',n:'Western graduate standard.'},
],lec:[
  {t:'MIT 18.675: Theory of Probability (OCW)',u:'https://ocw.mit.edu/courses/18-675-theory-of-probability-fall-2009/',type:'course'},
]},

diff_geometry:{tier:4,cat:'math',label:'Differential Geometry',
desc:'Smooth manifolds, tangent/cotangent bundles, vector fields, differential forms, exterior algebra, de Rham cohomology, Riemannian metrics, geodesics, curvature tensors, Lie groups and algebras.',
