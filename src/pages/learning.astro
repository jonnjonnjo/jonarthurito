<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jonathan's Rigorous Learning DAG</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#06070a;--surf:#0a0b10;--surf2:#0e0f18;
  --b1:#181a28;--b2:#121420;
  --t1:#dedad2;--t2:#6e6c64;--t3:#2e2d2a;

  /* discipline colours */
  --phil:#c084fc;   /* violet */
  --math:#34d399;   /* emerald */
  --ling:#fb923c;   /* orange */
  --cs:#38bdf8;     /* sky */
  --ai:#facc15;     /* amber */
  --ctrl:#f472b6;   /* pink */
  --logic:#2dd4bf;  /* teal */
  --hw:#fb923c88;   /* orange-dim for hw */
  --sig:#818cf8;    /* indigo */
  --found:#94a3b8;  /* slate */
  --primary:#7c6af5; /* person's "canon" figures */

  --font:'EB Garamond',Georgia,serif;
  --mono:'IBM Plex Mono',monospace;
}
html,body{height:100%;background:var(--bg);color:var(--t1);font-family:var(--font);overflow:hidden}
#app{display:flex;flex-direction:column;height:100vh;width:100vw;position:fixed;top:0;left:0}

/* ── TOPBAR ── */
#topbar{display:flex;align-items:center;justify-content:space-between;padding:7px 14px;border-bottom:1px solid var(--b1);flex-shrink:0;gap:8px;flex-wrap:wrap;background:var(--surf)}
#topbar h1{font-family:var(--mono);font-size:9px;font-weight:400;color:var(--t3);letter-spacing:.18em;text-transform:uppercase;white-space:nowrap}
#legend{display:flex;gap:10px;flex-wrap:wrap}
.li{display:flex;align-items:center;gap:4px;font-size:8.5px;color:var(--t2);font-family:var(--mono)}
.ld{width:7px;height:7px;border-radius:1px;flex-shrink:0}

/* ── FILTERS ── */
#filters{display:flex;gap:3px;padding:5px 14px;border-bottom:1px solid var(--b1);flex-shrink:0;flex-wrap:wrap;background:var(--surf)}
.fb{font-size:8px;font-family:var(--mono);padding:2px 7px;border-radius:2px;border:1px solid var(--b1);background:transparent;color:var(--t3);cursor:pointer;transition:all .1s;letter-spacing:.07em;text-transform:uppercase}
.fb:hover{color:var(--t2)}
.fb.active{font-weight:500;color:#04050a!important;border-color:transparent!important}
.fb[data-cat="all"].active{background:var(--found)}
.fb[data-cat="found"].active{background:var(--found)}
.fb[data-cat="phil"].active{background:var(--phil)}
.fb[data-cat="math"].active{background:var(--math)}
.fb[data-cat="ling"].active{background:var(--ling)}
.fb[data-cat="cs"].active{background:var(--cs)}
.fb[data-cat="ai"].active{background:var(--ai)}
.fb[data-cat="ctrl"].active{background:var(--ctrl)}
.fb[data-cat="logic"].active{background:var(--logic)}
.fb[data-cat="hw"].active{background:#fb923c}
.fb[data-cat="sig"].active{background:var(--sig)}
.fb[data-cat="canon"].active{background:var(--primary)}

/* ── HINT ── */
#hint{font-family:var(--mono);font-size:7.5px;color:var(--t3);padding:3px 14px;border-bottom:1px solid var(--b1);background:var(--surf);flex-shrink:0;letter-spacing:.04em}
#hint b{color:var(--t2);font-weight:400}

/* ── MAIN ── */
#main{display:flex;flex:1;overflow:hidden}
#cw{flex:1;overflow:auto;position:relative;background:var(--bg)}
#dag-svg{display:block}

/* ── PANEL ── */
#panel{width:0;flex-shrink:0;overflow:hidden;border-left:1px solid var(--b1);transition:width .2s ease;background:var(--surf)}
#panel.open{width:360px;overflow-y:auto}
#pi{padding:16px;min-width:360px}
.pcl{float:right;font-size:16px;color:var(--t3);cursor:pointer;line-height:1;font-family:var(--mono)}
.pcl:hover{color:var(--t1)}
.pcat{font-family:var(--mono);font-size:8px;letter-spacing:.16em;text-transform:uppercase;margin-bottom:3px}
.ptit{font-size:15px;font-weight:500;margin-bottom:7px;line-height:1.3}
.pdsc{font-size:11.5px;color:var(--t2);line-height:1.85;margin-bottom:8px}
.pfig{font-size:10px;color:var(--t3);font-family:var(--mono);margin-bottom:8px;border-left:2px solid var(--b1);padding-left:8px;line-height:1.8}
.pfig b{color:var(--t2)}
.pwhy{font-size:10px;color:var(--primary);font-family:var(--mono);margin-bottom:8px;border-left:2px solid var(--primary)44;padding-left:8px;line-height:1.7}
.psec{font-family:var(--mono);font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:var(--t3);margin:12px 0 5px;padding-top:9px;border-top:1px solid var(--b1)}
.ptgs{display:flex;flex-wrap:wrap;gap:3px}
.ptg{font-size:8px;padding:2px 7px;border-radius:2px;border:1px solid var(--b1);color:var(--t2);cursor:pointer;font-family:var(--mono);transition:all .1s}
.ptg:hover{color:var(--t1)}
.bk{padding:6px 0;border-bottom:1px solid var(--b1)}
.bk:last-child{border-bottom:none}
.btit{font-size:11px;font-weight:500;line-height:1.4}
.baut{font-size:9.5px;color:var(--t2);margin-top:1px;font-family:var(--mono)}
.bnot{font-size:9px;color:var(--t3);margin-top:2px;line-height:1.6;font-style:italic}
.bhard{color:#f87171;font-style:normal;font-family:var(--mono);font-size:8.5px;letter-spacing:.04em}
.lk{padding:4px 0;border-bottom:1px solid var(--b1)}
.lk:last-child{border-bottom:none}
.lk a{font-size:10px;color:var(--cs);text-decoration:none;font-family:var(--mono);line-height:1.5;display:block}
.lk a:hover{text-decoration:underline}
.ltype{font-size:7.5px;color:var(--t3);font-family:var(--mono);margin-bottom:1px}
.canon-badge{display:inline-block;font-family:var(--mono);font-size:7.5px;background:var(--primary)22;color:var(--primary);border:1px solid var(--primary)44;border-radius:2px;padding:1px 6px;margin-bottom:6px;letter-spacing:.06em}

/* ── TOOLTIP ── */
#tip{position:fixed;pointer-events:none;background:var(--surf2);border:1px solid var(--b1);border-radius:3px;padding:5px 9px;font-size:9px;color:var(--t2);font-family:var(--mono);max-width:240px;display:none;z-index:200;line-height:1.7}

/* ── SCROLLBAR ── */
#cw::-webkit-scrollbar{width:5px;height:5px}
#cw::-webkit-scrollbar-track{background:var(--bg)}
#cw::-webkit-scrollbar-thumb{background:var(--b1);border-radius:3px}
#panel::-webkit-scrollbar{width:4px}
#panel::-webkit-scrollbar-track{background:var(--surf)}
#panel::-webkit-scrollbar-thumb{background:var(--b1);border-radius:3px}
</style>
</head>
<body>
<div id="app">
<div id="topbar">
  <h1>Jonathan · Rigorous Learning DAG · Phil · Math · Ling · CS · Logic · Control · Signal · HW · AI</h1>
  <div id="legend">
    <div class="li"><div class="ld" style="background:var(--found)"></div>Foundations</div>
    <div class="li"><div class="ld" style="background:var(--phil)"></div>Philosophy</div>
    <div class="li"><div class="ld" style="background:var(--math)"></div>Mathematics</div>
    <div class="li"><div class="ld" style="background:var(--ling)"></div>Linguistics</div>
    <div class="li"><div class="ld" style="background:var(--cs)"></div>CS Theory</div>
    <div class="li"><div class="ld" style="background:var(--logic)"></div>Logic/KR</div>
    <div class="li"><div class="ld" style="background:var(--ctrl)"></div>Control/RL</div>
    <div class="li"><div class="ld" style="background:var(--sig)"></div>Signal/DSP</div>
    <div class="li"><div class="ld" style="background:#fb923c"></div>Hardware</div>
    <div class="li"><div class="ld" style="background:var(--ai)"></div>AI</div>
    <div class="li"><div class="ld" style="background:var(--primary)"></div>Canon Figures</div>
  </div>
</div>
<div id="filters">
  <button class="fb active" data-cat="all">All</button>
  <button class="fb" data-cat="found">Foundations</button>
  <button class="fb" data-cat="phil">Philosophy</button>
  <button class="fb" data-cat="math">Mathematics</button>
  <button class="fb" data-cat="ling">Linguistics</button>
  <button class="fb" data-cat="cs">CS Theory</button>
  <button class="fb" data-cat="logic">Logic/KR</button>
  <button class="fb" data-cat="ctrl">Control/RL</button>
  <button class="fb" data-cat="sig">Signal/DSP</button>
  <button class="fb" data-cat="hw">Hardware</button>
  <button class="fb" data-cat="ai">AI</button>
  <button class="fb" data-cat="canon">★ Canon Figures</button>
</div>
<div id="hint">hover → preview deps &nbsp;·&nbsp; <b>click → lock + open detail</b> &nbsp;·&nbsp; click again or × to release &nbsp;·&nbsp; <b>★ = primary source / Soviet-European</b> &nbsp;·&nbsp; <b>⚡ = start here (Jonathan)</b></div>
<div id="main">
  <div id="cw"><svg id="dag-svg" xmlns="http://www.w3.org/2000/svg"></svg></div>
  <div id="panel"><div id="pi">
    <span class="pcl" onclick="closePanel()">×</span>
    <div id="pcanon" style="display:none"></div>
    <div class="pcat" id="pcat"></div>
    <div class="ptit" id="ptit"></div>
    <div class="pdsc" id="pdsc"></div>
    <div class="pfig" id="pfig" style="display:none"></div>
    <div class="pwhy" id="pwhy" style="display:none"></div>
    <div class="psec">Prerequisites</div>
    <div class="ptgs" id="ppre"></div>
    <div class="psec">Books <span style="color:#f87171;font-size:7px;font-family:var(--mono);margin-left:3px">★ = primary source / Soviet-European · red note = brutally hard</span></div>
    <div id="pbooks"></div>
    <div class="psec" id="llbl">Lectures / Courses / Resources</div>
    <div id="plecs"></div>
  </div></div>
</div>
<div id="tip"></div>
</div>
<script>
const C={
  found:'#94a3b8',phil:'#c084fc',math:'#34d399',ling:'#fb923c',
  cs:'#38bdf8',ai:'#facc15',ctrl:'#f472b6',logic:'#2dd4bf',
  hw:'#fb923c',sig:'#818cf8',canon:'#7c6af5'
};
const CAT_NAME={
  found:'Foundations',phil:'Philosophy',math:'Mathematics',ling:'Linguistics',
  cs:'CS Theory',logic:'Logic / KR',ctrl:'Control / RL',sig:'Signal / DSP',
  hw:'Hardware',ai:'AI (General)',canon:'Canon Figure'
};
const TLAB={course:'📚 Course',video:'🎬 Video','book-free':'📖 Free Book',notes:'📝 Notes',tool:'🔧 Tool',forum:'💬 Community',paper:'📄 Paper'};

// ═══════════════════════════════════════════════════════════════════
// NODE DATA
// tier 0-10, cat, label, desc, figures, pre[], books[], lec[]
// soviet:true → ★   hard:true → red note   canon:true → purple node
// jonathan:str → why Jonathan specifically should read this
// start:true → ⚡ (Jonathan can start here given his background)
// ═══════════════════════════════════════════════════════════════════
const N={

// ─── TIER 0 · ABSOLUTE BEDROCK ──────────────────────────────────────
prop_logic:{tier:0,cat:'found',label:'Propositional Logic',start:true,
desc:'Truth tables, connectives (∧∨¬→↔), tautologies, CNF/DNF, resolution, natural deduction. The floor of every formal discipline. Non-negotiable before anything else.',
figures:'Aristotle (syllogisms), Boole (algebra of logic, 1847), Frege (Begriffsschrift, 1879), Russell & Whitehead (Principia Mathematica, 1910)',
jonathan:'Your CP background means you intuit boolean logic. Now formalise it from scratch — proofs, not tricks.',
pre:[],
books:[
  {t:'Begriffsschrift',a:'Gottlob Frege (1879)',n:'12 pages that created modern logic. Read the primary source.',soviet:true,primary:true},
  {t:'Principles of Mathematical Logic',a:'Hilbert & Ackermann',n:'The 1928 textbook that shaped a generation. Rigorous and terse.',soviet:true},
  {t:'Introduction to Logic',a:'Patrick Suppes',n:'Axiomatic from page one. No hand-holding.',hard:true},
  {t:'Language, Proof and Logic',a:'Barwise & Etchemendy',n:'Software-enforced drill. Good for getting fast.'},
],lec:[
  {t:'forall x: Calgary (free PDF)',u:'https://forallx.openlogicproject.org/',type:'book-free'},
  {t:'Stanford Coursera: Introduction to Logic',u:'https://www.coursera.org/learn/logic-introduction',type:'course'},
]},

naive_set:{tier:0,cat:'found',label:'Naive Set Theory',start:true,
desc:'Sets, subsets, functions, relations, Cartesian products, cardinality, Cantor diagonalisation, power sets, Zorn\'s Lemma statement. The raw language of all mathematics.',
figures:'Cantor (1870s–1897), Dedekind (cuts, 1872), Frege (logicism). Start with Cantor himself.',
jonathan:'Before any proof-based math, you need this language absolutely cold. One week with Halmos.',
pre:[],
books:[
  {t:'Naive Set Theory',a:'Paul Halmos',n:'100 pages. Read in one week. The entry point.',soviet:false},
  {t:'Basic Set Theory',a:'A. Shen & N. K. Vereshchagin',n:'Soviet. Free online. Concise and fully rigorous.',soviet:true},
  {t:'Contributions to the Founding of the Theory of Transfinite Numbers',a:'Georg Cantor (1895–97)',n:'The primary source. Cantor building ordinals himself.',soviet:true,primary:true},
],lec:[
  {t:'Shen & Vereshchagin: Basic Set Theory (free)',u:'https://www.lmcs-online.org/',type:'book-free'},
]},

proof:{tier:0,cat:'found',label:'Mathematical Proof',start:true,
desc:'Direct proof, contradiction, contrapositive, strong induction, well-ordering principle, proof by cases. Writing mathematics, not just computing it.',
figures:'Euclid (Elements — the oldest proof tradition), Gauss (Disquisitiones Arithmeticae — rigour as a standard)',
jonathan:'Your ACM-ICPC level means you already think algorithmically. This channels that into mathematical argument. You will find it fast.',
pre:[],
books:[
  {t:'How to Prove It',a:'Daniel Velleman',n:'Best single bridge from CS-mind to math-mind.'},
  {t:'Problems in Mathematics',a:'V. V. Prasolov',n:'Soviet olympiad tradition — proof by doing, not by reading.',soviet:true},
  {t:'Book of Proof',a:'Richard Hammack',n:'Free online. Clear and honest.',},
],lec:[
  {t:'Hammack: Book of Proof (free)',u:'https://www.people.vcu.edu/~rhammack/BookOfProof/',type:'book-free'},
]},

epistemology:{tier:0,cat:'phil',label:'Epistemology',
desc:'Justified true belief, Gettier problem, foundationalism vs coherentism, a priori/a posteriori distinction, analytic/synthetic. The philosophical ground of all inquiry — what it even means to "know" something.',
figures:'Plato (Meno, Theaetetus), Descartes (Meditations), Hume (Enquiry), Kant (Critique), Russell (Problems)',
jonathan:'Philosophy is where your intuitions about algorithms and truth get stress-tested. Start here before phil of science.',
pre:[],
books:[
  {t:'The Problems of Philosophy',a:'Bertrand Russell (1912)',n:'90 pages. The fastest rigorous entry point.',primary:true},
  {t:'Theory of Knowledge',a:'Roderick Chisholm',n:'Classic analytic epistemology. Dense but tractable.'},
  {t:'Critique of Pure Reason',a:'Immanuel Kant',n:'The a priori/a posteriori distinction at its source. Extremely hard. Return to it.',hard:true,soviet:true,primary:true},
],lec:[
  {t:'SEP: Epistemology',u:'https://plato.stanford.edu/entries/epistemology/',type:'notes'},
  {t:'MIT 24.01: Classics of Western Philosophy (OCW)',u:'https://ocw.mit.edu/courses/24-01-classics-in-western-philosophy-spring-2006/',type:'course'},
]},

// ─── TIER 1 ────────────────────────────────────────────────────────
pred_logic:{tier:1,cat:'found',label:'Predicate Logic (FOL)',
desc:'Quantifiers ∀∃, terms, free/bound variables, interpretations, models, validity, prenex normal form, Skolemisation, unification. The formal language of all mathematics and CS theory.',
figures:'Frege (Begriffsschrift — quantification invented here), Peirce, Peano, Russell',
jonathan:'This is the language your complexity proofs and algorithm correctness arguments are implicitly written in. Make it explicit.',
pre:['prop_logic','proof','naive_set'],
books:[
  {t:'Mathematical Logic',a:'Yu. I. Manin',n:'Soviet. Logic from a deep mathematician\'s view. Superior to most Western texts.',soviet:true,hard:true},
  {t:'Introduction to Mathematical Logic',a:'Elliott Mendelson',n:'The axiomatic standard. Terse.'},
  {t:'A Mathematical Introduction to Logic',a:'Herbert Enderton',n:'Cleaner than Mendelson. Both are worth having.'},
  {t:'Logic and Structure',a:'Dirk van Dalen',n:'Proof theory + model theory in one volume.'},
],lec:[
  {t:'MIT 24.241: Logic I (OCW)',u:'https://ocw.mit.edu/courses/24-241-logic-i-fall-2009/',type:'course'},
]},

arithmetic_found:{tier:1,cat:'math',label:'Foundations of Arithmetic',
desc:'Peano axioms, recursive definitions over ℕ, construction of ℤ, ℚ, ℝ from scratch. What "2+2=4" means — built, not assumed. The meaning behind all computation.',
figures:'Peano (axioms, 1889), Dedekind (Was sind und was sollen die Zahlen, 1888), Frege (Grundlagen der Arithmetik, 1884)',
jonathan:'You have been computing on numbers for years. Now see what they actually are.',
pre:['proof','naive_set'],
books:[
  {t:'The Foundations of Arithmetic',a:'Gottlob Frege (1884)',n:'The logicist programme. Primary source.',soviet:true,primary:true},
  {t:'Was sind und was sollen die Zahlen?',a:'Richard Dedekind (1888)',n:'How ℕ is constructed. The primary source.',primary:true},
  {t:'What is Mathematics?',a:'Courant & Robbins',n:'Breadth + rigour. Einstein recommended it.'},
],lec:[]},

phil_lang:{tier:1,cat:'phil',label:'Philosophy of Language',
desc:'Sense vs reference (Frege), rigid designators (Kripke), speech acts (Austin/Searle), meaning as use (Wittgenstein), conversational implicature (Grice). What words mean and how they manage to mean it.',
figures:'Frege (Über Sinn und Bedeutung, 1892), Wittgenstein (Investigations), Austin, Grice, Kripke (Naming & Necessity)',
jonathan:'Directly upstream of formal semantics, NLP, and computational linguistics. Not optional if you want to understand language models at depth.',
pre:['prop_logic','epistemology'],
books:[
  {t:'Über Sinn und Bedeutung',a:'Gottlob Frege (1892)',n:'Sense and reference invented. 20 pages. Primary source.',soviet:true,primary:true},
  {t:'Naming and Necessity',a:'Saul Kripke',n:'Rigid designators. Modal logic applied to language. Foundational.',hard:true},
  {t:'Philosophical Investigations',a:'Ludwig Wittgenstein',n:'Meaning as use. Extremely hard. Do not skip.',hard:true,primary:true},
  {t:'Studies in the Way of Words',a:'H. P. Grice',n:'Implicature from the source.'},
],lec:[
  {t:'MIT 24.251: Philosophy of Language (OCW)',u:'https://ocw.mit.edu/courses/24-251-introduction-to-philosophy-of-language-fall-2011/',type:'course'},
]},

phil_sci:{tier:1,cat:'phil',label:'Philosophy of Science',
desc:'Scientific explanation, falsificationism (Popper), paradigm shifts (Kuhn), Lakatosian research programmes, reductionism, underdetermination, Bayesian confirmation theory.',
figures:'Popper (Logik der Forschung, 1934), Kuhn (Structure, 1962), Lakatos, Quine (Two Dogmas, 1951)',
jonathan:'Before you can build AI systems that "learn", understand what scientific learning even is. Popper is essential.',
pre:['epistemology','prop_logic'],
books:[
  {t:'The Logic of Scientific Discovery',a:'Karl Popper (1934/59)',n:'Falsificationism from the source. Terse and hard.',hard:true,primary:true},
  {t:'The Structure of Scientific Revolutions',a:'Thomas Kuhn',n:'Paradigm shifts. Foundational for understanding knowledge change.'},
  {t:'Two Dogmas of Empiricism',a:'W. V. O. Quine (1951)',n:'20-page paper that reshaped analytic philosophy. Free online.',primary:true},
],lec:[
  {t:'SEP: Philosophy of Science',u:'https://plato.stanford.edu/entries/scientific-explanation/',type:'notes'},
]},

boolean_logic_hw:{tier:1,cat:'hw',label:'Boolean Logic & Digital Circuits',start:true,
desc:'Boolean algebra (De Morgan, Shannon), logic gates, combinational logic (MUX, full adder, comparators), sequential logic (D flip-flop, state machines), Karnaugh maps, hazards. The hardware foundation — doable entirely from books and simulation.',
figures:'Boole (algebra, 1854), Shannon (switching circuits + entropy, 1937), De Morgan',
jonathan:'You already know coding. Hardware is the other side of the abstraction wall. Start here — all of this is simulatable on your laptop with Logisim/Digital.',
pre:['prop_logic','proof'],
books:[
  {t:'Digital Design and Computer Architecture: RISC-V',a:'Harris & Harris',n:'Best modern text. Builds from gates to CPU. Read every chapter.',hard:true},
  {t:'Digital Design',a:'Morris Mano & Michael Ciletti',n:'Standard. Good problems set.'},
  {t:'A Symbolic Analysis of Relay and Switching Circuits',a:'Claude Shannon (1938)',n:'Master\'s thesis that created digital circuit design. Primary source.',soviet:true,primary:true},
],lec:[
  {t:'Nand2Tetris: Build a Modern Computer from First Principles',u:'https://www.nand2tetris.org/',type:'course'},
  {t:'MIT 6.004: Computation Structures (OCW)',u:'https://ocw.mit.edu/courses/6-004-computation-structures-spring-2017/',type:'course'},
  {t:'Logisim-Evolution (free circuit simulator)',u:'https://github.com/logisim-evolution/logisim-evolution',type:'tool'},
]},

// ─── TIER 2 ────────────────────────────────────────────────────────
model_theory:{tier:2,cat:'found',label:'Model Theory',
desc:'Structures, satisfaction ⊨, Löwenheim-Skolem theorems, compactness theorem, ultraproducts, categoricity, elementary equivalence, quantifier elimination, types. The mathematics of formal languages.',
figures:'Löwenheim (1915), Skolem (1920), Tarski (1930s–50s, truth defined), Morley (categoricity, 1965)',
pre:['pred_logic','naive_set'],
books:[
  {t:'A Course in Mathematical Logic',a:'Yu. I. Manin',n:'Soviet masterpiece. Model theory from the ground up. Superior.',soviet:true,hard:true},
  {t:'Model Theory: An Introduction',a:'David Marker',n:'Clean modern treatment. Best Western entry.'},
  {t:'A Shorter Model Theory',a:'Wilfrid Hodges',n:'More accessible than Chang-Keisler.'},
],lec:[]},

axiomatic_set:{tier:2,cat:'math',label:'Axiomatic Set Theory (ZFC)',
desc:'ZFC axioms one by one, ordinal arithmetic, cardinal arithmetic, Axiom of Choice and its equivalents (Zorn, well-ordering), continuum hypothesis, introduction to forcing (Cohen 1963). This is where mathematics is grounded.',
figures:'Zermelo (1908), Fraenkel, von Neumann (ordinal numbers), Gödel (constructible sets, L, 1938), Cohen (forcing, 1963)',
pre:['pred_logic','naive_set','proof'],
books:[
  {t:'Set Theory',a:'Thomas Jech',n:'750-page definitive graduate reference. Encyclopedic.',hard:true},
  {t:'Basic Set Theory',a:'A. Shen & N. K. Vereshchagin',n:'Soviet. Concise and free online. Start here.',soviet:true},
  {t:'Set Theory: An Introduction to Independence Proofs',a:'Kenneth Kunen',n:'Forcing explained properly.',hard:true},
  {t:'Set Theory and the Continuum Hypothesis',a:'Paul Cohen (1966)',n:'Forcing from the discoverer. Primary source.',primary:true},
],lec:[]},

cantor_deep:{tier:2,cat:'canon',label:'★ Cantor: Transfinite Mathematics',
canon:true,
desc:'Cantor\'s transfinite numbers in full: ordinal and cardinal arithmetic, transfinite induction, the diagonal argument (ℝ uncountable), Cantor-Bernstein theorem, the continuum hypothesis, absolute infinity. The mathematics of the infinite, built from scratch by one man.',
figures:'Georg Cantor (1845–1918) — invented set theory and transfinite arithmetic against massive resistance. Arguably the single greatest solo mathematical creation of the 19th century.',
jonathan:'Cantor is upstream of computability (Gödel, Turing), information theory (Shannon), and all of formal mathematics. Understanding him is understanding the engine underneath CS.',
pre:['naive_set','arithmetic_found','proof'],
books:[
  {t:'Contributions to the Founding of the Theory of Transfinite Numbers',a:'Georg Cantor (1895)',n:'The primary source. Read Cantor himself.',soviet:true,primary:true},
  {t:'Set Theory and the Continuum Hypothesis',a:'Paul Cohen',n:'Independence of CH from the man who proved it.',primary:true},
  {t:'Georg Cantor: His Mathematics and Philosophy of the Infinite',a:'Joseph Dauben',n:'Historical and mathematical. Essential context.'},
],lec:[
  {t:'SEP: Cantor\'s Theorem',u:'https://plato.stanford.edu/entries/cantor/',type:'notes'},
]},

abstract_alg:{tier:2,cat:'math',label:'Abstract Algebra',
desc:'Groups (Lagrange, Sylow theorems), rings, ideals, fields, Galois theory (field extensions, solvability by radicals), modules, homomorphisms, quotient structures. The structural language of all mathematics.',
figures:'Galois (group theory, 1832 — died at 20), Noether (abstract algebra, 1920s), Artin, van der Waerden (Moderne Algebra, 1930)',
jonathan:'Galois theory directly connects to number theory, coding theory, and cryptography — your algorithms background makes this more accessible than it looks.',
pre:['proof','naive_set','pred_logic'],
books:[
  {t:'Course of Higher Algebra',a:'A. G. Kurosh',n:'Soviet classic. Groups through Galois theory. Very rigorous.',soviet:true,hard:true},
  {t:'Algebra',a:'A. I. Kostrikin & Yu. I. Manin',n:'Soviet. Rigorous from foundations. Two volumes.',soviet:true,hard:true},
  {t:'Algebra',a:'Michael Artin',n:'Best Western undergraduate text. Geometric throughout.'},
  {t:'Abstract Algebra',a:'Dummit & Foote',n:'Encyclopedic. Graduate standard. Use as reference.'},
],lec:[
  {t:'MIT 18.701: Algebra I (OCW)',u:'https://ocw.mit.edu/courses/18-701-algebra-i-fall-2021/',type:'course'},
]},

real_analysis:{tier:2,cat:'math',label:'Real Analysis',
desc:'ε-δ definitions, metric spaces, completeness, Cauchy sequences, continuity, uniform continuity, differentiation, Riemann integration, uniform convergence, Arzelà-Ascoli, Stone-Weierstrass. The first genuinely hard mathematics.',
figures:'Cauchy (rigor, 1820s), Weierstrass (ε-δ everywhere), Riemann (integration), Dedekind, Cantor (completeness of ℝ)',
jonathan:'Everything in ML theory, signal processing, and optimisation is downstream of real analysis. Do not skip it for Zorich — it is the best textbook in existence for self-study.',
pre:['pred_logic','proof','naive_set','arithmetic_found'],
books:[
  {t:'Mathematical Analysis (2 vols.)',a:'V. A. Zorich',n:'Soviet. The superior self-study text in existence. Do every problem.',soviet:true,hard:true},
  {t:'A Course of Mathematical Analysis (2 vols.)',a:'A. N. Kolmogorov & S. V. Fomin',n:'Soviet grandmasters. Concurrent reading.',soviet:true},
  {t:'Problems in Mathematical Analysis',a:'B. P. Demidovich',n:'Soviet. 3000 problems. The drill book.',soviet:true},
  {t:'Principles of Mathematical Analysis',a:'Walter Rudin',n:'Baby Rudin. Terse. Read after Zorich.'},
],lec:[
  {t:'Francis Su: Real Analysis (Harvey Mudd, YouTube)',u:'https://www.youtube.com/playlist?list=PL0E754696F72137EC',type:'video'},
  {t:'MIT 18.100A: Real Analysis (OCW)',u:'https://ocw.mit.edu/courses/18-100a-real-analysis-fall-2020/',type:'course'},
]},

combinatorics:{tier:2,cat:'math',label:'Combinatorics',
desc:'Permutations, combinations, inclusion-exclusion, pigeonhole principle, generating functions (Euler, Wilf), Ramsey theory, Stirling numbers, Pólya enumeration, probabilistic method.',
figures:'Euler (generating functions), Ramsey (Ramsey theory, 1930), Erdős (probabilistic method, 1947), MacMahon',
jonathan:'As an ICPC competitor you already know combinatorics computationally. Now do it with proofs and generating functions. Wilf is the book.',
pre:['proof','naive_set'],
books:[
  {t:'Combinatorics',a:'N. Ya. Vilenkin',n:'Soviet. Proof-heavy and elegant.',soviet:true},
  {t:'generatingfunctionology',a:'Herbert Wilf',n:'Free online. Generating functions done right. Essential.',},
  {t:'The Probabilistic Method',a:'Alon & Spencer',n:'Erdős\'s probabilistic method rigorously. Graduate level.',hard:true},
  {t:'A Walk Through Combinatorics',a:'Miklós Bóna',n:'Rigorous and clear. Good start.'},
],lec:[
  {t:'Wilf: generatingfunctionology (free PDF)',u:'https://www2.math.upenn.edu/~wilf/gfologyLinked2.pdf',type:'book-free'},
]},

struct_ling:{tier:2,cat:'ling',label:'Structural Linguistics',
desc:'The sign (signifier/signified), paradigmatic/syntagmatic relations, phoneme, morpheme, distributional analysis, the arbitrariness of the sign. Language treated as a formal system for the first time.',
figures:'Saussure (Cours de linguistique générale, 1916 — published posthumously), Bloomfield (Language, 1933), Jakobson, Harris',
pre:['phil_lang','epistemology'],
books:[
  {t:'Course in General Linguistics',a:'Ferdinand de Saussure (1916)',n:'The founding text. Non-negotiable.',primary:true,soviet:true},
  {t:'Language',a:'Leonard Bloomfield',n:'American structuralist canon. Very rigorous.'},
  {t:'Fundamentals of Language',a:'Roman Jakobson & Morris Halle',n:'Phonological features from the masters.'},
],lec:[]},

phil_mind:{tier:2,cat:'phil',label:'Philosophy of Mind',
desc:'Mind-body problem, dualism, functionalism, qualia, the hard problem of consciousness, intentionality, Chinese Room argument (Searle), the frame problem. What computation cannot explain about mind — and whether that matters.',
figures:'Descartes (dualism), Ryle (Concept of Mind, 1949), Searle (Chinese Room, 1980), Chalmers (hard problem, 1995), Fodor (LOT)',
jonathan:'The Chinese Room argument directly challenges claims about what LLMs "understand". You need this before serious AI theory.',
pre:['epistemology','phil_sci','phil_lang'],
books:[
  {t:'Intentionality',a:'John Searle',n:'Mental representation from first principles. Includes Chinese Room.',hard:true},
  {t:'The Conscious Mind',a:'David Chalmers',n:'The hard problem of consciousness stated precisely.'},
  {t:'The Language of Thought',a:'Jerry Fodor',n:'Mentalese and the representational theory of mind.'},
  {t:'The Concept of Mind',a:'Gilbert Ryle (1949)',n:'Systematic demolition of Cartesian dualism.',primary:true},
],lec:[
  {t:'MIT 24.09: Minds and Machines (OCW)',u:'https://ocw.mit.edu/courses/24-09-minds-and-machines-fall-2011/',type:'course'},
]},

computer_arch:{tier:2,cat:'hw',label:'Computer Architecture',
desc:'ISA design (RISC-V), pipelining, hazards, out-of-order execution (Tomasulo), caches (cache coherence, associativity), memory hierarchy, branch prediction, SIMD. Build a CPU you understand completely — simulatable in software.',
figures:'von Neumann (stored-program, 1945), Wilkes (EDSAC), Patterson & Hennessy (RISC revolution), Tomasulo (OOO, 1967)',
jonathan:'After Nand2Tetris you have an intuition. This is where it becomes rigorous. RISC-V is the right ISA to learn — open, clean, modern.',
pre:['boolean_logic_hw','prop_logic'],
books:[
  {t:'Computer Organization and Design: RISC-V Edition',a:'Patterson & Hennessy',n:'The standard. Every chapter matters.'},
  {t:'Digital Design and Computer Architecture: RISC-V',a:'Harris & Harris',n:'Build from gates to CPU. Better for self-study.'},
  {t:'Computer Architecture: A Quantitative Approach',a:'Hennessy & Patterson',n:'Graduate-level. The definitive reference.',hard:true},
  {t:'First Draft of a Report on the EDVAC',a:'John von Neumann (1945)',n:'The stored-program concept. 101 pages. Primary source.',primary:true,soviet:true},
],lec:[
  {t:'Nand2Tetris (Parts I and II)',u:'https://www.nand2tetris.org/',type:'course'},
  {t:'CS61C: Great Ideas in Computer Architecture (Berkeley)',u:'https://cs61c.org/',type:'course'},
  {t:'MIT 6.004: Computation Structures (OCW)',u:'https://ocw.mit.edu/courses/6-004-computation-structures-spring-2017/',type:'course'},
]},

signals_intro:{tier:2,cat:'sig',label:'Signals & Systems',
desc:'Continuous and discrete-time signals, LTI systems, convolution, impulse response, BIBO stability, Fourier series, differential equations as systems. The entry point to all signal processing.',
figures:'Fourier (heat equation & Fourier series, 1822), Heaviside (operational calculus), Dirac (δ function, 1927)',
pre:['real_analysis','prop_logic'],
books:[
  {t:'Signals and Systems',a:'Oppenheim, Willsky & Nawab',n:'The MIT standard. Thorough. Work every problem.'},
  {t:'Signals and Systems',a:'Haykin & Van Veen',n:'Clean alternative.'},
],lec:[
  {t:'MIT 6.003: Signals and Systems (OCW)',u:'https://ocw.mit.edu/courses/6-003-signals-and-systems-fall-2011/',type:'course'},
  {t:'Alan Oppenheim: Signals and Systems (MIT YouTube)',u:'https://www.youtube.com/playlist?list=PL41692B571DD0AF9B',type:'video'},
]},

// ─── TIER 3 ────────────────────────────────────────────────────────
metalogic:{tier:3,cat:'found',label:'Metalogic & Proof Theory',
desc:'Soundness, completeness (Gödel 1930), Gödel incompleteness I & II (1931), Tarski undefinability of truth, cut elimination (Gentzen 1935), formal provability, arithmetical hierarchy (Σ/Π/Δ).',
figures:'Gödel (incompleteness, 1931 — at 25 years old), Tarski (truth, 1936), Gentzen (cut elimination, 1935), Löb (provability)',
jonathan:'Incompleteness is not a curiosity — it defines the limits of formal systems, which defines the limits of computation and AI.',
pre:['pred_logic','model_theory','axiomatic_set'],
books:[
  {t:"Gödel's Incompleteness Theorem",a:'V. A. Uspenskiy',n:'Soviet. The clearest short exposition in any language.',soviet:true},
  {t:'Introduction to Mathematical Logic',a:'A. A. Markov & N. M. Nagorny',n:'Soviet. Constructive emphasis. Very rigorous.',soviet:true,hard:true},
  {t:"Über formal unentscheidbare Sätze…",a:'Kurt Gödel (1931)',n:'The incompleteness papers. Primary source.',primary:true,soviet:true},
  {t:'Structural Proof Theory',a:'Negri & von Plato',n:'Sequent calculus, cut elimination.'},
  {t:"Gödel's Proof",a:'Nagel & Newman',n:'Short, beautiful. Non-technical entry — read first.'},
],lec:[
  {t:'Peter Smith: Gödel Without Tears (free PDF)',u:'https://www.logicmatters.net/resources/pdfs/gwt/GWT.pdf',type:'book-free'},
]},

hilbert_deep:{tier:3,cat:'canon',label:'★ Hilbert: Programme & Problems',
canon:true,
desc:'Hilbert\'s 23 problems (1900), the formalist programme (consistency + completeness as goals), epsilon calculus, the Entscheidungsproblem — and understanding what Gödel (1931) and Turing (1936) destroyed and why. The most important failed programme in history.',
figures:'David Hilbert (1862–1943) — the most influential mathematician of the 20th century. His programme shaped all of logic, CS, and AI foundations.',
jonathan:'Understanding Hilbert\'s programme is understanding why computation has limits. Every theoretical CS result lives in Hilbert\'s shadow.',
pre:['pred_logic','real_analysis','axiomatic_set','metalogic'],
books:[
  {t:'Mathematical Problems',a:'David Hilbert (1900)',n:'The 23 problems address. Free online. Primary source.',primary:true,soviet:true},
  {t:'Foundations of Mathematics (2 vols.)',a:'Hilbert & Bernays',n:'The programme from the source. Extremely hard.',hard:true,soviet:true,primary:true},
  {t:'Hilbert',a:'Constance Reid',n:'The definitive biography. Essential context for all of 20th century math.'},
  {t:'Methods of Mathematical Physics',a:'Hilbert & Courant',n:'Hilbert spaces meet physics. Graduate level.',hard:true},
],lec:[
  {t:'Hilbert: Mathematical Problems 1900 (free)',u:'https://mathcs.clarku.edu/~djoyce/hilbert/problems.html',type:'book-free'},
  {t:'SEP: Hilbert\'s Program',u:'https://plato.stanford.edu/entries/hilbert-program/',type:'notes'},
]},

type_theory:{tier:3,cat:'cs',label:'Type Theory & λ-Calculus',
desc:'Untyped λ-calculus (Church 1936), Church-Rosser theorem, simply-typed λ-calculus, Curry-Howard correspondence (proofs = programs), System F (Girard), dependent types, Martin-Löf Type Theory (MLTT), Homotopy Type Theory.',
figures:'Church (λ-calculus, 1936 — same year as Turing), Curry, Howard (correspondence, 1969), Martin-Löf (MLTT, 1975), Girard (System F, 1972)',
jonathan:'The Curry-Howard isomorphism means every program has a proof and every proof has a program. This is the deep unity under CS theory. Essential before formal verification.',
pre:['pred_logic','model_theory','abstract_alg'],
books:[
  {t:'Types and Programming Languages',a:'Benjamin Pierce',n:'Theory-first. Pedagogically excellent. The standard.',hard:true},
  {t:'Lambda Calculus: Its Syntax and Semantics',a:'H. P. Barendregt',n:'The definitive reference. Very dense.',hard:true},
  {t:'Lectures on the Curry-Howard Isomorphism',a:'Sørensen & Urzyczyn',n:'Free online. Rigorous.',},
  {t:'Homotopy Type Theory',a:'Univalent Foundations Program',n:'Free online. Types as spaces. Advanced.',hard:true},
],lec:[
  {t:'Oregon PL Summer School (lecture videos)',u:'https://www.cs.uoregon.edu/research/summerschool/',type:'video'},
  {t:'HoTT Book (free PDF)',u:'https://homotopytypetheory.org/book/',type:'book-free'},
]},

cat_theory:{tier:3,cat:'math',label:'Category Theory',
desc:'Categories, functors, natural transformations, Yoneda lemma, adjoint functors, limits/colimits, monads, topoi. The mathematics of mathematical structure — unifies algebra, topology, logic, and computation.',
figures:'Mac Lane & Eilenberg (1945), Lawvere (categorical logic, 1963), Grothendieck (topoi), Kan (adjunctions, 1958)',
jonathan:'Category theory is the abstraction layer over all of mathematics. Monads in Haskell are a shadow of categorical monads. This makes type theory, PL semantics, and logic unify.',
pre:['abstract_alg','naive_set','pred_logic'],
books:[
  {t:'Categories for the Working Mathematician',a:'Saunders Mac Lane',n:'The canonical text. Extremely dense.',hard:true,primary:true},
  {t:'Category Theory',a:'Steve Awodey',n:'Most accessible rigorous introduction. Free online.'},
  {t:'Conceptual Mathematics',a:'Lawvere & Schanuel',n:'Category theory from absolute scratch. Start here.'},
],lec:[
  {t:'Awodey: Category Theory (free PDF)',u:'https://www.andrew.cmu.edu/course/80-413-713/notes/',type:'book-free'},
  {t:'Bartosz Milewski: Category Theory (YouTube)',u:'https://www.youtube.com/playlist?list=PLbgaMIhjbmEnaH_LTkxLI7FMa2HsnawM_',type:'video'},
]},

linear_alg:{tier:3,cat:'math',label:'Linear Algebra (Structural)',
desc:'Vector spaces over arbitrary fields, linear maps, quotient/dual spaces, tensor products, eigenspectrum, Jordan form, inner product spaces, SVD. Structural, not computational — you already know the computation.',
figures:'Cayley (matrices, 1858), Hamilton (quaternions), Sylvester, Peano (vector spaces, 1888), Hilbert (infinite-dimensional)',
jonathan:'You know matrix multiplication. Now learn what a vector space actually is. Shilov is the book — it is the clearest rigorous treatment in any language.',
pre:['proof','naive_set','abstract_alg','real_analysis'],
books:[
  {t:'Linear Algebra',a:'G. E. Shilov',n:'Soviet. Rigorous, geometric, superior to anything Western at this level.',soviet:true,hard:true},
  {t:'Problems in Linear Algebra',a:'I. V. Proskuryakov',n:'Soviet. 2000 problems. Essential drill.',soviet:true},
  {t:'Linear Algebra Done Right',a:'Sheldon Axler',n:'No determinants early. Pure structure. Excellent.'},
  {t:'Finite-Dimensional Vector Spaces',a:'Paul Halmos',n:'Abstract and elegant. Short.'},
],lec:[
  {t:'MIT 18.06: Linear Algebra — Strang (OCW)',u:'https://ocw.mit.edu/courses/18-06-linear-algebra-spring-2010/',type:'course'},
]},

number_theory:{tier:3,cat:'math',label:'Number Theory',
desc:'Divisibility, primes, prime number theorem, congruences, quadratic reciprocity, Diophantine equations, algebraic integers, p-adic numbers, zeta function, Riemann hypothesis.',
figures:'Euclid (primes infinite), Euler (∑1/p diverges), Gauss (quadratic reciprocity, Disquisitiones 1801), Riemann (zeta, 1859), Wiles (FLT, 1995)',
pre:['abstract_alg','arithmetic_found','combinatorics'],
books:[
  {t:'Elements of Number Theory',a:'I. M. Vinogradov',n:'Soviet grandmaster. Terse and complete.',soviet:true,hard:true},
  {t:'Introduction to Number Theory',a:'A. A. Bukhshtab',n:'Soviet. Thorough and rigorous.',soviet:true},
  {t:'Disquisitiones Arithmeticae',a:'Carl Friedrich Gauss (1801)',n:'Number theory made rigorous. Primary source.',primary:true,soviet:true},
  {t:'A Classical Introduction to Modern Number Theory',a:'Ireland & Rosen',n:'Western graduate standard.'},
],lec:[
  {t:'MIT 18.781: Theory of Numbers (OCW)',u:'https://ocw.mit.edu/courses/18-781-theory-of-numbers-spring-2012/',type:'course'},
]},

graph_theory:{tier:3,cat:'math',label:'Graph Theory',
desc:'Graphs, trees, matchings (Hall\'s theorem), colorings (four-colour theorem), network flows (max-flow min-cut, Ford-Fulkerson), planarity (Kuratowski), Ramsey theory, spectral graph theory.',
figures:'Euler (Königsberg bridges, 1736 — first graph theory result), Cayley (trees), Ramsey, Erdős, Appel & Haken (four-colour, 1976)',
jonathan:'You already know graph algorithms from ICPC. Now prove them from structural graph theory. Diestel is free and definitive.',
pre:['combinatorics','proof'],
books:[
  {t:'Graph Theory',a:'Reinhard Diestel',n:'Free online. Definitive graduate text. Essential.',},
  {t:'Introduction to Graph Theory',a:'Douglas West',n:'Proof-heavy undergraduate standard.'},
  {t:'Solvability of Equations in Integers',a:'Various Soviet sources',n:'See Vinogradov for graph-adjacent number problems.',soviet:true},
],lec:[
  {t:'Diestel: Graph Theory (free PDF)',u:'https://diestel-graph-theory.com/',type:'book-free'},
]},

topology:{tier:3,cat:'math',label:'Point-Set Topology',
desc:'Topological spaces, open/closed sets, continuous maps, compactness, connectedness, separation axioms (T0–T4), Tychonoff theorem, product topology, quotient spaces, metric topology.',
figures:'Cantor (point sets), Fréchet (metric spaces, 1906), Hausdorff (Grundzüge, 1914), Tychonoff (product theorem)',
pre:['real_analysis','abstract_alg'],
books:[
  {t:'Topology',a:'James Munkres',n:'The gold standard. Extremely clear. Do every problem.',},
  {t:'General Topology',a:'N. Bourbaki',n:'French formalist. Complete. Very hard.',hard:true},
  {t:'Topology',a:'K. Jänich',n:'Short, beautiful geometric intuition. Read alongside Munkres.'},
],lec:[
  {t:'MIT 18.901: Introduction to Topology (OCW)',u:'https://ocw.mit.edu/courses/18-901-introduction-to-topology-fall-2004/',type:'course'},
]},

measure_theory:{tier:3,cat:'math',label:'Measure Theory',
desc:'σ-algebras, Lebesgue measure, measurable functions, Lebesgue integral, L^p spaces, Radon-Nikodym theorem, product measures, Fubini-Tonelli. Required before any rigorous probability.',
figures:'Borel (measurable sets), Lebesgue (Intégrale, 1902), Carathéodory, Radon, Nikodym',
pre:['real_analysis','axiomatic_set'],
books:[
  {t:'Real Analysis',a:'G. E. Shilov & B. L. Gurevich',n:'Soviet. Measure + integration rigorously. The best short treatment.',soviet:true,hard:true},
  {t:'Introductory Real Analysis',a:'A. N. Kolmogorov & S. V. Fomin',n:'Soviet grandmasters. Normed spaces included.',soviet:true},
  {t:'Measure Theory',a:'Paul Halmos',n:'Classic. Abstract measure from scratch.'},
  {t:'Real Analysis: Measure Theory…',a:'Stein & Shakarchi',n:'Princeton Lectures. Very clear.'},
],lec:[
  {t:'MIT 18.125: Measure and Integration (OCW)',u:'https://ocw.mit.edu/courses/18-125-measure-and-integration-fall-2003/',type:'course'},
]},

formal_sem:{tier:3,cat:'ling',label:'Formal Semantics',
desc:'Compositionality, λ-calculus applied to natural language meaning, type-theoretic semantics, quantifier scope, intensionality, possible worlds semantics, Montague grammar, model-theoretic truth conditions.',
figures:'Montague (1970 — applied mathematical logic to natural language), Frege (sense/reference), Kripke (possible worlds), Heim & Kratzer',
pre:['pred_logic','struct_ling','phil_lang','type_theory'],
books:[
  {t:'Semantics in Generative Grammar',a:'Heim & Kratzer',n:'The rigorous graduate standard. Dense.',hard:true},
  {t:'Mathematical Methods in Linguistics',a:'Partee, ter Meulen & Wall',n:'Logic, sets, algebra for linguists. Best entry.',},
  {t:'Formal Philosophy',a:'Richard Montague (1974)',n:'Montague grammar primary source.',primary:true,soviet:true},
],lec:[
  {t:'Partee: Mathematical Methods (free PDF)',u:'https://people.umass.edu/partee/MGU_2005/MGU055.pdf',type:'book-free'},
]},

phonology:{tier:3,cat:'ling',label:'Phonology',
desc:'Phonemes, allophones, distinctive features (SPE system), phonological rules, syllable structure, moraic theory, prosody, Optimality Theory (Prince & Smolensky), autosegmental phonology.',
figures:'Jakobson (distinctive features), Chomsky & Halle (Sound Pattern of English, 1968), Prince & Smolensky (OT, 1993)',
pre:['struct_ling'],
books:[
  {t:'The Sound Pattern of English',a:'Chomsky & Halle (1968)',n:'The foundational generative phonology text. Dense.',hard:true,primary:true},
  {t:'Phonology: An Introduction',a:'Roger Lass',n:'Rigorous and broad historical coverage.'},
  {t:'Introductory Phonology',a:'Bruce Hayes',n:'Modern. OT included.'},
],lec:[
  {t:'MIT 24.901: Sound Structure of Language (OCW)',u:'https://ocw.mit.edu/courses/24-901-language-and-its-structure-i-phonology-fall-2010/',type:'course'},
]},

vlsi:{tier:3,cat:'hw',label:'VLSI & Digital Design',
desc:'CMOS transistor physics (field effect, saturation region), logic gate CMOS implementation, timing analysis (setup/hold times), standard cell design, SRAM/DRAM cells, power analysis (dynamic/static), RTL design, synthesis, FPGA architecture. Entirely learnable without a fab.',
figures:'Noyce & Kilby (IC, 1958–59), Mead & Conway (VLSI design methodology, 1980), Moore (Moore\'s law, 1965)',
jonathan:'FPGA work is excellent homelab. You program the silicon itself — no lab required beyond a ~$50 board.',
pre:['computer_arch','boolean_logic_hw'],
books:[
  {t:'CMOS VLSI Design',a:'Weste & Harris',n:'The standard. CMOS from physics to system. Excellent.'},
  {t:'Introduction to VLSI Systems',a:'Mead & Conway (1980)',n:'The foundational methodology. Primary source.',primary:true,soviet:true},
  {t:'Digital Integrated Circuits',a:'Rabaey, Chandrakasan & Nikolic',n:'Comprehensive. Industry-aligned.'},
  {t:'FPGA Prototyping by VHDL Examples',a:'Pong P. Chu',n:'HDL on real hardware. Good for homelab.'},
],lec:[
  {t:'MIT 6.374: Analysis and Design of Digital ICs (OCW)',u:'https://ocw.mit.edu/courses/6-374-analysis-and-design-of-digital-integrated-circuits-fall-2003/',type:'course'},
  {t:'FPGA4Fun — practical FPGA projects',u:'https://www.fpga4fun.com/',type:'tool'},
  {t:'Lattice iCE40 + icestorm toolchain (open source FPGA)',u:'https://clifford.at/icestorm/',type:'tool'},
]},

// ─── TIER 4 ────────────────────────────────────────────────────────
computability:{tier:4,cat:'cs',label:'Computability Theory',
desc:'Turing machines, Church-Turing thesis, decidability, the halting problem, Rice\'s theorem, many-one reductions, Turing reductions, oracle TMs, arithmetical hierarchy (Σ/Π/Δ), Kleene recursion theorem, μ-recursive functions, Markov algorithms.',
figures:'Turing (TM, 1936 — same year as Church\'s λ-calculus), Church, Kleene, Post (correspondence problem), Gödel (recursive functions), Markov (Soviet version)',
jonathan:'You think in algorithms. This is where algorithms meet their absolute limits. The halting problem is the foundation of all undecidability results in CS.',
pre:['metalogic','pred_logic','proof','type_theory'],
books:[
  {t:'Theory of Algorithms',a:'A. A. Markov (1954)',n:'Soviet founder of computability. Markov algorithms. Primary source.',soviet:true,primary:true,hard:true},
  {t:'Computability',a:'A. Shen & N. K. Vereshchagin',n:'Soviet. Short, rigorous, free online. Start here.',soviet:true},
  {t:'Introduction to the Theory of Computation',a:'Michael Sipser',n:'The pedagogical standard. Clear.'},
  {t:'Computability and Logic',a:'Boolos, Burgess & Jeffrey',n:'Logic-first. Dense and rewarding.',hard:true},
  {t:'On Computable Numbers…',a:'Alan Turing (1936)',n:'The primary source. 36 pages. Read it.',primary:true,soviet:true},
],lec:[
  {t:'MIT 18.404J: Theory of Computation (OCW)',u:'https://ocw.mit.edu/courses/18-404j-theory-of-computation-fall-2020/',type:'course'},
  {t:'Shen & Vereshchagin: Computability (free)',u:'https://www.lmcs-online.org/',type:'book-free'},
]},

turing_deep:{tier:4,cat:'canon',label:'★ Turing: Full Contributions',
canon:true,
desc:'Turing machines and computability (1936), oracle machines and the arithmetical hierarchy (1938 PhD), the Turing test as philosophical analysis (1950), morphogenesis via reaction-diffusion PDEs (1952), ACE computer design (1945). The most consequential papers in the history of CS.',
figures:'Alan Turing (1912–1954): invented the theoretical computer (1936), broke Enigma, defined machine intelligence, discovered biological pattern formation.',
jonathan:'Turing\'s 1936 paper directly defines what your algorithms can and cannot do. His 1950 paper defines the question your career may be trying to answer.',
pre:['computability','metalogic','phil_mind'],
books:[
  {t:'On Computable Numbers, with an Application to the Entscheidungsproblem',a:'Alan Turing (1936)',n:'36 pages. The birth of theoretical computer science.',primary:true,soviet:true},
  {t:'Computing Machinery and Intelligence',a:'Alan Turing (1950)',n:'The Turing test paper. 30 pages.',primary:true,soviet:true},
  {t:'The Chemical Basis of Morphogenesis',a:'Alan Turing (1952)',n:'Stunning applied mathematics.',primary:true,soviet:true},
