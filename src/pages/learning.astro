  {t:'Computer Architecture: A Quantitative Approach',a:'Hennessy & Patterson',n:'GPU/accelerator architecture chapters.',hard:true},
],lec:[
  {t:'Sze et al.: Efficient Deep Learning (free PDF)',u:'https://efficientml.ai/',type:'book-free'},
  {t:'MIT 6.5930: Hardware Architecture for Deep Learning (OCW)',u:'https://ocw.mit.edu/courses/6-5930-hardware-architecture-for-deep-learning-fall-2022/',type:'course'},
  {t:'Stanford CS217: Hardware Accelerators for ML',u:'https://cs217.stanford.edu/',type:'course'},
]},

