  {t:'Mathematical Methods of Classical Mechanics',a:'V. I. Arnold',n:'Soviet. Lagrangian mechanics geometrically.',soviet:true},
],lec:[
  {t:'Gelfand & Fomin (free archive)',u:'https://archive.org/details/calculus-of-variations-gelfand-fomin',type:'book-free'},
