]},

cog_sci:{tier:4,cat:'phil',label:'Cognitive Science',
desc:'Mental representation, perception, memory, language processing, reasoning — studied computationally and empirically. The interdisciplinary root of AI: how does a physical system produce mind-like behaviour?',
figures:'Miller, Galanter & Pribram (Plans and the Structure of Behavior, 1960 — the founding cognitive science text), Fodor (Language of Thought), Rosch (prototype theory)',
pre:['phil_mind','struct_ling','phil_sci'],
books:[
  {t:'Plans and the Structure of Behavior',a:'Miller, Galanter & Pribram (1960)',n:'The founding cognitive science text.',primary:true,soviet:true},
  {t:'The Language of Thought',a:'Jerry Fodor',n:'Mentalese and the representational theory of mind.'},
  {t:'How the Mind Works',a:'Steven Pinker',n:'Computational theory of mind, accessible.'},
],lec:[
  {t:'MIT 9.00SC: Introduction to Psychology (OCW)',u:'https://ocw.mit.edu/courses/9-00sc-introduction-to-psychology-fall-2011/',type:'course'},
