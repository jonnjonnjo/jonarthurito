---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { id: post.id } }));
}

const { id } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find(p => p.id === id)!;
const { Content, headings } = await render(post);

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readTime = Math.max(1, Math.ceil(wordCount / 225));
---

<Layout title={post.data.title}>
<div class="bg-kanagawa-bgDim min-h-screen pb-20">
    <div id="layout-container" class="flex justify-center items-start gap-12 max-w-7xl mx-auto px-8 py-10 transition-all duration-300">
      
      <aside id="toc-sidebar" class="w-64 shrink-0 sticky top-12 h-fit hidden lg:block">
        <nav class="border-l border-kanagawa-bgHighlight/40 pl-5">
          <div class="text-[10px] font-mono text-kanagawa-comment uppercase tracking-[0.2em] mb-6">
            Outline
          </div>
          <ul class="space-y-3 toc-list">
            {headings.map(h => (
              <li class={`depth-${h.depth}`}>
                <a 
                  href={'#' + h.slug} 
                  data-slug={h.slug}
                  class="toc-link block text-[14px] font-mono text-kanagawa-fgDim hover:text-kanagawa-yellow transition-all leading-tight border-l-2 border-transparent -ml-[22px] pl-[20px]"
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

<article id="main-article" class="w-full max-w-[720px] shrink-0 font-sans">
        <header class="mb-12 flex flex-col items-center text-center border-b border-kanagawa-bgHighlight/40 pb-8">
          <h1 class="text-3xl sm:text-4xl font-normal text-kanagawa-fg leading-tight mb-6">
            {post.data.title}
          </h1>
          
          <div class="flex flex-col items-center gap-1.5 text-[15px] text-kanagawa-fgDim">
            <span class="text-kanagawa-fg">Jonathan Sinaga</span>
            <span>Independent Researcher</span>
            <span>{post.data.date}</span>
          </div>

          <div class="mt-6 font-mono text-[11px] text-kanagawa-comment uppercase tracking-widest flex gap-4">
            <span>Words: {wordCount}</span>
            <span>&bull;</span>
            <span>Time: {readTime} min</span>
          </div>
        </header>

        <div class="prose-kanagawa pt-0">
          <Content />
        </div>
      </article>
    </div>
  </div>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        document.querySelectorAll('.toc-link').forEach(l => l.classList.remove('text-kanagawa-yellow', 'font-bold', 'border-kanagawa-yellow'));
        const active = document.querySelector(`.toc-link[data-slug="${entry.target.id}"]`);
        active?.classList.add('text-kanagawa-yellow', 'font-bold', 'border-kanagawa-yellow');
      }
    });
  }, { rootMargin: '-5% 0px -80% 0px' });

  document.querySelectorAll('h2, h3').forEach(h => observer.observe(h));

  document.addEventListener('toggle-toc', () => {
    const sidebar = document.getElementById('toc-sidebar');
    if (sidebar) sidebar.classList.toggle('lg:hidden');
  });
</script>

<style is:global>
  .prose-kanagawa { 
    font-size: 16px; 
    line-height: 1.6; 
    color: var(--color-kanagawa-fg);
    text-align: justify;
  }

  .prose-kanagawa > p:first-of-type { margin-top: 0; }

  .prose-kanagawa h2 { font-size: 1.4rem; color: var(--color-kanagawa-yellow); margin: 2rem 0 0.5rem; font-weight: normal; scroll-margin-top: 3rem; }
  .prose-kanagawa p { margin-bottom: 1rem; }

  .prose-kanagawa pre {
    background: #181616 !important;
    padding: 1.25rem;
    border: 1px solid var(--color-kanagawa-bgHighlight);
    font-size: 14px;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .toc-list { counter-reset: h2-counter; }
  .toc-list li.depth-2 { counter-reset: h3-counter; counter-increment: h2-counter; }
  .toc-list li.depth-3 { counter-increment: h3-counter; padding-left: 1rem; }

  .toc-list li.depth-2 .toc-link::before { content: counter(h2-counter) ". "; color: var(--color-kanagawa-comment); margin-right: 0.5rem; }
  .toc-list li.depth-3 .toc-link::before { content: counter(h2-counter) "." counter(h3-counter) " "; color: var(--color-kanagawa-comment); margin-right: 0.5rem; }
</style>
